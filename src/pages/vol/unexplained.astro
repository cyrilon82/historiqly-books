---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import EmailCapture from '../../components/EmailCapture.astro';
const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;
---

<SidebarLayout title="Vol 8: Unexplained Phenomena" currentVolume={8}>
  <div class="volume-page">
    <div class="volume-header">
      <div class="volume-header-glow"></div>
      <div class="volume-header-inner">
        <div class="volume-meta">
          <span class="volume-number">Vol 8</span>
        </div>
        <!-- Headline rule -->
        <div class="headline-rule">
          <svg class="rule-star" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 2L9.5 6.5L14 8L9.5 9.5L8 14L6.5 9.5L2 8L6.5 6.5Z" />
          </svg>
          <span class="rule-line"></span>
          <svg class="rule-diamond" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
            <path d="M6 1L8.5 6L6 11L3.5 6Z" />
          </svg>
          <span class="rule-line"></span>
          <svg class="rule-star" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 2L9.5 6.5L14 8L9.5 9.5L8 14L6.5 9.5L2 8L6.5 6.5Z" />
          </svg>
        </div>
        <h1>Unexplained Phenomena</h1>
        <p class="volume-subtitle">Phenomena beyond explanation</p>
      </div>
    </div>

    <div class="volume-intro">
      <div class="intro-accent"></div>
      <p>
        Events that defy easy explanation. We apply scientific methodology to separate the genuinely puzzling
        from the easily debunked, examining UFO sightings, paranormal claims, and anomalous events.
      </p>
    </div>

    <div class="section-divider">
      <span class="divider-line"></span>
      <svg class="divider-glyph" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 2L9.5 6.5L14 8L9.5 9.5L8 14L6.5 9.5L2 8L6.5 6.5Z" />
      </svg>
      <span class="divider-line"></span>
    </div>

    <div class="cases-section" id="cases">
      <div class="cases-header">
        <h2>Cases</h2>
        <span class="cases-count">8 cases</span>
      </div>
      <div class="cases-preview">
        <div class="case-preview"><span class="case-num">01</span><span class="case-title">The Dyatlov Pass Incident</span><div class="case-btns"><a href="/cases/dyatlov-pass" class="btn-read">Read Case</a><button onclick={`window.location.href='${stripeUrl}'`} class="btn-buy-sm">Buy $2.99</button><a href="https://www.amazon.com/dp/B0GQSVJHTW" target="_blank" rel="noopener" class="btn-kindle-sm">Kindle</a></div></div>
        <div class="case-preview"><span class="case-num">02</span><span class="case-title">The Loch Ness Monster</span><div class="case-btns"><a href="/cases/loch-ness-monster" class="btn-read">Read Case</a><button onclick={`window.location.href='${stripeUrl}'`} class="btn-buy-sm">Buy $2.99</button></div></div>
        <div class="case-preview"><span class="case-num">03</span><span class="case-title">The Wow! Signal</span><div class="case-btns"><a href="/cases/wow-signal" class="btn-read">Read Case</a><button onclick={`window.location.href='${stripeUrl}'`} class="btn-buy-sm">Buy $2.99</button></div></div>
        <div class="case-preview"><span class="case-num">04</span><span class="case-title">The Shroud of Turin</span><div class="case-btns"><a href="/cases/shroud-of-turin" class="btn-read">Read Case</a><button onclick={`localStorage.setItem('historiqly_purchasing','shroud-of-turin');window.location.href='${stripeUrl}'`} class="btn-buy-sm" id="shroud-of-turinBuyPill">Buy $2.99</button><a href="/books/epub/shroud-of-turin.epub" class="btn-read" id="shroud-of-turinDownloadPill" style="display:none;" download>Download</a></div></div>
        <div class="case-preview"><span class="case-num">05</span><span class="case-title">The Dancing Plague of 1518</span><div class="case-btns"><a href="/cases/dancing-plague" class="btn-read">Read Case</a><button onclick={`localStorage.setItem('historiqly_purchasing','dancing-plague');window.location.href='${stripeUrl}'`} class="btn-buy-sm" id="dancing-plagueBuyPill">Buy $2.99</button><a href="/books/dancing-plague.epub" class="btn-free-sm" id="dancing-plagueDownloadPill" style="display:none;" download>Download</a></div></div>
        <div class="case-preview"><span class="case-num">06</span><span class="case-title">The Tunguska Event</span><div class="case-btns"><a href="/cases/tunguska-event" class="btn-read">Read Case</a><button onclick={`localStorage.setItem('historiqly_purchasing','tunguska-event');window.location.href='${stripeUrl}'`} class="btn-buy-sm" id="tunguska-eventBuyPill">Buy $2.99</button><a href="/books/tunguska-event.epub" class="btn-read" id="tunguska-eventDownloadPill" style="display:none;" download>Download</a></div></div>
        <div class="case-preview"><span class="case-num">07</span><span class="case-title">Ball Lightning</span><div class="case-btns"><a href="/cases/ball-lightning" class="btn-read">Read Case</a><button onclick={`localStorage.setItem('historiqly_purchasing','ball-lightning');window.location.href='${stripeUrl}'`} class="btn-buy-sm" id="ball-lightningBuyPill">Buy $2.99</button><a href="/books/epub/ball-lightning.epub" class="btn-read" id="ball-lightningDownloadPill" style="display:none;" download>Download</a></div></div>
        <div class="case-preview"><span class="case-num">08</span><span class="case-title">The Hessdalen Lights</span><div class="case-btns"><a href="/cases/hessdalen-lights" class="btn-read">Read Case</a><button onclick={`localStorage.setItem('historiqly_purchasing','hessdalen-lights');window.location.href='${stripeUrl}'`} class="btn-buy-sm" id="hessdalen-lightsBuyPill">Buy $2.99</button><a href="/books/epub/hessdalen-lights.epub" class="btn-read" id="hessdalen-lightsDownloadPill" style="display:none;" download>Download</a></div></div>
      </div>
    </div>

    <div class="email-section"><EmailCapture /></div>

    <div class="available-now">
      <p>While you wait, check out:</p>
      <a href="/vol/hoaxes" class="vol-link">
        <span class="vol-badge soon">Soon</span>
        <span>Vol 1: Hoaxes, Forgeries & Frauds</span>
        <span class="arrow">→</span>
      </a>
    </div>
  </div>
</SidebarLayout>

<script>
  // Check each paid book in this volume
  ['dyatlov-pass', 'loch-ness-monster', 'wow-signal', 'shroud-of-turin', 'dancing-plague', 'tunguska-event', 'ball-lightning', 'hessdalen-lights'].forEach(slug => {
    if (localStorage.getItem(`historiqly_purchased_${slug}`) === 'true') {
      const buyPill = document.getElementById(`${slug}BuyPill`);
      const downloadPill = document.getElementById(`${slug}DownloadPill`);
      if (buyPill) buyPill.style.display = 'none';
      if (downloadPill) downloadPill.style.display = 'inline-flex';
    }
  });
</script>

<style>
  .volume-page { max-width: 820px; margin: 0 auto; }

  /* Header */
  .volume-header {
    position: relative;
    margin-bottom: 2.5rem;
    padding: 2.5rem 0 0;
    overflow: hidden;
  }

  .volume-header-glow {
    position: absolute;
    top: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(227, 171, 113, 0.08) 0%, transparent 70%);
    pointer-events: none;
    animation: glow-breathe 8s ease-in-out infinite;
  }

  @keyframes glow-breathe {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }

  .volume-header-inner { position: relative; z-index: 1; }
  .volume-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }

  .volume-number {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Headline rule */
  .headline-rule {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    max-width: 280px;
    margin-bottom: 0.5rem;
  }

  .rule-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(227, 171, 113, 0.3) 30%,
      rgba(227, 171, 113, 0.3) 70%,
      transparent
    );
  }

  .rule-star {
    width: 10px;
    height: 10px;
    color: rgba(227, 171, 113, 0.4);
    flex-shrink: 0;
  }

  .rule-diamond {
    width: 8px;
    height: 8px;
    color: rgba(227, 171, 113, 0.3);
    flex-shrink: 0;
  }

  .volume-header h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 800;
    margin-bottom: 0.5rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--foreground);
    text-shadow: 0 2px 12px rgba(0,0,0,0.4);
  }

  .volume-subtitle {
    font-family: 'Playfair Display', Georgia, serif;
    color: rgba(227, 171, 113, 0.6);
    font-size: 1.0625rem;
    font-style: italic;
    line-height: 1.5;
  }

  /* Intro — premium double-border */
  .volume-intro {
    padding: 1.75rem;
    background: #1a1815;
    border: 1px solid rgba(227, 171, 113, 0.1);
    border-radius: 4px;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
    box-shadow:
      inset 0 0 0 3px rgba(15, 12, 8, 0.8),
      inset 0 0 0 4px rgba(227, 171, 113, 0.05);
  }

  .intro-accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(180deg, var(--gold), rgba(227, 171, 113, 0.2));
    border-radius: 3px 0 0 3px;
  }

  .volume-intro p {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--foreground-muted);
    margin: 0;
    padding-left: 0.75rem;
  }

  /* Section divider — star glyph */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0.5rem auto 2rem;
    max-width: 200px;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(227, 171, 113, 0.25));
  }

  .divider-line:last-child {
    background: linear-gradient(90deg, rgba(227, 171, 113, 0.25), transparent);
  }

  .divider-glyph {
    width: 12px;
    height: 12px;
    color: rgba(227, 171, 113, 0.35);
    flex-shrink: 0;
    animation: slow-rotate 20s linear infinite;
  }

  @keyframes slow-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Cases Section */
  .cases-header { display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 1.25rem; }

  .cases-section h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--foreground);
  }

  .cases-count {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.7rem;
    color: var(--muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .cases-preview { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 2.5rem; }

  .case-preview {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: #1a1815;
    border: 1px solid rgba(227, 171, 113, 0.08);
    border-radius: 4px;
    color: var(--foreground-muted);
    transition: all 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
    position: relative;
  }

  /* Inner border on case rows */
  .case-preview::before {
    content: '';
    position: absolute;
    inset: 3px;
    border: 1px solid rgba(227, 171, 113, 0.03);
    border-radius: 2px;
    pointer-events: none;
    transition: border-color 0.35s ease;
  }

  .case-preview:hover {
    border-color: rgba(227, 171, 113, 0.25);
    transform: translateX(6px);
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.3),
      0 0 20px rgba(227, 171, 113, 0.04);
  }

  .case-preview:hover::before {
    border-color: rgba(227, 171, 113, 0.08);
  }

  .case-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    height: 28px;
    padding: 0 0.375rem;
    background: rgba(227, 171, 113, 0.08);
    border: 1px solid rgba(227, 171, 113, 0.1);
    border-radius: 3px;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--gold);
    flex-shrink: 0;
    letter-spacing: 0.04em;
    transition: all 0.3s;
  }

  .case-preview:hover .case-num {
    background: rgba(227, 171, 113, 0.14);
    border-color: rgba(227, 171, 113, 0.2);
  }

  .case-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--foreground);
    transition: color 0.3s;
  }

  .case-preview:hover .case-title {
    color: var(--gold-light);
  }

  /* Email Section */
  .email-section { margin-bottom: 2rem; }

  /* Buttons — premium with corner dots */
  .case-btns { display: flex; gap: 0.5rem; margin-left: auto; flex-shrink: 0; }

  .btn-read {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    background: rgba(227, 171, 113, 0.06);
    border: 1px solid rgba(227, 171, 113, 0.25);
    color: var(--gold);
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 3px;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
    white-space: nowrap;
    position: relative;
    box-shadow:
      inset 0 0 0 2px rgba(15, 12, 8, 0.8),
      inset 0 0 0 3px rgba(227, 171, 113, 0.06);
  }

  .btn-read:hover {
    background: rgba(227, 171, 113, 0.12);
    border-color: rgba(227, 171, 113, 0.4);
    color: var(--gold-light);
    box-shadow:
      inset 0 0 0 2px rgba(15, 12, 8, 0.7),
      inset 0 0 0 3px rgba(227, 171, 113, 0.12),
      0 0 12px rgba(227, 171, 113, 0.08);
  }

  .btn-buy-sm {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    background: linear-gradient(180deg, #6a5848 0%, #4e4235 100%);
    color: #fff;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 3px;
    border: 1px solid rgba(227, 171, 113, 0.3);
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
    white-space: nowrap;
    position: relative;
    box-shadow:
      inset 0 0 0 2px rgba(78, 66, 53, 0.5),
      inset 0 0 0 3px rgba(227, 171, 113, 0.12);
  }

  .btn-buy-sm:hover {
    border-color: rgba(227, 171, 113, 0.5);
    transform: translateY(-1px);
    box-shadow:
      inset 0 0 0 2px rgba(78, 66, 53, 0.4),
      inset 0 0 0 3px rgba(227, 171, 113, 0.2),
      0 0 16px rgba(227, 171, 113, 0.15);
  }

  .btn-free-sm {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    background: linear-gradient(180deg, #6a5848 0%, #4e4235 100%);
    color: #fff;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 3px;
    border: 1px solid rgba(227, 171, 113, 0.3);
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
    white-space: nowrap;
  }

  .btn-free-sm:hover {
    border-color: rgba(227, 171, 113, 0.5);
    box-shadow: 0 0 16px rgba(227, 171, 113, 0.15);
  }

  .btn-kindle-sm {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    background: rgba(245, 158, 11, 0.06);
    border: 1px solid rgba(245, 158, 11, 0.4);
    color: #F59E0B;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 3px;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
    white-space: nowrap;
  }

  .btn-kindle-sm:hover {
    background: rgba(245, 158, 11, 0.1);
    border-color: rgba(245, 158, 11, 0.6);
    box-shadow: 0 0 12px rgba(245, 158, 11, 0.08);
  }

  .btn-soon {
    margin-left: auto;
    color: var(--muted);
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Available Now / Cross-links */
  .available-now { text-align: center; margin-bottom: 1rem; }

  .available-now > p {
    color: var(--muted);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
  }

  .vol-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.5rem;
    background: rgba(227, 171, 113, 0.04);
    border: 1px solid rgba(227, 171, 113, 0.15);
    border-radius: 4px;
    text-decoration: none;
    color: var(--foreground-muted);
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.9375rem;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow:
      inset 0 0 0 3px rgba(15, 12, 8, 0.8),
      inset 0 0 0 4px rgba(227, 171, 113, 0.04);
  }

  .vol-link:hover {
    background: rgba(227, 171, 113, 0.08);
    border-color: rgba(227, 171, 113, 0.3);
    color: var(--gold-light);
    box-shadow:
      inset 0 0 0 3px rgba(15, 12, 8, 0.7),
      inset 0 0 0 4px rgba(227, 171, 113, 0.08),
      0 0 16px rgba(227, 171, 113, 0.06);
  }

  .vol-badge {
    padding: 0.2rem 0.5rem;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: 3px;
    letter-spacing: 0.04em;
  }

  .vol-badge.soon {
    background: rgba(227, 171, 113, 0.08);
    color: var(--gold);
    border: 1px solid rgba(227, 171, 113, 0.15);
  }

  .arrow {
    color: var(--gold);
    transition: transform 0.2s;
    display: inline-block;
  }

  .vol-link:hover .arrow { transform: translateX(3px); }

  /* Responsive */
  @media (max-width: 480px) {
    .volume-header h1 { font-size: 1.75rem; }
    .case-preview { padding: 0.875rem 1rem; gap: 0.75rem; }
    .case-btns { gap: 0.35rem; }
    .btn-read, .btn-buy-sm, .btn-free-sm, .btn-kindle-sm { padding: 0.3rem 0.5rem; font-size: 0.6rem; }
    .headline-rule { max-width: 200px; }
  }
</style>
