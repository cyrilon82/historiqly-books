---
import Layout from '../../layouts/Layout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-tower-of-london.jpg',
  millais: '/cases/images/princes-millais-painting.jpg',
  delaroche: '/cases/images/princes-delaroche-painting.jpg',
  richardIII: '/cases/images/figure-richard-iii-portrait.jpg',
  edwardIV: '/cases/images/figure-edward-iv-portrait.jpg',
  elizabethWoodville: '/cases/images/figure-elizabeth-woodville.jpg',
  bloodyTower: '/cases/images/location-bloody-tower.jpg',
  skeleton: '/cases/images/evidence-richard-iii-skeleton.jpg',
  medieval: '/cases/images/atmosphere-tower-medieval.jpg',
  bosworth: '/cases/images/atmosphere-bosworth-field.jpg',
};
---

<SidebarLayout
  title="The Princes in the Tower — The Royal Mystery That Haunts England"
  description="The Princes in the Tower: Two boys entered the Tower of London in 1483 and were never seen again. Who killed them? The definitive investigation. $2.99 EPUB."
  currentVolume={3}
  image="/books/covers/princes-in-the-tower.jpg"
  ogType="book"
  keywords="Princes in the Tower book, Edward V, Richard Duke of York, Richard III, Tower of London mystery, Wars of the Roses, medieval England, true crime non-fiction, cold case"
  bookSeo={{ bookTitle: "The Princes in the Tower", subtitle: "The Royal Mystery That Haunts England", price: "2.99", author: "HistorIQly Thrillers", genre: "Non-Fiction, History, Cold Case, Medieval", format: "EBook", keywords: "princes, tower, Richard III, Edward V, medieval mystery" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Cold Cases", url: "/vol/cold-cases" }, { name: "Princes in the Tower", url: "/cases/princes-in-the-tower" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 03-1483</span>
          <span class="meta-badge alert">STATUS: UNSOLVED</span>
        </div>

        <h1 class="hero-title">The Princes in the Tower</h1>
        <p class="hero-subtitle">The Royal Mystery That Haunts England</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Date</span>
            <span class="stat-value">Summer 1483</span>
          </div>
          <div class="stat">
            <span class="stat-label">Location</span>
            <span class="stat-value">Tower of London</span>
          </div>
           <div class="stat">
            <span class="stat-label">Status</span>
            <span class="stat-value text-accent">UNSOLVED</span>
          </div>
        </div>

        <div class="hero-actions">
          <button onclick={`localStorage.setItem('historiqly_purchasing','princes-in-the-tower');window.location.href='${stripeUrl}'`} class="btn-buy-primary" id="heroBuyBtn">
            <span class="btn-buy-text">Buy the Book</span>
            <span class="btn-buy-price">$2.99</span>
          </button>
          <a href="/books/princes-in-the-tower.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section">
      <div class="intro-text">
        <p class="drop-cap">In the summer of 1483, two boys — Edward V, aged twelve, and Richard, Duke of York, aged nine — were seen playing in the gardens of the Tower of London. Then they were withdrawn to the inner apartments, seen more rarely behind the bars and windows, and finally not seen at all. Their uncle had just crowned himself King Richard III.</p>
        <p>Five centuries of investigation. No confirmed body. No conclusive evidence. <strong>History's most enduring cold case.</strong></p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Victims</span>
            <h3 class="card-value">2</h3>
            <p class="card-desc">Two princes of the blood — Edward V, the uncrowned king, and his brother Richard, Duke of York — vanished from the Tower of London in the summer of 1483 and were never seen again.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Years Unsolved</span>
            <h3 class="card-value text-accent">543</h3>
            <p class="card-desc">The longest-running cold case in English history. No killer has ever been formally identified.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">Suspects</span>
            <h3 class="card-value">4</h3>
            <p class="card-desc">Richard III, the Duke of Buckingham, Henry VII, and Margaret Beaufort have all been accused. None conclusively proven.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Pretenders</span>
            <h3 class="card-value">2</h3>
            <p class="card-desc">Lambert Simnel and Perkin Warbeck both claimed to be the surviving prince. Warbeck's true identity remains debated.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.millais} alt="The Princes in the Tower by John Everett Millais, 1878" />
            <div class="visual-overlay">
              <span class="overlay-label">MILLAIS — THE PRINCES IN THE TOWER, 1878</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Last Sighting</h3>
            <p>The princes were last seen "shooting and playing in the garden of the Tower by sundry times" in the summer of 1483. Dr John Argentine, the royal physician, was the last independent witness — he reported that Edward V was seeking "remission of his sins because he believed that death was facing him."</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.bloodyTower} alt="The Bloody Tower at the Tower of London" />
            <div class="visual-overlay">
               <span class="overlay-label">THE BLOODY TOWER — TOWER OF LONDON</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Bloody Tower</h3>
            <p>Originally called the Garden Tower, it was renamed after the princes' disappearance gave the fortress its sinister reputation. In 1674, two children's skeletons were discovered beneath a nearby staircase — exactly where Thomas More wrote they were buried.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.skeleton} alt="The skeleton of Richard III discovered in Leicester, 2012" />
            <div class="visual-overlay">
               <span class="overlay-label">RICHARD III — LEICESTER EXCAVATION, 2012</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The King Under the Car Park</h3>
            <p>In 2012, Richard III's skeleton was found beneath a Leicester car park. DNA confirmed his identity with 99.9994% probability. His severe scoliosis matched historical accounts, but his face — reconstructed from the skull — showed a man, not a monster.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TIMELINE -->
    <section class="timeline-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">A Crown Seized, Two Boys Lost</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">APR 1483</span>
          <div class="timeline-content">
            <h4>The King Dies</h4>
            <p>Edward IV dies suddenly at 40. His 12-year-old son Edward V is proclaimed king. Richard of Gloucester is named Lord Protector — but the Woodville faction moves to crown the boy quickly and end the protectorate.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">APR 30</span>
          <div class="timeline-content">
            <h4>The Stony Stratford Coup</h4>
            <p>Gloucester intercepts the young king at Stony Stratford, arrests his Woodville guardians, and takes personal control of Edward V. Elizabeth Woodville flees to sanctuary at Westminster Abbey with the younger prince.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">JUN 13</span>
          <div class="timeline-content">
            <h4>Hastings Executed</h4>
            <p>Lord Hastings — the last man loyal to Edward V who could have resisted — is dragged from a council meeting and beheaded on Tower Green without trial. Three days later, the young Duke of York is surrendered from sanctuary.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">JUL 6</span>
          <div class="timeline-content highlight">
            <h4>Richard III Crowned</h4>
            <p>Edward IV's children are declared illegitimate. Richard of Gloucester is crowned Richard III at Westminster Abbey. The princes, now bastards by act of Parliament, remain in the Tower — and are never seen again.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1485</span>
          <div class="timeline-content">
            <h4>Bosworth Field</h4>
            <p>Richard III is killed at the Battle of Bosworth — the last English king to die in battle. Henry Tudor seizes the crown. He never investigates the princes' disappearance and never produces their bodies.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1674</span>
          <div class="timeline-content">
            <h4>Bones Discovered</h4>
            <p>Two children's skeletons are found beneath a Tower staircase — matching Thomas More's account. Charles II orders them reburied in Westminster Abbey. A 1933 examination suggests they match the princes' ages, but DNA testing has never been permitted.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- KEY FIGURES -->
    <section class="figures-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.richardIII} alt="Portrait of King Richard III" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Prime Suspect</span>
            <h3>Richard III</h3>
            <p>The princes' uncle and Lord Protector, who seized the throne in June 1483. He had motive, means, and opportunity. The boys vanished while in his custody. He was killed at Bosworth Field in 1485 — the last English king to die in battle.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.elizabethWoodville} alt="Portrait of Elizabeth Woodville" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Mother</span>
            <h3>Elizabeth Woodville</h3>
            <p>Queen consort and mother of the princes. She fled to sanctuary when Gloucester seized power, but was forced to surrender her younger son. She never saw either boy again. She died in obscurity at Bermondsey Abbey in 1492.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.delaroche} alt="The Princes in the Tower by Paul Delaroche, 1830" />
          <div class="image-caption">Paul Delaroche, "Edward V and the Duke of York in the Tower," 1830. Wallace Collection, London.</div>
        </div>
        <div class="conclusion-text">
          <h2>The Daughter of Time</h2>
          <p>Two boys walked into the Tower of London in the summer of 1483. They never walked out. Their uncle seized the throne. The man who killed their uncle married their sister. Neither ever produced the boys, alive or dead.</p>
          <p>Five centuries later, a set of bones lies in Westminster Abbey, untested. The truth waits — sealed in marble, buried in silence.</p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story — from the Wars of the Roses to the car park in Leicester, from the vanishing of two princes to the mystery that still haunts England.</p>
            <button onclick={`localStorage.setItem('historiqly_purchasing','princes-in-the-tower');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy" id="ctaBuyBtn">
              <span class="btn-buy-text">Buy the Book</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
            <a href="/books/princes-in-the-tower.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_princes-in-the-tower', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_princes-in-the-tower') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuy = document.getElementById('heroBuyBtn');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuy) heroBuy.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuy = document.getElementById('ctaBuyBtn');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuy) ctaBuy.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }
</script>

<style>
  /* SWISS TECHNICAL BENTO THEME */
  :root {
    --bg-dark: #0a0a0a;
    --bg-card: #111111;
    --bg-card-hover: #161616;
    --border-color: rgba(255, 255, 255, 0.08);
    --text-primary: #FAFAFA;
    --text-secondary: #A1A1AA;
    --accent: #F59E0B;
    --accent-dim: rgba(245, 158, 11, 0.1);

    --font-serif: 'Cormorant Garamond', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;
  }

  .case-file {
    background-color: var(--bg-dark);
    color: var(--text-primary);
    font-family: var(--font-sans);
    overflow-x: hidden;
  }

  /* UTILS */
  .text-accent { color: var(--accent); }

  /* HERO */
  .hero {
    position: relative;
    height: 90vh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-bottom: 1px solid var(--border-color);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.4) grayscale(0.8) contrast(1.2);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 0%, var(--bg-dark) 90%);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 900px;
    padding: 0 1.5rem;
  }

  .case-meta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .meta-badge {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border-color);
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(4px);
    color: var(--text-secondary);
  }

  .meta-badge.alert {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  .meta-badge.price {
    border-color: var(--accent);
    background: var(--accent-dim);
    color: var(--accent);
    font-weight: 800;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 8vw, 6rem);
    line-height: 0.9;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    text-shadow: 0 10px 30px rgba(0,0,0,0.7);
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    color: var(--text-secondary);
    font-weight: 300;
    margin-bottom: 4rem;
    letter-spacing: 0.02em;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
  }

  .stat-value {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    z-index: 10;
  }

  .scroll-indicator span {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--text-secondary);
    opacity: 0.7;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--text-secondary) 0%, transparent 100%);
  }

  /* HERO ACTIONS */
  .hero-actions {
    margin-top: 3rem;
  }

  .btn-buy-primary {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
    color: #000;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: all 0.25s;
    box-shadow: 0 4px 24px rgba(245, 158, 11, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .btn-buy-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(245, 158, 11, 0.45), 0 4px 12px rgba(0, 0, 0, 0.3);
    background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%);
  }

  .btn-buy-text {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .btn-buy-price {
    font-size: 1.125rem;
    font-weight: 800;
    padding: 0.25rem 0.75rem;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 4px;
  }

  .btn-download-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, #5DB585 0%, #4a9e70 100%);
    color: #000;
    text-decoration: none;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-sans);
    transition: all 0.25s;
    box-shadow: 0 4px 24px rgba(93, 181, 133, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .btn-download-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(93, 181, 133, 0.45), 0 4px 12px rgba(0, 0, 0, 0.3);
    background: linear-gradient(135deg, #6FC494 0%, #5DB585 100%);
  }

  .cta-buy, .cta-download {
    width: 100%;
    justify-content: center;
  }

  /* INTRO */
  .intro-section {
    padding: 8rem 1.5rem;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .intro-text p {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .intro-text strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* BENTO GRID */
  .bento-section {
    padding: 2rem 1.5rem 8rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(2, minmax(200px, auto));
    }

    .large-card {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  .bento-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    padding: 2rem;
    border-radius: 4px;
    transition: transform 0.3s ease, border-color 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .bento-card:hover {
    transform: translateY(-2px);
    border-color: rgba(255,255,255,0.2);
    background: var(--bg-card-hover);
  }

  .card-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .card-value {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .discovery-card .card-value { font-size: 5rem; font-weight: 700; }
  .check-card .card-value { font-size: 4rem; }

  .card-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* EVIDENCE */
  .evidence-section {
    padding: 4rem 1.5rem;
    background: #0F0F0F;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .section-header {
