---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/uss-eldridge-at-sea.jpg',
  shipyard: '/cases/images/philadelphia-naval-shipyard-1943.jpg',
  engstrom: '/cases/images/uss-engstrom-philadelphia.jpg',
  einstein: '/cases/images/albert-einstein-portrait.jpg',
  transfer: '/cases/images/uss-eldridge-transfer-greece.jpg',
  eldridge: '/cases/images/hero-uss-eldridge.jpg',
};
---

<SidebarLayout
  title="The Philadelphia Experiment — The Invisible Ship That Never Was"
  description="The Philadelphia Experiment: Did the Navy teleport a warship in 1943? Non-fiction ebook investigating the origins, claims, and debunking of this enduring military conspiracy. $2.99 EPUB."
  currentVolume={5}
  image="/books/covers/philadelphia-experiment.jpg"
  ogType="book"
  keywords="Philadelphia Experiment book, USS Eldridge, Navy invisibility experiment, Carlos Allende, Morris Jessup, Varo Edition, conspiracy theory, degaussing, teleportation, military conspiracy"
  bookSeo={{
    bookTitle: "The Philadelphia Experiment",
    subtitle: "The Invisible Ship That Never Was",
    price: "2.99",
    author: "HistorIQly Mysteries",
    genre: "Non-Fiction, History, Conspiracy, Military",
    format: "EBook",
    keywords: "Philadelphia Experiment, USS Eldridge, Navy conspiracy, Carlos Allende, Morris Jessup",
  }}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Conspiracies", url: "/vol/conspiracies" },
    { name: "The Philadelphia Experiment", url: "/cases/philadelphia-experiment" },
  ]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 05-1943</span>
          <span class="meta-badge alert">STATUS: DEBUNKED</span>
        </div>

        <h1 class="hero-title">The Philadelphia Experiment</h1>
        <p class="hero-subtitle">The Invisible Ship That Never Was</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Alleged Date</span>
            <span class="stat-value">1943</span>
          </div>
          <div class="stat">
            <span class="stat-label">First Claim</span>
            <span class="stat-value">1956</span>
          </div>
           <div class="stat">
            <span class="stat-label">Credibility</span>
            <span class="stat-value text-accent">Zero</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','philadelphia-experiment');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy the Book</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
          </div>
          <a href="/books/philadelphia-experiment.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">In 1943, the U.S. Navy allegedly rendered a destroyer escort invisible and teleported it two hundred miles — with catastrophic consequences for the crew. For seven decades, the Philadelphia Experiment has captivated conspiracy theorists worldwide.</p>
        <p>But the entire legend traces back to <strong>one man</strong>, <strong>two letters</strong>, and <strong>zero evidence</strong>.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Ship</span>
            <h3 class="card-value">DE-173</h3>
            <p class="card-desc">USS Eldridge — a Cannon-class destroyer escort commissioned August 27, 1943. Her deck logs prove she was never in Philadelphia during the alleged experiment.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Witnesses</span>
            <h3 class="card-value text-accent">1</h3>
            <p class="card-desc">Carlos Allende — the sole source. A troubled merchant mariner who later admitted the hoax.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">Varo Copies</span>
            <h3 class="card-value">127</h3>
            <p class="card-desc">Annotated copies of Jessup's book printed by ONR — personal curiosity, not official endorsement.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Navy Statement</span>
            <h3 class="card-value">"Never"</h3>
            <p class="card-desc">"ONR has never conducted investigations on radar invisibility, either in 1943 or at any other time."</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.shipyard} alt="Destroyer escort at the Philadelphia Naval Shipyard, 1943" />
            <div class="visual-overlay">
              <span class="overlay-label">PHILADELPHIA NAVAL SHIPYARD</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Shipyard</h3>
            <p>The Philadelphia Naval Shipyard was one of the busiest in the nation during WWII. Carlos Allende claimed to have witnessed the Eldridge vanish from its berth here — but the ship's deck logs prove it was never at this facility during the alleged period. The Eldridge was in Bermuda and New York.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.engstrom} alt="USS Engstrom at Philadelphia Naval Shipyard, 1943" />
            <div class="visual-overlay">
               <span class="overlay-label">USS ENGSTROM (DE-50)</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Degaussing</h3>
            <p>The USS Engstrom, docked near where the Eldridge would have been, carried classified degaussing equipment — cables wrapped around the hull to neutralise magnetic signatures and protect against mines. The eerie glow of electrical corona discharge may have been the seed of the "invisibility" story.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.transfer} alt="USS Eldridge being transferred to Greece, 1951" />
            <div class="visual-overlay">
               <span class="overlay-label">TRANSFERRED TO GREECE 1951</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Ship's Fate</h3>
            <p>In 1951, the Eldridge was transferred to Greece and renamed HS Leon. Greek naval personnel maintained the ship for decades and found nothing unusual. Before scrapping in 1999, researchers examined the hull — no secret compartments, no exotic equipment, no anomalies of any kind.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">From Hoax to Legend</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">1943</span>
          <div class="timeline-content">
            <h4>The Alleged Experiment</h4>
            <p>The USS Eldridge is supposedly made invisible and teleported from Philadelphia to Norfolk. Deck logs show the ship was actually near Bermuda and New York.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1956</span>
          <div class="timeline-content">
            <h4>Allende's Letters</h4>
            <p>Carlos Allende writes to Morris Jessup claiming to have witnessed the experiment. He provides no evidence, no witnesses, and no verifiable details.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1959</span>
          <div class="timeline-content">
            <h4>Jessup's Death</h4>
            <p>Morris Jessup is found dead of carbon monoxide poisoning in Coral Gables, Florida. Conspiracy theorists allege murder; evidence points to suicide.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1979</span>
          <div class="timeline-content">
            <h4>The Bestseller</h4>
            <p>Berlitz and Moore publish <em>The Philadelphia Experiment: Project Invisibility</em>, bringing the story to millions for the first time.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1984</span>
          <div class="timeline-content highlight">
            <h4>The Movie</h4>
            <p>The Philadelphia Experiment becomes a feature film, cementing the legend in popular culture. Time travel elements are added to the original story.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Key Figures</span>
        <h2 class="section-title">The Hoaxer & The Physicist</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.eldridge} alt="USS Eldridge — the ship at the centre of the legend" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Sole Source, 1925–1994</span>
            <h3>Carlos Allende</h3>
            <p>Born Carl Meredith Allen, this troubled merchant mariner was the only person who ever claimed to witness the experiment. He admitted it was a hoax in 1969, then retracted the confession. His family confirmed a history of erratic behaviour.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.einstein} alt="Albert Einstein" />
          </div>
          <div class="figure-info">
            <span class="figure-role">Unwitting Icon</span>
            <h3>Albert Einstein</h3>
            <p>Einstein's Unified Field Theory was cited as the basis for the experiment, but he never completed it. He did consult for the Navy during WWII — on conventional explosives, not electromagnetic invisibility. There is no evidence linking him to any such experiment.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.hero} alt="USS Eldridge at sea" />
          <div class="image-caption">USS Eldridge (DE-173) — a conventional destroyer escort, not a secret experiment.</div>
        </div>
        <div class="conclusion-text">
          <h2>The Ship Was Never Invisible</h2>
          <p>No evidence. One unreliable witness. A ship that was never in Philadelphia. Crew members who denied everything. And a Navy that categorically states it never happened.</p>
          <p>The Philadelphia Experiment is a masterclass in how a single fabrication can become an unshakeable legend — growing from two letters into books, films, and an entire mythology spanning eight decades.</p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>10 chapters. The complete investigation — from Carlos Allende's letters to the Montauk Project and beyond.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','philadelphia-experiment');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy the Book</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
            </div>
            <a href="/books/philadelphia-experiment.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_philadelphia-experiment', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_philadelphia-experiment') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

