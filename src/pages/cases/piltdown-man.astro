---
import Layout from '../../layouts/Layout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const images = {
  hero: '/cases/images/hero-gravel-pit.jpg',
  painting: '/cases/images/piltdown-gang-painting.jpg',
  filedTeeth: '/cases/images/filed-teeth.jpg',
  skull: '/cases/images/piltdown-skull-reconstruction.jpg',
  stainedBones: '/cases/images/stained-bone-fragments.jpg',
  suspectDawson: '/cases/images/suspect-dawson.jpg',
  memorial: '/cases/images/memorial-stone.jpg',
};
---

<SidebarLayout
  title="Piltdown Man Book — Scientific Fraud Exposed"
  description="The Piltdown Men: The 41-year scientific fraud that fooled the world. Free non-fiction ebook about history's greatest hoax. Free EPUB download."
  currentVolume={1}
  image="/books/covers/piltdown-man.jpg"
  ogType="book"
  keywords="Piltdown Man book, scientific fraud ebook, history hoaxes, archaeological fraud, Piltdown hoax, free history ebook, science fraud non-fiction"
  bookSeo={{ bookTitle: "The Piltdown Men", subtitle: "The 41-Year Fraud That Fooled Science", price: "0.00", author: "HistorIQly Mysteries", genre: "Non-Fiction, History, Science, Hoaxes", format: "EBook", keywords: "Piltdown Man, scientific fraud, hoax, archaeology" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Hoaxes", url: "/vol/hoaxes" }, { name: "The Piltdown Men", url: "/cases/piltdown-man" }]}
>
  <article class="case-file">
    
    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>
      
      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge preview">FREE</span>
          <span class="meta-badge">CASE 01-1912</span>
          <span class="meta-badge alert">STATUS: HOAX</span>
        </div>
        
        <h1 class="hero-title">The Piltdown Men</h1>
        <p class="hero-subtitle">The 41-Year Fraud That Fooled Science</p>
        
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Discovery</span>
            <span class="stat-value">1912</span>
          </div>
          <div class="stat">
            <span class="stat-label">Exposed</span>
            <span class="stat-value">1953</span>
          </div>
           <div class="stat">
            <span class="stat-label">Duration</span>
            <span class="stat-value text-accent">41 Years</span>
          </div>
        </div>

        <div class="hero-actions">
          <a href="#" data-free-book class="btn-hero-action">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Get Free EPUB</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">In 1912, a skull was found in a Sussex gravel pit that would rewrite the story of human evolution. It was announced to the world as the missing link — proof that England had produced the first true human.</p>
        <p>It took <strong>41 years</strong> to discover the truth.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">
        
        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Discovery</span>
            <h3 class="card-value">1912</h3>
            <p class="card-desc">Amateur archaeologist Charles Dawson presents skull fragments to the Natural History Museum. The Keeper of Geology declares them extraordinary.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Rigorous Checks</span>
            <h3 class="card-value text-accent">0</h3>
            <p class="card-desc">People who examined original bones before 1953.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">Academic Papers</span>
            <h3 class="card-value">500+</h3>
            <p class="card-desc">Published citing Piltdown as fact.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Serial Fraud</span>
            <h3 class="card-value">38</h3>
            <p class="card-desc">Other fakes by Dawson discovered later.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">Forensic Analysis</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.filedTeeth} alt="Microscope view of teeth" />
            <div class="visual-overlay">
              <span class="overlay-label">MAGNIFICATION: 10x</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Filed Molars</h3>
            <p>Under a microscope, the flat molar surfaces dissolved into parallel scratches — the unmistakable marks of a steel file. Someone had manually ground down an ape's teeth to mimic human wear patterns.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.stainedBones} alt="Stained bone fragments" />
            <div class="visual-overlay">
               <span class="overlay-label">CHEMICAL TEST</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Painted Bones</h3>
            <p>The "ancient" brown patina was iron solution and potassium dichromate. When scratched, the staining came off to reveal white, modern bone beneath. The jaw was a medieval orangutan's.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.skull} alt="Skull reconstruction" />
            <div class="visual-overlay">
               <span class="overlay-label">ANATOMICAL MIRACLE</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Impossible Anatomy</h3>
            <p>The crucial connecting bone (condyle) was snapped off. Without it, nobody could prove the jaw didn't fit. It was a perfect biological impossibility: a human cranium with an orangutan jaw.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">41 Years of Deception</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>
        
        <div class="timeline-entry left">
          <span class="timeline-year">1908</span>
          <div class="timeline-content">
            <h4>First Fragment</h4>
            <p>Dawson claims a workman handed him a skull fragment. He pockets it and waits three years.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1912</span>
          <div class="timeline-content">
            <h4>The Announcement</h4>
            <p>Dawson and Woodward announce the discovery at Burlington House. The "Missing Link" is found.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1915</span>
          <div class="timeline-content">
            <h4>The Insurance Policy</h4>
            <p>Dawson "finds" a second skull two miles away. This silences the few remaining skeptics.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1953</span>
          <div class="timeline-content highlight">
            <h4>The Exposure</h4>
            <p>Joseph Weiner files a chimp jaw. Kenneth Oakley runs fluorine tests. The hoax collapses in days.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.painting} alt="The Piltdown committee" />
          <div class="image-caption">Every man in this painting was wrong.</div>
        </div>
        <div class="conclusion-text">
          <h2>The Real Question</h2>
          <p>It isn't <em>who</em> did it. It's how the finest minds in British science looked at a filed ape jaw painted brown and saw the missing link.</p>
          <p>They saw what they wanted to see: that the first human was an Englishman.</p>
          
          <div class="cta-box">
            <h3>Get the Full Book — Free</h3>
            <p>15 chapters. 45-min read. The complete story of ambition, delusion, and detection. Just enter your email.</p>
            <a href="#" data-free-book class="btn-download">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Get Free EPUB
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

