---
import Layout from '../../layouts/Layout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/black-dahlia-hollywood-night.jpg',
  portrait: '/cases/images/hero-black-dahlia-portrait.jpg',
  biltmore: '/cases/images/black-dahlia-biltmore-hotel.jpg',
  norton: '/cases/images/black-dahlia-norton-avenue.jpg',
  sowden: '/cases/images/black-dahlia-sowden-house.jpg',
  bulletin: '/cases/images/black-dahlia-lapd-bulletin.png',
  hodel: '/cases/images/suspect-george-hodel.jpg',
  fbi: '/cases/images/black-dahlia-fbi-mugshot-fingerprints.jpg',
};
---

<SidebarLayout
  title="Black Dahlia Book — Hollywood's Cold Case"
  description="The Black Dahlia: Hollywood's most haunting unsolved murder. Non-fiction ebook investigating the 1947 Elizabeth Short case. $2.99 EPUB."
  currentVolume={3}
  image="/books/covers/black-dahlia.jpg"
  ogType="book"
  keywords="Black Dahlia book, Black Dahlia ebook, Elizabeth Short murder, Hollywood cold case, 1947 Los Angeles, unsolved murder non-fiction, true crime history"
  bookSeo={{ bookTitle: "The Black Dahlia", subtitle: "Hollywood's Most Haunting Cold Case", price: "2.99", author: "HistorIQly Mysteries", genre: "Non-Fiction, True Crime, Cold Cases, History", format: "EBook", keywords: "Black Dahlia, Elizabeth Short, Hollywood murder, cold case" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Cold Cases", url: "/vol/cold-cases" }, { name: "The Black Dahlia", url: "/cases/black-dahlia" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 02-1947</span>
          <span class="meta-badge alert">STATUS: UNSOLVED</span>
        </div>

        <h1 class="hero-title">The Black Dahlia</h1>
        <p class="hero-subtitle">Hollywood's Most Haunting Cold Case</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Murder</span>
            <span class="stat-value">1947</span>
          </div>
          <div class="stat">
            <span class="stat-label">Suspects</span>
            <span class="stat-value">150+</span>
          </div>
           <div class="stat">
            <span class="stat-label">Status</span>
            <span class="stat-value text-accent">UNSOLVED</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','black-dahlia');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
            <a href="https://www.amazon.com/dp/B0GQS2M81G" target="_blank" rel="noopener" class="btn-buy-kindle">
              Buy on Kindle →
            </a>
          </div>
          <a href="/books/epub/black-dahlia.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">On a January morning in 1947, a young mother walking with her three-year-old daughter along a quiet Los Angeles street saw a pale shape in a vacant lot and thought it was a department store mannequin. It was the bisected body of twenty-two-year-old Elizabeth Short — and the beginning of the most infamous unsolved murder in American history.</p>
        <p>Over <strong>750 investigators</strong>. More than <strong>150 suspects</strong>. Sixty false confessions. And nearly eighty years later, not a single arrest.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Victim</span>
            <h3 class="card-value">1947</h3>
            <p class="card-desc">Elizabeth Short, 22, found bisected in a vacant lot in Leimert Park, Los Angeles. She was last seen alive six days earlier at the Biltmore Hotel.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Investigators</span>
            <h3 class="card-value text-accent">750+</h3>
            <p class="card-desc">The largest LAPD investigation of its era.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">Confessions</span>
            <h3 class="card-value">60+</h3>
            <p class="card-desc">False confessions from 'Confessing Sams' seeking notoriety.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Suspects</span>
            <h3 class="card-value">150+</h3>
            <p class="card-desc">Named suspects investigated. No arrest has ever been made.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.portrait} alt="Elizabeth Short, known as the Black Dahlia" />
            <div class="visual-overlay">
              <span class="overlay-label">VICTIM: ELIZABETH SHORT</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Black Dahlia</h3>
            <p>Her nickname came from the 1946 film The Blue Dahlia and her habit of wearing all black — black dresses, black suede shoes, a black coat. Elizabeth Short was an aspiring actress living behind the Florentine Gardens nightclub on Hollywood Boulevard, drifting between rooming houses and borrowed beds, chasing a dream the city had no intention of giving her.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.biltmore} alt="The Biltmore Hotel in downtown Los Angeles" />
            <div class="visual-overlay">
               <span class="overlay-label">LAST SEEN: JAN 9, 1947</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Biltmore Hotel</h3>
            <p>Red Manley, a traveling salesman, dropped Elizabeth Short at the Biltmore Hotel lobby at 6:30 PM on January 9, 1947. She told him she was meeting her sister. The hotel doorman later recalled seeing her make a phone call from the lobby. Around 10 PM, she was seen leaving through the Olive Street exit — alone. Then six days of silence.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.bulletin} alt="LAPD police bulletin regarding the Black Dahlia case" />
            <div class="visual-overlay">
               <span class="overlay-label">LAPD POLICE BULLETIN</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Avenger</h3>
            <p>On January 24, a gasoline-washed envelope arrived at the Los Angeles Examiner. Inside: Elizabeth Short's birth certificate, business cards, photographs, and Mark Hansen's address book — with certain pages torn out. A pasted-letter message on the envelope read: "Here is Dahlia's Belongings. Letter to Follow." A second note taunted: "Had my fun at police."</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">The Black Dahlia</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">JAN 9, 1947</span>
          <div class="timeline-content">
            <h4>Last Seen Alive</h4>
            <p>Dropped at the Biltmore Hotel by Red Manley at 6:30 PM. Seen leaving via the Olive Street exit around 10 PM. Then silence.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">JAN 15, 1947</span>
          <div class="timeline-content">
            <h4>The Discovery</h4>
            <p>Betty Bersinger discovers the body in a vacant lot on South Norton Avenue, Leimert Park. Bisected, exsanguinated, posed.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">JAN 24, 1947</span>
          <div class="timeline-content">
            <h4>The Envelope</h4>
            <p>A gasoline-washed package arrives at the LA Examiner containing Short's belongings and Mark Hansen's address book with pages torn out.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1949-50</span>
          <div class="timeline-content highlight">
            <h4>The Wiretap</h4>
            <p>LAPD surveillance of Dr. George Hodel captures him saying: "Supposin' I did kill the Black Dahlia. They couldn't prove it now."</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">2003</span>
          <div class="timeline-content">
            <h4>A Son's Investigation</h4>
            <p>Retired LAPD detective Steve Hodel publishes "Black Dahlia Avenger," making the case that his own father was the killer.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.hodel} alt="Dr. George Hodel" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Prime Suspect</span>
            <h3>Dr. George Hodel</h3>
            <p>Prominent LA physician who lived in the Sowden House. Medical training matching the surgical precision of the bisection. Caught on wiretap: "Supposin' I did kill the Black Dahlia." Fled to the Philippines. His own son, an LAPD detective, later identified him as the killer.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.portrait} alt="Elizabeth Short" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Victim</span>
            <h3>Elizabeth Short</h3>
            <p>Born in Medford, Massachusetts. Abandoned by her father at age six. Arrested at nineteen. Moved to Hollywood with dreams that never materialized. Murdered at twenty-two. She has become an archetype of American noir — sunshine and shadow, aspiration and exploitation.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.sowden} alt="The Sowden House in Los Feliz, George Hodel's residence" />
          <div class="image-caption">The Sowden House, Los Feliz. George Hodel's residence.</div>
        </div>
        <div class="conclusion-text">
          <h2>The Case That Will Never Die</h2>
          <p>Nearly eighty years later, the Black Dahlia case remains officially open. All principal suspects are dead. The evidence has degraded. DNA testing may never produce a match.</p>
          <p>But the case endures — in novels, films, podcasts, and the collective imagination of a city built on dreams and shadows. Elizabeth Short asked Hollywood for a story. <em>Hollywood gave her one she never wanted.</em></p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>Eight chapters tracing every lead, every suspect, and every theory in Hollywood's darkest cold case.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','black-dahlia');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
              <a href="https://www.amazon.com/dp/B0GQS2M81G" target="_blank" rel="noopener" class="btn-buy-kindle cta-kindle">
                Buy on Kindle →
              </a>
            </div>
            <a href="/books/epub/black-dahlia.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_black-dahlia', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_black-dahlia') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

