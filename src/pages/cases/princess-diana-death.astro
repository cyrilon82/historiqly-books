---
import SidebarLayout from '../../layouts/SidebarLayout.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-princess-diana-portrait.jpg',
  tunnel: '/cases/images/pont-de-lalma-tunnel.jpg',
  flowers: '/cases/images/kensington-palace-flowers-diana.jpg',
  flame: '/cases/images/flame-of-liberty-paris.jpg',
  althorp: '/cases/images/althorp-house.jpg',
  henriPaul: '/cases/images/suspect-henri-paul.png',
  abbey: '/cases/images/westminster-abbey-exterior.jpg',
};
---

<SidebarLayout
  title="The Thirteenth Pillar — The Death of Princess Diana"
  description="Princess Diana's Death: Was it a tragic accident or an assassination? The full story of the Paris crash, the conspiracy theories, and the verdict. $2.99 EPUB."
  currentVolume={5}
  image="/books/covers/princess-diana-death.jpg"
  ogType="book"
  keywords="Princess Diana death, Diana conspiracy, Pont de l'Alma tunnel, Henri Paul, Dodi Fayed, MI6 Diana, Operation Paget, Diana inquest"
  bookSeo={{ bookTitle: "The Thirteenth Pillar", subtitle: "The Death of Princess Diana and the Conspiracy That Would Not Die", price: "2.99", author: "HistorIQly Thrillers", genre: "Non-Fiction, History, Conspiracies", format: "EBook", keywords: "Princess Diana, death, conspiracy, Paris crash, Royal Family" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Conspiracies", url: "/vol/conspiracies" }, { name: "Princess Diana's Death", url: "/cases/princess-diana-death" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 05-1997</span>
          <span class="meta-badge alert">STATUS: UNLAWFUL KILLING</span>
        </div>

        <h1 class="hero-title">Princess Diana's Death</h1>
        <p class="hero-subtitle">The Thirteenth Pillar</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Date</span>
            <span class="stat-value">Aug 31, 1997</span>
          </div>
          <div class="stat">
            <span class="stat-label">Verdict</span>
            <span class="stat-value text-accent">Unlawful Killing</span>
          </div>
           <div class="stat">
            <span class="stat-label">Investigations</span>
            <span class="stat-value">3</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','princess-diana-death');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
          </div>
          <a href="/books/princess-diana-death.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section">
      <div class="intro-text">
        <p class="drop-cap">In the early hours of August 31, 1997, a black Mercedes carrying the most famous woman in the world slammed into a concrete pillar in a Paris tunnel. Princess Diana, Dodi Fayed, and their driver Henri Paul were dead. The official verdict blamed a <strong>drunk driver</strong> and reckless paparazzi.</p>
        <p>But for millions, the questions were only beginning. Was it truly an accident — or was it <strong>murder</strong>?</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Crash</span>
            <h3 class="card-value">12:23 AM</h3>
            <p class="card-desc">The Mercedes S280 struck the thirteenth pillar of the Pont de l'Alma tunnel at over 60 mph — more than double the speed limit. Three of the four occupants were killed.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Blood Alcohol</span>
            <h3 class="card-value text-accent">3.7x</h3>
            <p class="card-desc">Henri Paul's blood alcohol was 3.6 times the French legal limit. He was also on Prozac and anti-alcohol medication.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">The Inquest</span>
            <h3 class="card-value">250</h3>
            <p class="card-desc">Witnesses heard during the six-month British inquest — the most extensive and expensive in legal history.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Global Audience</span>
            <h3 class="card-value">2.5B</h3>
            <p class="card-desc">Estimated viewers of Diana's funeral on September 6, 1997 — one of the most-watched events in television history.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.tunnel} alt="Pont de l'Alma tunnel, Paris" />
            <div class="visual-overlay">
              <span class="overlay-label">PONT DE L'ALMA TUNNEL</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Thirteenth Pillar</h3>
            <p>The Mercedes clipped a white Fiat Uno, swerved left, and struck the thirteenth concrete pillar head-on at over 60 mph. The Fiat was never found — despite police eliminating over 4,000 white Fiat Unos from the inquiry.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.flowers} alt="Sea of flowers at Kensington Palace" />
            <div class="visual-overlay">
               <span class="overlay-label">KENSINGTON PALACE, SEPT 1997</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>A Nation in Mourning</h3>
            <p>Over one million bouquets — an estimated 60 million individual blooms — were laid at Kensington Palace. The Guinness Book of World Records recognised it as the largest floral tribute in history.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.flame} alt="Flame of Liberty memorial near the Pont de l'Alma tunnel" />
            <div class="visual-overlay">
               <span class="overlay-label">FLAME OF LIBERTY</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Unofficial Memorial</h3>
            <p>The Flame of Liberty, a gold replica of the Statue of Liberty's torch, stands above the crash tunnel. It predates Diana's death but became a public shrine. The site was officially renamed Place Diana in 2019.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TIMELINE -->
    <section class="timeline-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">The Final Night</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">4:35 PM</span>
          <div class="timeline-content">
            <h4>Arrival at the Ritz</h4>
            <p>Diana and Dodi arrive at the Ritz Hotel on the Place Vendome. CCTV captures Diana smiling in a hotel lift. The couple dine in the Imperial Suite after paparazzi make a restaurant meal impossible.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">10:08 PM</span>
          <div class="timeline-content">
            <h4>Henri Paul Returns</h4>
            <p>The off-duty deputy security chief is summoned back to the hotel. He will later be found to have a blood alcohol level 3.6 times the legal limit. CCTV shows him appearing calm and composed.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">12:20 AM</span>
          <div class="timeline-content">
            <h4>The Decoy Plan</h4>
            <p>Diana and Dodi depart via the rear Rue Cambon exit in a backup Mercedes driven by Henri Paul. No follow car. No backup. Only bodyguard Trevor Rees-Jones accompanies them.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">12:23 AM</span>
          <div class="timeline-content highlight">
            <h4>Impact</h4>
            <p>The Mercedes enters the Pont de l'Alma tunnel at over 60 mph, clips a white Fiat Uno, and slams into the thirteenth concrete pillar. Dodi and Henri Paul are killed instantly.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">4:00 AM</span>
          <div class="timeline-content">
            <h4>Diana Pronounced Dead</h4>
            <p>After nearly two hours of emergency surgery at the Pitie-Salpetriere Hospital, Diana is pronounced dead. A torn pulmonary vein had caused massive internal haemorrhage.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">APR 2008</span>
          <div class="timeline-content">
            <h4>The Verdict</h4>
            <p>After a six-month inquest hearing 250 witnesses, the jury returns a verdict of "unlawful killing" through grossly negligent driving by Henri Paul and the pursuing paparazzi.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- KEY FIGURES -->
    <section class="figures-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.henriPaul} alt="Henri Paul" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Driver</span>
            <h3>Henri Paul</h3>
            <p>Deputy head of security at the Ritz Hotel. Blood alcohol 3.6 times the legal limit. On Prozac and anti-alcohol medication. Maintained 15 bank accounts totalling ~$200,000 on a $30,000 salary. The source of his wealth was never explained.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.abbey} alt="Westminster Abbey" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Funeral</span>
            <h3>Westminster Abbey</h3>
            <p>On September 6, 1997, two thousand mourners filled the Gothic nave. Elton John performed "Candle in the Wind." Earl Spencer delivered a eulogy that attacked the media and the Royal Family. 2.5 billion watched worldwide.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.althorp} alt="Althorp House, the Spencer family estate" />
          <div class="image-caption">Althorp House, Northamptonshire — Diana's final resting place, on a small island in an ornamental lake.</div>
        </div>
        <div class="conclusion-text">
          <h2>Accident or Assassination?</h2>
          <p>Three investigations. 250 witnesses. 832 pages of evidence. The official verdict: unlawful killing through grossly negligent driving. No conspiracy. No murder plot.</p>
          <p>But polls show one in three Britons still believes Diana was murdered. The conspiracy <em>will not die</em>.</p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story — from the fairy-tale wedding to the Paris tunnel to the verdict.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','princess-diana-death');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
            </div>
            <a href="/books/princess-diana-death.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_princess-diana-death', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_princess-diana-death') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }
</script>

<style>
  /* SWISS TECHNICAL BENTO THEME */
  :root {
    --bg-dark: #0a0a0a;
    --bg-card: #111111;
    --bg-card-hover: #161616;
    --border-color: rgba(255, 255, 255, 0.08);
    --text-primary: #FAFAFA;
    --text-secondary: #A1A1AA;
    --accent: #F59E0B;
    --accent-dim: rgba(245, 158, 11, 0.1);

    --font-serif: 'Cormorant Garamond', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;
  }

  .case-file {
    background-color: var(--bg-dark);
    color: var(--text-primary);
    font-family: var(--font-sans);
    overflow-x: hidden;
  }

  /* UTILS */
  .text-accent { color: var(--accent); }

  /* HERO */
  .hero { position: relative; height: 90vh; min-height: 600px; display: flex; flex-direction: column; justify-content: center; align-items: center; border-bottom: 1px solid var(--border-color); }
  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.4) grayscale(0.8) contrast(1.2); }
  .hero-overlay { position: absolute; inset: 0; background: radial-gradient(circle at center, transparent 0%, var(--bg-dark) 90%); }
  .hero-content { position: relative; z-index: 10; text-align: center; max-width: 900px; padding: 0 1.5rem; }
  .case-meta { display: flex; gap: 1rem; justify-content: center; margin-bottom: 2rem; }
  .meta-badge { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; padding: 0.4rem 0.8rem; border: 1px solid var(--border-color); background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); color: var(--text-secondary); }
  .meta-badge.alert { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
  .meta-badge.price { border-color: var(--accent); background: var(--accent-dim); color: var(--accent); font-weight: 800; }
  .hero-title { font-family: var(--font-serif); font-size: clamp(3.5rem, 8vw, 6rem); line-height: 0.9; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 1rem; text-shadow: 0 10px 30px rgba(0,0,0,0.7); }
  .hero-subtitle { font-size: clamp(1.1rem, 3vw, 1.5rem); color: var(--text-secondary); font-weight: 300; margin-bottom: 4rem; letter-spacing: 0.02em; }
  .hero-stats { display: flex; justify-content: center; gap: 3rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1); }
  .stat { display: flex; flex-direction: column; align-items: center; }
  .stat-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-secondary); margin-bottom: 0.25rem; }
  .stat-value { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 500; }
  .scroll-indicator { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 1rem; z-index: 10; }
  .scroll-indicator span { font-size: 0.65rem; letter-spacing: 0.3em; color: var(--text-secondary); opacity: 0.7; }
  .scroll-line { width: 1px; height: 60px; background: linear-gradient(to bottom, var(--text-secondary) 0%, transparent 100%); }

  /* HERO ACTIONS */
  .hero-actions { margin-top: 3rem; }
  .btn-buy-primary { display: inline-flex; align-items: center; gap: 1rem; padding: 1rem 2.5rem; background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); color: #000; border: none; border-radius: 8px; cursor: pointer; font-family: var(--font-sans); transition: all 0.25s; box-shadow: 0 4px 24px rgba(245, 158, 11, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3); }
  .btn-buy-primary:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(245, 158, 11, 0.45), 0 4px 12px rgba(0, 0, 0, 0.3); background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%); }
  .btn-buy-text { font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; }
  .btn-buy-price { font-size: 1.125rem; font-weight: 800; padding: 0.25rem 0.75rem; background: rgba(0, 0, 0, 0.15); border-radius: 4px; }
  .btn-download-primary { display: inline-flex; align-items: center; gap: 0.75rem; padding: 1rem 2.5rem; background: linear-gradient(135deg, #5DB585 0%, #4a9e70 100%); color: #000; text-decoration: none; border: none; border-radius: 8px; font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; font-family: var(--font-sans); transition: all 0.25s; box-shadow: 0 4px 24px rgba(93, 181, 133, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3); }
  .btn-download-primary:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(93, 181, 133, 0.45), 0 4px 12px rgba(0, 0, 0, 0.3); background: linear-gradient(135deg, #6FC494 0%, #5DB585 100%); }
  .cta-buy, .cta-download { width: 100%; justify-content: center; }

  /* INTRO */
  .intro-section { padding: 8rem 1.5rem; max-width: 800px; margin: 0 auto; text-align: center; }
  .intro-text p { font-family: var(--font-serif); font-size: clamp(1.25rem, 3vw, 1.75rem); line-height: 1.6; color: var(--text-secondary); margin-bottom: 2rem; }
  .intro-text strong { color: var(--text-primary); font-weight: 600; }

  /* BENTO GRID */
  .bento-section { padding: 2rem 1.5rem 8rem; max-width: 1200px; margin: 0 auto; }
  .bento-grid { display: grid; grid-template-columns: repeat(1, 1fr); gap: 1.5rem; }
  @media (min-width: 768px) { .bento-grid { grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(2, minmax(200px, auto)); } .large-card { grid-column: span 2; grid-row: span 2; } }
  .bento-card { background: var(--bg-card); border: 1px solid var(--border-color); padding: 2rem; border-radius: 4px; transition: transform 0.3s ease, border-color 0.3s ease; display: flex; flex-direction: column; justify-content: center; }
  .bento-card:hover { transform: translateY(-2px); border-color: rgba(255,255,255,0.2); background: var(--bg-card-hover); }
  .card-label { display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-secondary); margin-bottom: 1rem; }
  .card-value { font-family: var(--font-serif); font-size: 3rem; font-weight: 400; margin-bottom: 0.5rem; line-height: 1; }
  .discovery-card .card-value { font-size: 5rem; font-weight: 700; }
  .check-card .card-value { font-size: 4rem; }
  .card-desc { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.5; }

  /* EVIDENCE */
  .evidence-section { padding: 4rem 1.5rem; background: #0F0F0F; border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color); }
  .section-header { text-align: center; margin-bottom: 4rem; }
  .section-label { font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); display: block; margin-bottom: 0.5rem; }
  .section-title { font-family: var(--font-serif); font-size: 3rem; font-weight: 400; }
  .evidence-grid { max-width: 1000px; margin: 0 auto; display: grid; gap: 4rem; }
  .evidence-card { display: grid; grid-template-columns: 1fr; gap: 2rem; align-items: center; }
  @media (min-width: 768px) { .evidence-card { grid-template-columns: 1fr 1fr; } .evidence-card:nth-child(even) .evidence-visual { order: 2; } }
  .evidence-visual { position: relative; border: 1px solid var(--border-color); }
  .evidence-visual img { width: 100%; display: block; filter: brightness(0.8) contrast(1.1); }
  .visual-overlay { position: absolute; bottom: 0; left: 0; width: 100%; padding: 0.5rem; background: rgba(0,0,0,0.7); backdrop-filter: blur(2px); border-top: 1px solid rgba(255,255,255,0.1); }
  .overlay-label { font-size: 0.6rem; font-family: monospace; color: var(--accent); letter-spacing: 0.1em; }
  .evidence-data h3 { font-family: var(--font-serif); font-size: 2rem; margin-bottom: 1rem; font-weight: 500; }
  .evidence-data p { color: var(--text-secondary); line-height: 1.7; font-size: 1.1rem; }

  /* TIMELINE */
  .timeline-section { padding: 6rem 1.5rem; max-width: 800px; margin: 0 auto; }
  .timeline { position: relative; padding: 2rem 0; }
  .timeline-line { position: absolute; left: 50%; top: 0; bottom: 0; width: 1px; background: var(--border-color); transform: translateX(-50%); }
  .timeline-entry { position: relative; display: flex; justify-content: center; margin-bottom: 4rem; }
  .timeline-year { position: absolute; left: 50%; transform: translateX(-50%); background: var(--bg-dark); padding: 0.25rem 0.5rem; font-family: monospace; color: var(--accent); font-size: 0.8rem; border: 1px solid var(--border-color); z-index: 2; }
  .timeline-content { width: 45%; background: var(--bg-card); border: 1px solid var(--border-color); padding: 1.5rem; position: relative; }
  .timeline-entry.left .timeline-content { margin-right: auto; text-align: right; }
  .timeline-entry.right .timeline-content { margin-left: auto; text-align: left; }
