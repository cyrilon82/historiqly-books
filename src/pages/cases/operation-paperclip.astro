---
import Layout from '../../layouts/Layout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-von-braun-surrender-1945.jpg',
  prisonersV2: '/cases/images/evidence-prisoners-assembling-v2.jpg',
  v2WhiteSands: '/cases/images/evidence-v2-launch-white-sands.jpg',
  explorer1: '/cases/images/evidence-explorer-1-celebration.jpg',
  vonBraunNasa: '/cases/images/figure-von-braun-nasa-1960.jpg',
  rudolph: '/cases/images/figure-arthur-rudolph.jpg',
  strughold: '/cases/images/figure-hubertus-strughold.jpg',
  debus: '/cases/images/figure-kurt-debus.jpg',
  apollo11: '/cases/images/atmosphere-apollo-11-launch.jpg',
  mittelwerk: '/cases/images/location-mittelwerk-tunnel.jpg',
  fortBliss: '/cases/images/evidence-paperclip-team-fort-bliss.jpg',
  vonBraunSaturnV: '/cases/images/figure-von-braun-saturn-v-engines.jpg',
};
---

<SidebarLayout
  title="Operation Paperclip Book — Nazi Scientists in America"
  description="Operation Paperclip: How the US recruited Nazi scientists after WWII. Non-fiction ebook about the declassified program that built NASA. $2.99 EPUB."
  currentVolume={7}
  image="/books/covers/operation-paperclip.jpg"
  ogType="book"
  keywords="Operation Paperclip book, Operation Paperclip ebook, Nazi scientists America, Wernher von Braun, WWII declassified, Cold War secrets, NASA history non-fiction"
  bookSeo={{ bookTitle: "Operation Paperclip", subtitle: "The Nazi Scientists Who Built the American Dream", price: "2.99", author: "HistorIQly Mysteries", genre: "Non-Fiction, History, Declassified, World War II", format: "EBook", keywords: "Operation Paperclip, Nazi scientists, declassified, NASA" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Declassified", url: "/vol/declassified" }, { name: "Operation Paperclip", url: "/cases/operation-paperclip" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 07-1945</span>
          <span class="meta-badge alert">STATUS: DECLASSIFIED</span>
        </div>

        <h1 class="hero-title">Operation Paperclip</h1>
        <p class="hero-subtitle">The Nazi Scientists Who Built the American Dream</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Scientists</span>
            <span class="stat-value text-accent">1,600+</span>
          </div>
          <div class="stat">
            <span class="stat-label">Slave Laborers Died</span>
            <span class="stat-value">20,000</span>
          </div>
          <div class="stat">
            <span class="stat-label">Duration</span>
            <span class="stat-value">1945–1959</span>
          </div>
        </div>

        <div class="hero-actions">
          <button onclick={`localStorage.setItem('historiqly_purchasing','operation-paperclip');window.location.href='${stripeUrl}'`} class="btn-buy-primary" id="heroBuyBtn">
            <span class="btn-buy-text">Buy the Book</span>
            <span class="btn-buy-price">$2.99</span>
          </button>
          <a href="/books/epub/operation-paperclip.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">In May 1945, a young German engineer with a broken arm and an SS commission surrendered to American forces in the Bavarian Alps. He had built the most advanced weapon on earth — and he wanted to go to the Moon. Within a decade, the United States had secretly recruited more than 1,600 Nazi scientists to win the Cold War.</p>
        <p>The deal was simple: <strong>trade justice for the stars</strong>. Falsify the records, erase the Nazi past, and give these men American lives. The men who had built weapons with slave labour would build the rockets that put Americans on the Moon.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Programme</span>
            <h3 class="card-value">1,600+</h3>
            <p class="card-desc">German scientists, engineers, and technicians recruited under Operation Paperclip and its successor programmes between 1945 and 1959. Their dossiers were falsified by the JIOA to circumvent President Truman's explicit ban on Nazi activists.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Slave Laborers Died</span>
            <h3 class="card-value text-accent">20,000</h3>
            <p class="card-desc">Prisoners who died at Mittelbau-Dora building the V-2. More than were killed by the weapon itself.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">V-2 Launches</span>
            <h3 class="card-value">67</h3>
            <p class="card-desc">V-2 rockets launched from White Sands by the Paperclip team — the birth of the U.S. space programme.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Von Braun's Rank</span>
            <h3 class="card-value">SS Major</h3>
            <p class="card-desc">Sturmbannführer. Personally approved by Heinrich Himmler. Von Braun called it a "formality." The JIOA called it irrelevant.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.prisonersV2} alt="Concentration camp prisoners assembling V-2 rockets at the Mittelwerk underground factory" />
            <div class="visual-overlay">
              <span class="overlay-label">MITTELWERK — SLAVE LABOUR, 1943–45</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Price of the Weapon</h3>
            <p>Prisoners from Konzentrationslager Dora assembled V-2 rockets inside tunnels beneath the Kohnstein mountain. The average life expectancy was six months. At least 20,000 died — from starvation, disease, beatings, and execution. Arthur Rudolph, the production manager who oversaw this workforce, later managed the Saturn V programme for NASA.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.v2WhiteSands} alt="V-2 rocket launch at White Sands Proving Ground, 1948" />
            <div class="visual-overlay">
               <span class="overlay-label">WHITE SANDS — V-2 LAUNCH, 1948</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Desert Launches</h3>
            <p>Between 1946 and 1952, von Braun's team launched 67 captured V-2 rockets from White Sands, New Mexico. The rockets took the first photographs of Earth's curvature from space and discovered cosmic radiation. One famously flew south instead of north and landed in a cemetery near Juárez, Mexico.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.explorer1} alt="Pickering, Van Allen, and Von Braun celebrate the launch of Explorer 1, January 1958" />
            <div class="visual-overlay">
               <span class="overlay-label">EXPLORER 1 — JANUARY 31, 1958</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Payoff</h3>
            <p>Three months after Sputnik, von Braun's Jupiter-C rocket launched Explorer 1 — America's first satellite. The photograph of Pickering, Van Allen, and von Braun holding the satellite model aloft became an icon of the Space Age. The SS major was now an American hero.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">From V-2 to Apollo</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">SEP 1944</span>
          <div class="timeline-content">
            <h4>The First V-2 Hits London</h4>
            <p>A ballistic missile travelling faster than sound strikes Chiswick, killing three. Over the next seven months, more than 3,000 V-2s will be launched. The weapon that kills 9,000 people costs 20,000 slave labourers' lives to produce.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">MAY 1945</span>
          <div class="timeline-content highlight">
            <h4>Von Braun Surrenders</h4>
            <p>With his arm in a cast and 500 engineers behind him, von Braun surrenders to the U.S. 44th Infantry Division. He has hidden 14 tons of rocket blueprints in a mine shaft as a bargaining chip. "We want to go to the Moon," he tells his captors.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">SEP 1946</span>
          <div class="timeline-content">
            <h4>Truman Signs the Directive</h4>
            <p>The president authorises Paperclip with one condition: no "active supporters of Nazi militarism." The JIOA responds by rewriting the dossiers. Von Braun's file is changed from "potential security threat" to "not an ardent Nazi."</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">OCT 1957</span>
          <div class="timeline-content">
            <h4>Sputnik</h4>
            <p>A Soviet satellite the size of a beach ball crosses the American sky, beeping. The Paperclip scientists go from embarrassment to national priority overnight. Von Braun is finally unleashed.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">JUL 1969</span>
          <div class="timeline-content highlight">
            <h4>Apollo 11</h4>
            <p>Saturn V — designed by von Braun, managed by Rudolph, launched by Debus — carries Armstrong, Aldrin, and Collins to the Moon. The most powerful rocket ever built works flawlessly. Its architects' wartime records remain sealed.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.vonBraunNasa} alt="Wernher von Braun, NASA Marshall Space Flight Center director, 1960" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Architect</span>
            <h3>Wernher von Braun</h3>
            <p>SS-Sturmbannführer, inventor of the V-2, and director of NASA's Marshall Space Flight Center. He designed the Saturn V that put men on the Moon. His party membership, SS rank, and connections to slave labour were systematically minimised in his JIOA dossier.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.rudolph} alt="Arthur Rudolph, Saturn V project manager" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Manager</span>
            <h3>Arthur Rudolph</h3>
            <p>Production manager at the Mittelwerk, where 20,000 slave labourers died building V-2 rockets. Later became project manager of the Saturn V. In 1984, facing a war crimes investigation, he renounced his U.S. citizenship and left the country.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.apollo11} alt="Saturn V launching Apollo 11, July 16, 1969" />
          <div class="image-caption">Saturn V AS-506 launches Apollo 11, July 16, 1969. Designed by von Braun. Managed by Rudolph. Launched by Debus.</div>
        </div>
        <div class="conclusion-text">
          <h2>Were the Stars Worth the Price?</h2>
          <p>Operation Paperclip traded justice for technological supremacy. The men who built the V-2 with slave labour built the Saturn V with taxpayer dollars. The files were falsified. The past was erased. The Moon was reached.</p>
          <p>The defenders say there was no alternative — that the Cold War demanded it, that the Soviets would have taken these men, that the cost of losing was greater than the cost of compromise. The critics say that this is the logic of the SS itself: <em>that human suffering can be weighed against a greater purpose.</em></p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the secret programme, the falsified files, the slave tunnels, and the rockets that reached the Moon.</p>
            <button onclick={`localStorage.setItem('historiqly_purchasing','operation-paperclip');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy" id="ctaBuyBtn">
              <span class="btn-buy-text">Buy the Book</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
            <a href="/books/epub/operation-paperclip.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_operation-paperclip', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_operation-paperclip') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuy = document.getElementById('heroBuyBtn');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuy) heroBuy.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuy = document.getElementById('ctaBuyBtn');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuy) ctaBuy.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

