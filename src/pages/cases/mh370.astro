---
import Layout from '../../layouts/Layout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-mh370-aircraft.jpg',
  klia: '/cases/images/mh370-klia-terminal.jpg',
  satellite: '/cases/images/mh370-satellite-arc.jpg',
  navy: '/cases/images/mh370-navy-search.jpg',
  searchVessel: '/cases/images/mh370-search-vessel.jpg',
  p8: '/cases/images/mh370-p8-poseidon.jpg',
  oceanShield: '/cases/images/mh370-ocean-shield.jpg',
};
---

<SidebarLayout
  title="Malaysia Airlines Flight 370 — The Plane That Vanished"
  description="MH370: A Boeing 777 carrying 239 people vanished in the digital age. Satellite handshakes, a flaperon on Réunion Island, and the most expensive search in aviation history. $2.99 EPUB."
  currentVolume={4}
  image="/books/covers/mh370.jpg"
  ogType="book"
  keywords="MH370 book, Malaysia Airlines Flight 370, missing plane, Indian Ocean search, Inmarsat satellite, flaperon, aviation mystery, Boeing 777"
  bookSeo={{ bookTitle: "Malaysia Airlines Flight 370", subtitle: "The Plane That Vanished from the Digital Age", price: "2.99", author: "HistorIQly Thrillers", genre: "Non-Fiction, History, Disappearances", format: "EBook", keywords: "MH370, Malaysia Airlines, missing plane, Indian Ocean, aviation mystery" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Disappearances", url: "/vol/disappearances" }, { name: "MH370", url: "/cases/mh370" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 04-2014</span>
          <span class="meta-badge alert">STATUS: MISSING</span>
        </div>

        <h1 class="hero-title">MH370</h1>
        <p class="hero-subtitle">The Plane That Vanished from the Digital Age</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Vanished</span>
            <span class="stat-value">2014</span>
          </div>
          <div class="stat">
            <span class="stat-label">Souls</span>
            <span class="stat-value">239</span>
          </div>
           <div class="stat">
            <span class="stat-label">Search Cost</span>
            <span class="stat-value text-accent">$155M+</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','mh370');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
          </div>
          <a href="/books/mh370.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section">
      <div class="intro-text">
        <p class="drop-cap">At 12:41 a.m. on March 8, 2014, a Boeing 777 carrying 239 people lifted off from Kuala Lumpur bound for Beijing. Thirty-eight minutes later, someone in the cockpit said <strong>"Good night, Malaysian Three Seven Zero"</strong> — and the aircraft vanished from radar. It was never seen again.</p>
        <p>The most expensive search in aviation history scanned <strong>230,000 km²</strong> of ocean floor. It found shipwrecks, underwater volcanoes, and the tracks of deep-sea creatures. It did not find MH370.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Disappearance</span>
            <h3 class="card-value">7h 38m</h3>
            <p class="card-desc">The aircraft flew for seven hours and thirty-eight minutes after vanishing from radar — crossing the Malay Peninsula, turning south, and flying deep into the Indian Ocean until the fuel ran out. No distress call was ever made.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">The Signal</span>
            <h3 class="card-value text-accent">7 Arcs</h3>
            <p class="card-desc">Seven satellite "handshakes" — automatic pings between the aircraft and an Inmarsat satellite — are the only electronic traces of the flight.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">The Search</span>
            <h3 class="card-value">$155M</h3>
            <p class="card-desc">The most expensive search in aviation history. 120,000 km² of seabed scanned. Three years. Nothing found.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">The Evidence</span>
            <h3 class="card-value">43 Pieces</h3>
            <p class="card-desc">Debris washed ashore across the Indian Ocean — from Réunion to Madagascar to Mozambique. The flaperon confirmed the crash. The cause remains unknown.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.satellite} alt="Inmarsat satellite handshake arcs showing possible positions of MH370" />
            <div class="visual-overlay">
              <span class="overlay-label">THE SEVENTH ARC</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Satellite Handshakes</h3>
            <p>Seven automated "pings" between the aircraft and the Inmarsat-3F1 satellite traced a path into the southern Indian Ocean. The final partial handshake at 8:19 a.m. — indicating fuel exhaustion — defined the "Seventh Arc," a 2,000-kilometre ring of possible crash sites in some of the deepest water on Earth.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.searchVessel} alt="Fugro Discovery search vessel in the Southern Indian Ocean" />
            <div class="visual-overlay">
               <span class="overlay-label">SOUTHERN INDIAN OCEAN</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Deep Search</h3>
            <p>Over three years, ships equipped with deep-tow sonar and autonomous underwater vehicles scanned 120,000 km² of ocean floor — an area larger than England. They mapped previously unknown underwater mountains, volcanic ridges, and trenches up to 6,000 metres deep. A private company later scanned another 112,000 km². Neither found the wreckage.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.p8} alt="P-8A Poseidon maritime patrol aircraft during MH370 search" />
            <div class="visual-overlay">
               <span class="overlay-label">MULTINATIONAL SEARCH</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Flaperon</h3>
            <p>On July 29, 2015, a barnacle-encrusted aircraft wing panel washed ashore on Réunion Island — 5,000 km from the crash zone. Confirmed as MH370's right flaperon, it was the first physical proof of the crash. Over 43 pieces of debris would follow, scattered across six countries along the Indian Ocean rim.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TIMELINE -->
    <section class="timeline-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">Into the Void</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">MAR 2014</span>
          <div class="timeline-content">
            <h4>Last Contact</h4>
            <p>"Good night, Malaysian Three Seven Zero." At 1:19 a.m., the cockpit signs off. Two minutes later, the transponder goes dark. The aircraft turns back across the Malay Peninsula and vanishes.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">MAR 2014</span>
          <div class="timeline-content highlight">
            <h4>Ended in the Indian Ocean</h4>
            <p>On March 24, PM Najib Razak announces that Inmarsat satellite data shows MH370 "ended in the southern Indian Ocean." The search shifts from the South China Sea to waters off Western Australia.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">JUL 2015</span>
          <div class="timeline-content">
            <h4>The Flaperon</h4>
            <p>A two-metre wing panel washes ashore on Réunion Island, 5,000 km from the search zone. Serial numbers confirm it: MH370's right flaperon — the first physical evidence of the crash.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">JAN 2017</span>
          <div class="timeline-content">
            <h4>Search Suspended</h4>
            <p>After scanning 120,000 km² of seabed at a cost of $155 million, Australia, Malaysia, and China suspend the underwater search. The wreckage has not been found.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">2025–26</span>
          <div class="timeline-content">
            <h4>The Search Continues</h4>
            <p>Ocean Infinity launches a new "no find, no fee" search in a refined 15,000 km² zone. As of early 2026, scanning continues. MH370 has not been found.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- KEY FIGURES -->
    <section class="figures-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.klia} alt="Kuala Lumpur International Airport terminal" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Captain</span>
            <h3>Zaharie Ahmad Shah</h3>
            <p>Age 53. Boeing 777 captain since 1998. 18,365 flight hours. Built a home flight simulator. FBI recovered a deleted simulation showing a route into the southern Indian Ocean, created 34 days before the flight. The Malaysian government initially called the data "not sinister."</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.navy} alt="Multinational naval search operations for MH370" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Families</span>
            <h3>Voice370</h3>
            <p>300 family members from 15 nationalities, led by Malaysian lawyer Grace Nathan. They have campaigned for over a decade to keep the search alive. "We speak not just for MH370 families, but because there is a larger issue of aviation safety and public interest at stake."</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.oceanShield} alt="Search operations for Malaysia Airlines Flight MH370" />
          <div class="image-caption">The southern Indian Ocean — the most expensive search in aviation history.</div>
        </div>
        <div class="conclusion-text">
          <h2>Good Night</h2>
          <p>Twelve years later, MH370 remains the greatest unsolved mystery in aviation history. The aircraft has not been found. The black boxes have not been recovered. The 239 people aboard have not been returned to their families.</p>
          <p><em>"Good night, Malaysian Three Seven Zero."</em> The silence that followed those words has never been broken.</p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the vanished flight, the satellite handshakes, the deep-sea search, and the families who refuse to give up.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','mh370');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
            </div>
            <a href="/books/mh370.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_mh370', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_mh370') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }
</script>

<style>
  /* SWISS TECHNICAL BENTO THEME */
  :root {
    --bg-dark: #0a0a0a;
    --bg-card: #111111;
    --bg-card-hover: #161616;
    --border-color: rgba(255, 255, 255, 0.08);
    --text-primary: #FAFAFA;
    --text-secondary: #A1A1AA;
    --accent: #F59E0B;
    --accent-dim: rgba(245, 158, 11, 0.1);

    --font-serif: 'Cormorant Garamond', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;
  }

  .case-file {
    background-color: var(--bg-dark);
    color: var(--text-primary);
    font-family: var(--font-sans);
    overflow-x: hidden;
  }

  /* UTILS */
  .text-accent { color: var(--accent); }

  /* HERO */
  .hero {
    position: relative;
    height: 90vh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-bottom: 1px solid var(--border-color);
  }

  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.4) grayscale(0.8) contrast(1.2); }
  .hero-overlay { position: absolute; inset: 0; background: radial-gradient(circle at center, transparent 0%, var(--bg-dark) 90%); }
  .hero-content { position: relative; z-index: 10; text-align: center; max-width: 900px; padding: 0 1.5rem; }
  .case-meta { display: flex; gap: 1rem; justify-content: center; margin-bottom: 2rem; }
  .meta-badge { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; padding: 0.4rem 0.8rem; border: 1px solid var(--border-color); background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); color: var(--text-secondary); }
  .meta-badge.alert { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
  .meta-badge.price { border-color: var(--accent); background: var(--accent-dim); color: var(--accent); font-weight: 800; }
  .hero-title { font-family: var(--font-serif); font-size: clamp(3.5rem, 8vw, 6rem); line-height: 0.9; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 1rem; text-shadow: 0 10px 30px rgba(0,0,0,0.7); }
  .hero-subtitle { font-size: clamp(1.1rem, 3vw, 1.5rem); color: var(--text-secondary); font-weight: 300; margin-bottom: 4rem; letter-spacing: 0.02em; }
  .hero-stats { display: flex; justify-content: center; gap: 3rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1); }
  .stat { display: flex; flex-direction: column; align-items: center; }
  .stat-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-secondary); margin-bottom: 0.25rem; }
  .stat-value { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 500; }
  .scroll-indicator { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 1rem; z-index: 10; }
  .scroll-indicator span { font-size: 0.65rem; letter-spacing: 0.3em; color: var(--text-secondary); opacity: 0.7; }
  .scroll-line { width: 1px; height: 60px; background: linear-gradient(to bottom, var(--text-secondary) 0%, transparent 100%); }

  /* HERO ACTIONS */
  .hero-actions { margin-top: 3rem; }
  .btn-buy-primary { display: inline-flex; align-items: center; gap: 1rem; padding: 1rem 2.5rem; background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); color: #000; border: none; border-radius: 8px; cursor: pointer; font-family: var(--font-sans); transition: all 0.25s; box-shadow: 0 4px 24px rgba(245, 158, 11, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3); }
  .btn-buy-primary:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(245, 158, 11, 0.45), 0 4px 12px rgba(0, 0, 0, 0.3); background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%); }
  .btn-buy-text { font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; }
  .btn-buy-price { font-size: 1.125rem; font-weight: 800; padding: 0.25rem 0.75rem; background: rgba(0, 0, 0, 0.15); border-radius: 4px; }
  .btn-download-primary { display: inline-flex; align-items: center; gap: 0.75rem; padding: 1rem 2.5rem; background: linear-gradient(135deg, #5DB585 0%, #4a9e70 100%); color: #000; text-decoration: none; border: none; border-radius: 8px; font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; font-family: var(--font-sans); transition: all 0.25s; box-shadow: 0 4px 24px rgba(93, 181, 133, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3); }
  .btn-download-primary:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(93, 181, 133, 0.45), 0 4px 12px rgba(0, 0, 0, 0.3); background: linear-gradient(135deg, #6FC494 0%, #5DB585 100%); }
  .cta-buy, .cta-download { width: 100%; justify-content: center; }

  /* INTRO */
  .intro-section { padding: 8rem 1.5rem; max-width: 800px; margin: 0 auto; text-align: center; }
  .intro-text p { font-family: var(--font-serif); font-size: clamp(1.25rem, 3vw, 1.75rem); line-height: 1.6; color: var(--text-secondary); margin-bottom: 2rem; }
  .intro-text strong { color: var(--text-primary); font-weight: 600; }

  /* BENTO GRID */
  .bento-section { padding: 2rem 1.5rem 8rem; max-width: 1200px; margin: 0 auto; }
  .bento-grid { display: grid; grid-template-columns: repeat(1, 1fr); gap: 1.5rem; }
  @media (min-width: 768px) { .bento-grid { grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(2, minmax(200px, auto)); } .large-card { grid-column: span 2; grid-row: span 2; } }
  .bento-card { background: var(--bg-card); border: 1px solid var(--border-color); padding: 2rem; border-radius: 4px; transition: transform 0.3s ease, border-color 0.3s ease; display: flex; flex-direction: column; justify-content: center; }
  .bento-card:hover { transform: translateY(-2px); border-color: rgba(255,255,255,0.2); background: var(--bg-card-hover); }
  .card-label { display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-secondary); margin-bottom: 1rem; }
  .card-value { font-family: var(--font-serif); font-size: 3rem; font-weight: 400; margin-bottom: 0.5rem; line-height: 1; }
  .discovery-card .card-value { font-size: 5rem; font-weight: 700; }
  .check-card .card-value { font-size: 4rem; }
  .card-desc { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.5; }

  /* EVIDENCE */
  .evidence-section { padding: 4rem 1.5rem; background: #0F0F0F; border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color); }
  .section-header { text-align: center; margin-bottom: 4rem; }
  .section-label { font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); display: block; margin-bottom: 0.5rem; }
  .section-title { font-family: var(--font-serif); font-size: 3rem; font-weight: 400; }
  .evidence-grid { max-width: 1000px; margin: 0 auto; display: grid; gap: 4rem; }
  .evidence-card { display: grid; grid-template-columns: 1fr; gap: 2rem; align-items: center; }
  @media (min-width: 768px) { .evidence-card { grid-template-columns: 1fr 1fr; } .evidence-card:nth-child(even) .evidence-visual { order: 2; } }
  .evidence-visual { position: relative; border: 1px solid var(--border-color); }
  .evidence-visual img { width: 100%; display: block; filter: brightness(0.8) contrast(1.1); }
  .visual-overlay { position: absolute; bottom: 0; left: 0; width: 100%; padding: 0.5rem; background: rgba(0,0,0,0.7); backdrop-filter: blur(2px); border-top: 1px solid rgba(255,255,255,0.1); }
  .overlay-label { font-size: 0.6rem; font-family: monospace; color: var(--accent); letter-spacing: 0.1em; }
  .evidence-data h3 { font-family: var(--font-serif); font-size: 2rem; margin-bottom: 1rem; font-weight: 500; }
  .evidence-data p { color: var(--text-secondary); line-height: 1.7; font-size: 1.1rem; }

  /* TIMELINE */
  .timeline-section { padding: 6rem 1.5rem; max-width: 800px; margin: 0 auto; }
  .timeline { position: relative; padding: 2rem 0; }
  .timeline-line { position: absolute; left: 50%; top: 0; bottom: 0; width: 1px; background: var(--border-color); transform: translateX(-50%); }
  .timeline-entry { position: relative; display: flex; justify-content: center; margin-bottom: 4rem; }
  .timeline-year { position: absolute; left: 50%; transform: translateX(-50%); background: var(--bg-dark); padding: 0.25rem 0.5rem; font-family: monospace; color: var(--accent); font-size: 0.8rem; border: 1px solid var(--border-color); z-index: 2; }
  .timeline-content { width: 45%; background: var(--bg-card); border: 1px solid var(--border-color); padding: 1.5rem; position: relative; }
  .timeline-entry.left .timeline-content { margin-right: auto; text-align: right; }
  .timeline-entry.right .timeline-content { margin-left: auto; text-align: left; }
