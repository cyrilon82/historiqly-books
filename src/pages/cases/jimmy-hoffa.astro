---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-jimmy-hoffa-portrait.jpg',
  mugshot: '/cases/images/hoffa-1939-mugshot.jpg',
  spindel: '/cases/images/hoffa-spindel-1957.jpg',
  son: '/cases/images/hoffa-and-son.jpg',
  kennedy: '/cases/images/figure-robert-kennedy.jpg',
  teamsters: '/cases/images/teamsters-headquarters.jpg',
  lewisburg: '/cases/images/lewisburg-penitentiary.jpg',
  alternative: '/cases/images/hoffa-alternative.jpg',
};
---

<SidebarLayout
  title="Jimmy Hoffa — The Most Powerful Man Who Ever Vanished"
  description="Jimmy Hoffa: The labor titan who built the Teamsters, fought Bobby Kennedy, survived prison, and vanished without a trace. The true story of America's most famous disappearance. $2.99 EPUB."
  currentVolume={3}
  image="/books/covers/jimmy-hoffa.jpg"
  ogType="book"
  keywords="Jimmy Hoffa book, Hoffa disappearance, Teamsters union, Machus Red Fox, Frank Sheeran, Bobby Kennedy, organized crime, disappearance"
  bookSeo={{ bookTitle: "Jimmy Hoffa", subtitle: "The Most Powerful Man Who Ever Vanished", price: "2.99", author: "HistorIQly Mysteries", genre: "Non-Fiction, History, Disappearances", format: "EBook", keywords: "Jimmy Hoffa, Teamsters, disappearance, Mafia" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Disappearances", url: "/vol/disappearances" }, { name: "Jimmy Hoffa", url: "/cases/jimmy-hoffa" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 03-1975</span>
          <span class="meta-badge alert">STATUS: COLD CASE</span>
        </div>

        <h1 class="hero-title">Jimmy Hoffa</h1>
        <p class="hero-subtitle">The Most Powerful Man Who Ever Vanished</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Vanished</span>
            <span class="stat-value">1975</span>
          </div>
          <div class="stat">
            <span class="stat-label">Body</span>
            <span class="stat-value text-accent">Never Found</span>
          </div>
           <div class="stat">
            <span class="stat-label">Suspects</span>
            <span class="stat-value">6+</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','jimmy-hoffa');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
          </div>
          <a href="/books/jimmy-hoffa.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">On July 30, 1975, the most powerful labor leader in American history walked into a restaurant parking lot in suburban Detroit and was never seen again. Jimmy Hoffa had built the Teamsters into the <strong>largest union on earth</strong>, negotiated the greatest labor contract in history, survived Bobby Kennedy's crusade, and endured federal prison.</p>
        <p>Then, one warm summer afternoon, he simply <strong>vanished</strong>. Fifty years later, his body has never been found.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Empire</span>
            <h3 class="card-value">2M</h3>
            <p class="card-desc">Teamsters members under Hoffa's leadership — the largest single union in American history. He negotiated the National Master Freight Agreement, covering 450,000 drivers under one contract.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">The Vanishing</span>
            <h3 class="card-value text-accent">2:45 PM</h3>
            <p class="card-desc">Last seen in the parking lot of the Machus Red Fox restaurant, Bloomfield Township, Michigan.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">The Hunt</span>
            <h3 class="card-value">50 Years</h3>
            <p class="card-desc">200+ FBI agents. 16,000+ pages. Dozens of searches. His body has never been found.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Declared Dead</span>
            <h3 class="card-value">1982</h3>
            <p class="card-desc">Legally declared dead seven years after his disappearance. Case remains officially open with the FBI.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.mugshot} alt="Jimmy Hoffa 1939 mugshot" />
            <div class="visual-overlay">
              <span class="overlay-label">1939 MUGSHOT</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Mercury Marquis</h3>
            <p>A maroon 1975 Mercury Marquis Brougham, borrowed by Chuckie O'Brien — Hoffa's foster son. FBI search dogs detected Hoffa's scent in the back seat. A single strand of hair, confirmed by DNA as Hoffa's, was recovered. O'Brien claimed he was delivering fish.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.lewisburg} alt="Lewisburg Federal Penitentiary" />
            <div class="visual-overlay">
               <span class="overlay-label">LEWISBURG PENITENTIARY</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Prison Feud</h3>
            <p>At Lewisburg Federal Penitentiary, Hoffa's friendship with Genovese capo Tony Provenzano erupted into a fistfight over pension payments. The blood feud that followed became one of the primary motives for Hoffa's murder.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.teamsters} alt="Teamsters headquarters, Washington D.C." />
            <div class="visual-overlay">
               <span class="overlay-label">THE MARBLE PALACE</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Pension Fund</h3>
            <p>The Central States Pension Fund financed Las Vegas casinos — the Dunes, Caesars Palace, the Stardust. The mob skimmed $300 million. Hoffa's return to power threatened hundreds of millions in organized crime revenue.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">The Disappearance</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">1957</span>
          <div class="timeline-content">
            <h4>King of the Road</h4>
            <p>Hoffa is elected Teamsters president by a 3-to-1 margin. He builds the union to 2 million members and negotiates the National Master Freight Agreement, the greatest labor contract in history.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1964</span>
          <div class="timeline-content">
            <h4>Bobby Kennedy Wins</h4>
            <p>After years of pursuit by the "Get Hoffa Squad," Hoffa is convicted of jury tampering and pension fund fraud. Sentenced to 13 years. Begins serving time at Lewisburg in 1967.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1971</span>
          <div class="timeline-content">
            <h4>Nixon's Deal</h4>
            <p>President Nixon commutes Hoffa's sentence — but with a catch: he is barred from union activity until 1980. Hoffa is convinced the restriction was engineered by the mob to keep him away from the Teamsters.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">JUL 1975</span>
          <div class="timeline-content highlight">
            <h4>Vanished</h4>
            <p>Hoffa drives to the Machus Red Fox restaurant for a meeting with mob figures. He is last seen entering a maroon Mercury at 2:45 PM. He is never seen again. His body has never been found.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">2025</span>
          <div class="timeline-content">
            <h4>Fifty Years</h4>
            <p>The FBI marks the 50th anniversary. Dozens of searches over five decades have found nothing. The case remains officially open — the longest unsolved disappearance in FBI history.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.alternative} alt="Jimmy Hoffa" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Vanished</span>
            <h3>Jimmy Hoffa</h3>
            <p>Born 1913 in Brazil, Indiana. Rose from a loading dock in Detroit to become president of the Teamsters — America's largest and most powerful union. Convicted of jury tampering and fraud, imprisoned, released by Nixon, and killed by the organized crime figures who had once been his partners.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.kennedy} alt="Robert F. Kennedy" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Nemesis</span>
            <h3>Robert F. Kennedy</h3>
            <p>Attorney General who made Hoffa's destruction a personal crusade. Created the "Get Hoffa Squad" — 20 prosecutors devoted exclusively to building criminal cases. Their rivalry was one of the most intense personal vendettas in American political history.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.son} alt="Jimmy Hoffa and his son James P. Hoffa" />
          <div class="image-caption">Jimmy Hoffa with his son James P. Hoffa, who would later serve as Teamsters president.</div>
        </div>
        <div class="conclusion-text">
          <h2>Where Is Jimmy Hoffa?</h2>
          <p>Fifty years of searches — farms, stadiums, landfills, backyards — have found nothing. The FBI has spent tens of millions of dollars. More than two hundred agents have worked the case. His body has never been recovered.</p>
          <p>The man who built the American middle class was erased from the face of the earth. The case remains <em>officially open</em>.</p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the labor titan, the mob, the vendetta, and the vanishing.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','jimmy-hoffa');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
            </div>
            <a href="/books/jimmy-hoffa.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_jimmy-hoffa', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_jimmy-hoffa') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

