---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/kujau-painting.jpg',
  kujau: '/cases/images/suspect-kujau.jpg',
  trevorRoper: '/cases/images/suspect-trevor-roper.jpg',
  heidemann: '/cases/images/heidemann.jpg',
  murdoch: '/cases/images/suspect-murdoch.jpg',
  forgedSignature: '/cases/images/forged-signature.jpg',
  fhMonogram: '/cases/images/fh-ah-monogram.svg',
};
---

<SidebarLayout
  title="Hitler Diaries Book — The Forgery That Fooled the World"
  description="The Hitler Diaries: The stunning forgery that duped journalists worldwide. Non-fiction ebook about the biggest media fraud in history. $2.99 EPUB."
  currentVolume={1}
  image="/books/covers/hitler-diaries.jpg"
  ogType="book"
  keywords="Hitler Diaries book, Hitler Diaries ebook, Konrad Kujau forgery, media fraud history, World War 2 hoax, historical forgery non-fiction"
  bookSeo={{ bookTitle: "The Hitler Diaries", subtitle: "The Forgery That Fooled the World", price: "2.99", author: "HistorIQly Mysteries", genre: "Non-Fiction, History, Hoaxes, World War II", format: "EBook", keywords: "Hitler Diaries, forgery, Konrad Kujau, media fraud" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Hoaxes", url: "/vol/hoaxes" }, { name: "The Hitler Diaries", url: "/cases/hitler-diaries" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 03-1983</span>
          <span class="meta-badge alert">STATUS: HOAX</span>
        </div>

        <h1 class="hero-title">The Hitler Diaries</h1>
        <p class="hero-subtitle">The Forgery That Fooled the World</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Published</span>
            <span class="stat-value">1983</span>
          </div>
          <div class="stat">
            <span class="stat-label">Exposed</span>
            <span class="stat-value">11 days</span>
          </div>
           <div class="stat">
            <span class="stat-label">Cost</span>
            <span class="stat-value text-accent">9.3M DM</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','hitler-diaries');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
            <a href="https://www.amazon.com/dp/B0GHPVR1MX" target="_blank" rel="noopener" class="btn-buy-kindle">
              Buy on Kindle →
            </a>
          </div>
          <a href="/books/epub/hitler-diaries.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">In April 1983, <em>Stern</em> magazine announced the discovery of Adolf Hitler's secret diaries — sixty-two handwritten volumes, smuggled out of East Germany. The world's media went into a frenzy. Within eleven days, forensic analysis revealed them as crude forgeries. The paper was wrong. The ink was wrong. Even the initials on the cover were wrong.</p>
        <p>It took a Stuttgart con man, a Nazi-obsessed journalist, and <strong>9.3 million Deutsche Marks</strong> to produce the greatest media hoax of the twentieth century.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Forgery</span>
            <h3 class="card-value">62</h3>
            <p class="card-desc">Handwritten volumes produced by Konrad Kujau between 1978 and 1983, covering the period from 1932 to 1945. He wrote them while watching television, copying facts from published reference books.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Price Per Volume</span>
            <h3 class="card-value text-accent">200K</h3>
            <p class="card-desc">Deutsche Marks per diary volume. Stern paid without forensic testing.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">Embezzled</span>
            <h3 class="card-value">~2M</h3>
            <p class="card-desc">DM skimmed by journalist Gerd Heidemann from the diary payments.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Time to Debunk</span>
            <h3 class="card-value">11</h3>
            <p class="card-desc">Days from triumphant press conference to total forensic demolition by the German Federal Archives.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.forgedSignature} alt="Forged Hitler signature by Konrad Kujau" />
            <div class="visual-overlay">
              <span class="overlay-label">HANDWRITING ANALYSIS</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Circular Authentication</h3>
            <p>Kujau had been forging Hitler documents for years. His fakes entered the collector market and were used as "authenticated" comparison specimens. When Stern's handwriting experts checked the diaries against "known" Hitler writing, they were comparing forgeries against forgeries — a closed loop of deception.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual uv-visual">
            <div class="uv-glow-card">
              <div class="uv-label">UV 365nm</div>
              <div class="uv-result">BLANKOPHOR<br/><span class="uv-sub">DETECTED</span></div>
              <div class="uv-bars">
                <div class="uv-bar" style="height:85%"></div>
                <div class="uv-bar" style="height:62%"></div>
                <div class="uv-bar" style="height:94%"></div>
                <div class="uv-bar" style="height:78%"></div>
                <div class="uv-bar" style="height:100%"></div>
              </div>
              <div class="uv-footer">OPTICAL BRIGHTENER — POST-1954</div>
            </div>
            <div class="visual-overlay">
               <span class="overlay-label">MATERIAL ANALYSIS</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Blankophor</h3>
            <p>The paper contained blankophor — an optical brightening agent not manufactured until after World War II. The ink was modern. The binding thread was polyester. Under UV light, the paper fluoresced like a neon sign. Every material was wrong. A single afternoon in a lab would have killed the fraud at any point during the three years Stern was paying.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual monogram-visual">
            <img src={images.fhMonogram} alt="FH vs AH — the Gothic initials Kujau stamped on all 62 diary covers" />
            <div class="visual-overlay">
               <span class="overlay-label">THE FH MONOGRAM</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>"FH" Not "AH"</h3>
            <p>The Gothic initials on every diary cover were supposed to read "AH" for Adolf Hitler. But Kujau chose a typeface where the letters F and A look nearly identical — and stamped "FH" on all sixty-two volumes. Nobody at Stern, and not even the Oxford historian who authenticated them, noticed the error.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">Eleven Days</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">~1978</span>
          <div class="timeline-content">
            <h4>The Forgery Begins</h4>
            <p>Kujau starts writing the diaries in Stuttgart, using modern notebooks aged with tea, wax seals, and physical distressing. He copies content from published histories of the Third Reich.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1980</span>
          <div class="timeline-content">
            <h4>Heidemann Takes the Bait</h4>
            <p>Stern reporter Gerd Heidemann sees a diary volume at a collector's home. He traces the source to Kujau and is told an elaborate story about a wartime plane crash near Dresden.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1981–83</span>
          <div class="timeline-content">
            <h4>9.3 Million Marks</h4>
            <p>Stern pays for the diaries in secret instalments over three years. No forensic analysis is conducted. No outside historians are consulted. Heidemann embezzles millions from the payments.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">APR 1983</span>
          <div class="timeline-content">
            <h4>Publication</h4>
            <p>Hugh Trevor-Roper authenticates the diaries in a Swiss bank vault. The Sunday Times, Newsweek, and Paris Match purchase serialisation rights. Stern holds a triumphant press conference.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">MAY 1983</span>
          <div class="timeline-content highlight">
            <h4>Total Collapse</h4>
            <p>The Bundesarchiv declares the diaries "grotesque and superficial forgeries." Paper, ink, thread — all postwar. Kujau and Heidemann are arrested. Stern's editors are fired. Trevor-Roper's reputation is destroyed.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.kujau} alt="Konrad Kujau, 1992" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Forger</span>
            <h3>Konrad Kujau</h3>
            <p>A Stuttgart memorabilia dealer who had been forging Hitler documents for years. Charming, flamboyant, and constitutionally dishonest. He wrote 62 diary volumes while watching TV, aged them with tea, and sold them for millions. After prison, he became a celebrity artist selling acknowledged fakes.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.trevorRoper} alt="Hugh Trevor-Roper, 1975" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Authenticator</span>
            <h3>Hugh Trevor-Roper</h3>
            <p>Oxford's Regius Professor of History and author of <em>The Last Days of Hitler</em>. Flown to a Swiss bank vault under time pressure, he authenticated the diaries — then publicly reversed himself within days. The humiliation followed him to his grave.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.heidemann} alt="Gerd Heidemann, 2017" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Journalist</span>
            <h3>Gerd Heidemann</h3>
            <p>Stern's star reporter and a Nazi memorabilia obsessive who owned Hermann Göring's former yacht. He brokered the diary deal, convinced his editors to pay millions — and embezzled roughly two million Marks from the payments along the way. Sentenced to four years and eight months in prison.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.murdoch} alt="Rupert Murdoch at the World Economic Forum" />
          <div class="image-caption">Rupert Murdoch. "Fuck Dacre. Publish."</div>
        </div>
        <div class="conclusion-text">
          <h2>The Desire to Believe</h2>
          <p>The Hitler Diaries were not a sophisticated forgery. The paper was wrong. The ink was wrong. The initials on the cover read "FH" instead of "AH." A single lab test at any point during three years of payments would have killed the fraud instantly.</p>
          <p>But nobody tested. Because <em>nobody wanted to know.</em></p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the forger, the journalist, the professor, and the greatest media hoax of the twentieth century.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','hitler-diaries');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
              <a href="https://www.amazon.com/dp/B0GHPVR1MX" target="_blank" rel="noopener" class="btn-buy-kindle cta-kindle">
                Buy on Kindle →
              </a>
            </div>
            <a href="/books/epub/hitler-diaries.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_hitler-diaries', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_hitler-diaries') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

