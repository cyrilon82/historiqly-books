---
import Layout from '../../layouts/Layout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-cottingley-fairies-1.jpg',
  elsieGnome: '/cases/images/cottingley-fairies-elsie-gnome.jpg',
  francesLeaping: '/cases/images/cottingley-fairies-frances-leaping.jpg',
  elsieHarebells: '/cases/images/cottingley-fairies-elsie-harebells.jpg',
  girlsTogether: '/cases/images/cottingley-frances-elsie-together.jpg',
  doyle: '/cases/images/suspect-arthur-conan-doyle.jpg',
  gardner: '/cases/images/suspect-edward-gardner.jpg',
  strand: '/cases/images/cottingley-strand-magazine-1920.jpg',
};
---

<SidebarLayout
  title="The Cottingley Fairies — The Hoax That Fooled Sherlock Holmes's Creator"
  description="The Cottingley Fairies: How two Yorkshire girls fooled Arthur Conan Doyle with cardboard cutouts and hatpins. Non-fiction ebook. $2.99 EPUB."
  currentVolume={1}
  image="/books/covers/cottingley-fairies.jpg"
  ogType="book"
  keywords="Cottingley Fairies book, Cottingley Fairies ebook, Arthur Conan Doyle fairies, hoax history, Yorkshire fairies, photography hoax"
  bookSeo={{ bookTitle: "The Cottingley Fairies", subtitle: "Two Girls, Five Photographs, and a Nation That Wanted to Believe", price: "2.99", author: "HistorIQly Thrillers", genre: "Non-Fiction, History, Hoaxes", format: "EBook", keywords: "Cottingley Fairies, hoax, Arthur Conan Doyle, fairy photographs, Yorkshire" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Hoaxes", url: "/vol/hoaxes" }, { name: "The Cottingley Fairies", url: "/cases/cottingley-fairies" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 04-1917</span>
          <span class="meta-badge alert">STATUS: HOAX</span>
        </div>

        <h1 class="hero-title">The Cottingley Fairies</h1>
        <p class="hero-subtitle">The Photographs That Fooled the World</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">First Photo</span>
            <span class="stat-value">1917</span>
          </div>
          <div class="stat">
            <span class="stat-label">Confessed</span>
            <span class="stat-value">1983</span>
          </div>
          <div class="stat">
            <span class="stat-label">Secret Kept</span>
            <span class="stat-value text-accent">66 yrs</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','cottingley-fairies');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy the Book</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
          </div>
          <a href="/books/epub/cottingley-fairies.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

      <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section">
      <div class="intro-text">
        <p class="drop-cap">In the summer of 1917, two Yorkshire girls borrowed a camera, cut some figures from a children's book, and pushed them into the bank with hatpins. The photographs they took would fool Arthur Conan Doyle, two expert investigators, the editors of The Strand Magazine, and millions of readers across the world.</p>
        <p>They kept the secret for <strong>sixty-six years</strong>.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Prank</span>
            <h3 class="card-value">1917</h3>
            <p class="card-desc">Elsie Wright (16) and Frances Griffiths (9) make cardboard fairy cutouts from a children's book illustration. They push them into Cottingley Beck's bank with hatpins and take a photograph. A private joke that escaped all control.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Photographs</span>
            <h3 class="card-value text-accent">5</h3>
            <p class="card-desc">Total fairy photographs produced, 1917–1920. Three more taken with cameras supplied by Arthur Conan Doyle.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">The Source</span>
            <h3 class="card-value">1914</h3>
            <p class="card-desc">Publication year of <em>Princess Mary's Gift Book</em>, the illustrated charity anthology whose fairy drawings Elsie copied.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Sold at auction</span>
            <h3 class="card-value">£20K+</h3>
            <p class="card-desc">Two original photographs sold in 2018 for over £20,400 — ten times their pre-sale estimate.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.elsieGnome} alt="Elsie Wright with a gnome-like fairy figure, September 1917" />
            <div class="visual-overlay">
              <span class="overlay-label">PHOTO 2 — SEPTEMBER 1917</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Cardboard Cutouts</h3>
            <p>Elsie copied illustrations by artist Claude Shepperson from <em>Princess Mary's Gift Book</em> (1914), a charity anthology that sold 604,884 copies. She cut the figures with her aunt's tailor's scissors, mounted them on card, and fixed them with hatpins pushed into the bank. The camera's long exposure and shallow depth of field made the pins invisible. James Randi identified the source book in 1978 — sixty-one years after the first photograph was taken.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.strand} alt="The Strand Magazine page with fairy photographs, December 1920" />
            <div class="visual-overlay">
              <span class="overlay-label">THE STRAND — DEC 1920</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Expert Enhancement</h3>
            <p>When photographic expert Harold Snelling declared the negatives genuine, he simultaneously retouched enhanced reprints at Edward Gardner's request — improving image quality for publication. The reprints he produced were what Kodak examined, what The Strand published, and what the world believed. Kodak found no evidence of manipulation in the enhanced reprints — but refused to certify authenticity, a caution Gardner dismissed as institutional bias.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.francesLeaping} alt="Frances Griffiths with a leaping fairy, August 1920" />
            <div class="visual-overlay">
              <span class="overlay-label">PHOTO 3 — AUGUST 1920</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Fashionable Fairies</h3>
            <p>Sceptics noted almost immediately that the fairy figures had strikingly fashionable hairstyles — the swept-back bobs and Edwardian illustration styles of the 1910s rather than the wild, timeless appearance of genuine supernatural beings. The <em>Westminster Gazette</em> reproduced the photographs alongside paper dolls for comparison. The comparison was uncomfortable. But in a nation still processing the loss of a generation, uncomfortable comparisons attracted less attention than hope.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TIMELINE -->
    <section class="timeline-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">The Sixty-Six-Year Secret</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">1917</span>
          <div class="timeline-content">
            <h4>The First Photographs</h4>
            <p>Elsie and Frances take the first two fairy photographs at Cottingley Beck using Arthur Wright's Midg camera. Wright develops them, suspects cardboard cutouts, and locks the camera away.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">DEC 1920</span>
          <div class="timeline-content">
            <h4>An Epoch-Making Event</h4>
            <p>Arthur Conan Doyle publishes "Fairies Photographed" in The Strand Magazine. The issue sells out within days. A grieving post-war nation chooses to believe.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1978</span>
          <div class="timeline-content">
            <h4>The Source Identified</h4>
            <p>James Randi identifies the fairy figures as copies of Claude Shepperson's illustration in Princess Mary's Gift Book (1914). Computer enhancements reveal supporting hatpins. Still no confession.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1983</span>
          <div class="timeline-content highlight">
            <h4>The Confession</h4>
            <p>Elsie Wright sends a written admission to the British Journal of Photography. Frances confirms photos 1–4 were faked — but maintains the fifth photograph was real until her death in 1986.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">2024</span>
          <div class="timeline-content">
            <h4>CT Scan</h4>
            <p>Researchers CT-scan the original cameras at 7-micron resolution at the University of Bradford. The cameras are now held at the National Science and Media Museum, Bradford. No fairies found.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- KEY FIGURES -->
    <section class="figures-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.doyle} alt="Sir Arthur Conan Doyle, 1893" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Believer</span>
            <h3>Arthur Conan Doyle</h3>
            <p>Creator of Sherlock Holmes — the most rigorous mind in English detective fiction — and one of the most credulous figures in the history of British spiritualism. Having lost his son to influenza in 1918 and his brother in 1919, Doyle used the photographs to argue that the dead were near and the world was merciful. He died in 1930 still convinced the photographs were genuine.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.gardner} alt="Edward Lewis Gardner" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Champion</span>
            <h3>Edward Gardner</h3>
            <p>The Theosophical Society lecturer who discovered the photographs and brought them to Conan Doyle's attention. Gardner arranged the expert examination, supplied the girls with cameras and marked plates for the 1920 session, and spent fifty years defending the photographs' authenticity. He lived to be exactly one hundred years old, dying in 1969 without ever changing his mind.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.girlsTogether} alt="Frances Griffiths and Elsie Wright at Cottingley Beck" />
          <div class="image-caption">Frances Griffiths and Elsie Wright. Cottingley Beck, c. 1920.</div>
        </div>
        <div class="conclusion-text">
          <h2>They Wanted to Believe</h2>
          <p>Elsie and Frances were not especially skilled deceivers. The cardboard was cardboard. The hatpins were hatpins. The source was a children's book.</p>
          <p>What kept the secret for sixty-six years was not cunning — it was the simple fact that <em>the world did not want the photographs to be fake.</em> A nation still deep in grief, with millions dead and a generation missing, chose a story with fairies over a story without them.</p>
          <p>Frances put it plainly, when she had nothing left to protect: <em>"They wanted to believe."</em></p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of two girls, a borrowed camera, and the sixty-six-year secret that fooled the creator of Sherlock Holmes.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','cottingley-fairies');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy the Book</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
            </div>
            <a href="/books/epub/cottingley-fairies.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_cottingley-fairies', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_cottingley-fairies') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }
</script>

<style>
  /* SWISS TECHNICAL BENTO THEME */
  :root {
    --bg-dark: #0a0a0a;
    --bg-card: #111111;
    --bg-card-hover: #161616;
    --border-color: rgba(255, 255, 255, 0.08);
    --text-primary: #FAFAFA;
    --text-secondary: #A1A1AA;
    --accent: #F59E0B;
    --accent-dim: rgba(245, 158, 11, 0.1);

    --font-serif: 'Cormorant Garamond', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;
  }

  .case-file {
    background-color: var(--bg-dark);
    color: var(--text-primary);
    font-family: var(--font-sans);
    overflow-x: hidden;
  }

  /* UTILS */
  .text-accent { color: var(--accent); }

  /* HERO */
  .hero {
    position: relative;
    height: 90vh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-bottom: 1px solid var(--border-color);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.35) grayscale(0.7) contrast(1.2);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 0%, var(--bg-dark) 90%);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 900px;
    padding: 0 1.5rem;
  }

  .case-meta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .meta-badge {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border-color);
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(4px);
    color: var(--text-secondary);
  }

  .meta-badge.alert {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  .meta-badge.price {
    border-color: var(--accent);
    background: var(--accent-dim);
    color: var(--accent);
    font-weight: 800;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 8vw, 6rem);
    line-height: 0.9;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    text-shadow: 0 10px 30px rgba(0,0,0,0.7);
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    color: var(--text-secondary);
    font-weight: 300;
    margin-bottom: 4rem;
    letter-spacing: 0.02em;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
  }

  .stat-value {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    z-index: 10;
  }

  .scroll-indicator span {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--text-secondary);
    opacity: 0.7;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--text-secondary) 0%, transparent 100%);
  }

  /* HERO ACTIONS */
  .hero-actions {
    margin-top: 3rem;
  }

  /* PRIMARY BUY BUTTON */
  .btn-buy-primary {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
    color: #000;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: all 0.25s;
    box-shadow: 0 4px 24px rgba(245, 158, 11, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .btn-buy-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(245, 158, 11, 0.45), 0 4px 12px rgba(0, 0, 0, 0.3);
    background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%);
  }

  .btn-buy-text {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .btn-buy-price {
    font-size: 1.125rem;
    font-weight: 800;
    padding: 0.25rem 0.75rem;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 4px;
  }

  /* PRIMARY DOWNLOAD BUTTON */
  .btn-download-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, #5DB585 0%, #4a9e70 100%);
    color: #000;
    text-decoration: none;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-sans);
    transition: all 0.25s;
    box-shadow: 0 4px 24px rgba(93, 181, 133, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .btn-download-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(93, 181, 133, 0.45), 0 4px 12px rgba(0, 0, 0, 0.3);
    background: linear-gradient(135deg, #6FC494 0%, #5DB585 100%);
  }

  .cta-buy, .cta-download {
    width: 100%;
    justify-content: center;
  }

  /* INTRO */
  .intro-section {
    padding: 8rem 1.5rem;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .intro-text p {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .intro-text strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* BENTO GRID */
  .bento-section {
    padding: 2rem 1.5rem 8rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(2, minmax(200px, auto));
    }

    .large-card {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  .bento-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    padding: 2rem;
    border-radius: 4px;
    transition: transform 0.3s ease, border-color 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .bento-card:hover {
    transform: translateY(-2px);
    border-color: rgba(255,255,255,0.2);
    background: var(--bg-card-hover);
  }

  .card-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .card-value {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .discovery-card .card-value { font-size: 5rem; font-weight: 700; }
  .check-card .card-value { font-size: 4rem; }

  .card-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* EVIDENCE */
  .evidence-section {
    padding: 4rem 1.5rem;
