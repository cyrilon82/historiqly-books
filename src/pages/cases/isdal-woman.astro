---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-isdal-valley.jpg',
  bergenStation: '/cases/images/isdal-bergen-station.jpg',
  bryggen: '/cases/images/isdal-bryggen-bergen.jpg',
  ulriken: '/cases/images/isdal-ulriken-mountain.jpg',
  valleyHistoric: '/cases/images/isdal-valley-historic.jpg',
};
---

<SidebarLayout
  title="The Isdal Woman — Nine Identities, One Burned Body"
  description="The Isdal Woman: a burned body in Norway's Death Valley, nine fake identities, coded notes, and no answers. The full story of Scandinavia's most baffling cold case. $2.99 EPUB."
  currentVolume={3}
  image="/books/covers/isdal-woman.jpg"
  ogType="book"
  keywords="Isdal Woman book, Isdal Woman ebook, Bergen Norway mystery, cold case, unidentified woman, Death Valley Norway, espionage Cold War"
  bookSeo={{ bookTitle: "The Isdal Woman", subtitle: "Nine Identities, One Burned Body", price: "2.99", author: "HistorIQly Mysteries", genre: "Non-Fiction, History, Cold Cases, True Crime", format: "EBook", keywords: "Isdal Woman, Bergen, Norway, cold case, espionage" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Cold Cases", url: "/vol/cold-cases" }, { name: "The Isdal Woman", url: "/cases/isdal-woman" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 07-1970</span>
          <span class="meta-badge alert">STATUS: UNSOLVED</span>
        </div>

        <h1 class="hero-title">The Isdal Woman</h1>
        <p class="hero-subtitle">Nine Identities, One Burned Body</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Discovered</span>
            <span class="stat-value">1970</span>
          </div>
          <div class="stat">
            <span class="stat-label">Aliases</span>
            <span class="stat-value text-accent">8+</span>
          </div>
           <div class="stat">
            <span class="stat-label">Status</span>
            <span class="stat-value">Unsolved</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','isdal-woman');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
          </div>
          <a href="/books/epub/isdal-woman.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">On November 29, 1970, a man and his two young daughters found a burned body on a rocky hillside in Bergen, Norway. She had no face, no name, and no past. Her fingerprints had been sanded off. Every label had been cut from her clothing. In her suitcases: <strong>wigs, coded notes, and currency from five countries.</strong></p>
        <p>She had checked into hotels across Norway under at least <strong>eight fake identities</strong>. Her movements matched top-secret missile trials. Over fifty years later, nobody knows who she was.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Body</span>
            <h3 class="card-value">0</h3>
            <p class="card-desc">Identifying marks left on her body or belongings. Every clothing label cut away. Fingerprints sanded off. Prescription cream name scratched out. A woman engineered to be nobody.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">False Identities</span>
            <h3 class="card-value text-accent">8+</h3>
            <p class="card-desc">Aliases used across Norwegian and European hotels. All claimed Belgian nationality.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">Sleeping Pills</span>
            <h3 class="card-value">50–70</h3>
            <p class="card-desc">Fenemal tablets ingested. A potentially lethal dose — but she was alive when the fire started.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Years Unsolved</span>
            <h3 class="card-value">55+</h3>
            <p class="card-desc">Despite DNA analysis, isotope testing, and a global podcast, her identity remains unknown.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.bergenStation} alt="Bergen Railway Station, Norway" />
            <div class="visual-overlay">
              <span class="overlay-label">THE SUITCASES</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Bergen Railway Station</h3>
            <p>Three days after the body was found, two unclaimed suitcases were discovered at Bergen's railway station. Inside: multiple wigs, clothing with all labels removed, currency from five countries, non-prescription glasses with her fingerprint, eczema cream with the brand scratched off, and a notepad containing coded entries.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual uv-visual">
            <div class="uv-glow-card">
              <div class="uv-label">DECODED</div>
              <div class="uv-result">O22 O28P<br/><span class="uv-sub">O29PS O30BN5</span></div>
              <div class="uv-bars">
                <div class="uv-bar" style="height:85%"></div>
                <div class="uv-bar" style="height:62%"></div>
                <div class="uv-bar" style="height:94%"></div>
                <div class="uv-bar" style="height:78%"></div>
                <div class="uv-bar" style="height:100%"></div>
              </div>
              <div class="uv-footer">OSLO → PARIS → STAVANGER → BERGEN</div>
            </div>
            <div class="visual-overlay">
               <span class="overlay-label">THE CODED NOTES</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Travel Code</h3>
            <p>The notepad contained what appeared to be encrypted text. Kripos cracked it: letters were cities (O=Oslo, P=Paris, S=Stavanger, B=Bergen), numbers were dates, and trailing digits indicated nights stayed. She had devised her own cipher to record her movements — the kind of tradecraft associated with intelligence operatives, not tourists.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.ulriken} alt="Ulriken mountain overlooking Bergen, Norway" />
            <div class="visual-overlay">
               <span class="overlay-label">THE PENGUIN CONNECTION</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Missile Trials</h3>
            <p>A classified military document from December 1970 noted that the Isdal Woman's movements — reconstructed from hotel forms and coded notes — corresponded with the locations and dates of top-secret Penguin anti-ship missile trials. Defence personnel stayed at the same Stavanger hotels. A fisherman reported she had been watching military movements in the harbour.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">Final Weeks</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">OCT 22</span>
          <div class="timeline-content">
            <h4>Oslo to Paris</h4>
            <p>The coded diary records her movements from Oslo to Paris over the course of a week. She carries multiple passports and wigs. At every stop, a different name.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">OCT 29</span>
          <div class="timeline-content">
            <h4>Stavanger</h4>
            <p>She checks into the Hotel St. Svithun as "Fenella Lorch." A waitress remembers her sitting near — but not with — two German naval officers. A shoe shop owner sells her rubber boots.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">NOV 23</span>
          <div class="timeline-content">
            <h4>Last Seen Alive</h4>
            <p>She checks out of Hotel Hordaheimen in Bergen, room 407. Six days of silence follow. No hotel registration. No sighting. Nothing.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">NOV 29</span>
          <div class="timeline-content highlight">
            <h4>Found in Isdalen</h4>
            <p>A father and his daughters discover a burned body in the Ice Valley. Arms in the boxer's stance. Objects arranged in what investigators call "some kind of ceremony." Every label removed. Identity erased.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">FEB 1971</span>
          <div class="timeline-content">
            <h4>Buried Nameless</h4>
            <p>After police rule suicide, she is buried in a zinc coffin at Møllendal cemetery. Only officers attend. Catholic rites are chosen based on the saint names in her aliases. The zinc preserves her for a future that doesn't arrive for 46 years.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Elements</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.bryggen} alt="Bryggen wharf, Bergen, Norway" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The City</span>
            <h3>Bergen, Norway</h3>
            <p>Norway's second-largest city and a major NATO port during the Cold War. The Isdal Woman stayed at multiple Bergen hotels under false names. Her final days were spent somewhere in this city of rain, fjords, and military secrets.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.hero} alt="Isdalen Valley, Bergen" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Scene</span>
            <h3>Isdalen — Death Valley</h3>
            <p>A treacherous scree slope on Ulriken's north face, known locally as "Death Valley" since medieval times. On November 29, 1970, it claimed one more name — or rather, one more absence of a name.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.valleyHistoric} alt="Historic photograph of the Isdalen area near Bergen" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Reopening</span>
            <h3>Modern Forensics</h3>
            <p>In 2016, NRK journalists persuaded police to reopen the case. Isotope analysis of the preserved jawbone placed her birth near Nuremberg, Germany, around 1930. DNA revealed Southeast European or Southwest Asian maternal ancestry. A podcast reached millions. Her name remains unknown.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.valleyHistoric} alt="Isdalen valley near Bergen, Norway" />
          <div class="image-caption">Isdalen. The name she was given, because it was the only name she had.</div>
        </div>
        <div class="conclusion-text">
          <h2>Still Nameless</h2>
          <p>Over fifty years have passed since a man and his daughters smelled smoke on a hillside in Bergen. The Isdal Woman lies in a zinc coffin in Møllendal cemetery, still unidentified, still unclaimed.</p>
          <p>She was <em>someone.</em> She had a name. Somewhere, that name is still waiting to be spoken.</p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the burned body, the coded notes, the nine identities, and Scandinavia's most baffling cold case.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','isdal-woman');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
            </div>
            <a href="/books/epub/isdal-woman.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_isdal-woman', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_isdal-woman') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

