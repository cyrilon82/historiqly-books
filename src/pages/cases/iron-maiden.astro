---
import Layout from '../../layouts/Layout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-iron-maiden.jpg',
  device1894: '/cases/images/iron-maiden-nuremberg-1894.jpg',
  interior: '/cases/images/iron-maiden-interior.jpg',
  catalogue: '/cases/images/iron-maiden-exhibition-catalogue.jpg',
  schandmantel: '/cases/images/schandmantel.jpg',
  siebenkees: '/cases/images/suspect-siebenkees.png',
  conclusion: '/cases/images/iron-maiden-interior.jpg',
};
---

<SidebarLayout
  title="The Iron Maiden — The Torture Device That Never Was"
  description="The spiked iron cabinet called the Iron Maiden drew millions to Nuremberg's Royal Castle and the Chicago World's Fair. It was never used to torture anyone. The first written account appeared in 1793. The device was assembled around 1800. The Middle Ages had nothing to do with it. $2.99 EPUB."
  currentVolume={2}
  image="/books/covers/iron-maiden.jpg"
  ogType="book"
  keywords="Iron Maiden torture device myth, medieval torture debunked, Nuremberg iron maiden, historical myths, medieval history, torture museum fraud, ebook non-fiction"
  bookSeo={{ bookTitle: "The Iron Maiden", subtitle: "The Torture Device That Never Was", price: "2.99", author: "HistorIQly Thrillers", genre: "Non-Fiction, History, Myths", format: "EBook", keywords: "Iron Maiden, medieval torture myth, Nuremberg, historical myths debunked" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Myths", url: "/vol/myths" }, { name: "The Iron Maiden", url: "/cases/iron-maiden" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 02-1793</span>
          <span class="meta-badge alert">STATUS: MYTH DEBUNKED</span>
        </div>

        <h1 class="hero-title">The Iron Maiden</h1>
        <p class="hero-subtitle">The Torture Device That Never Was</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">First Account</span>
            <span class="stat-value">1793</span>
          </div>
          <div class="stat">
            <span class="stat-label">Device Assembled</span>
            <span class="stat-value text-accent">c.1800</span>
          </div>
          <div class="stat">
            <span class="stat-label">Medieval Records</span>
            <span class="stat-value">Zero</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','iron-maiden');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy the Book</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
          </div>
          <a href="/books/epub/iron-maiden.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

      <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section">
      <div class="intro-text">
        <p class="drop-cap">The spiked iron cabinet known as the Iron Maiden terrified visitors to Nuremberg's Royal Castle for over a century. It was exhibited before <strong>27 million people</strong> at the Chicago World's Fair. It toured vaudeville theaters in London and New York. It appeared in guidebooks across Europe as proof of medieval barbarism.</p>
        <p>Not a single medieval document records its use. The first written account appeared in <strong>1793</strong>. The device was assembled around <strong>1800</strong>. The interior spikes may have been Napoleonic-era French bayonets. The Middle Ages had nothing to do with it.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Myth</span>
            <h3 class="card-value">1793</h3>
            <p class="card-desc">Johann Philipp Siebenkees publishes an account of an execution by iron maiden in 1515 Nuremberg. His source document has never been found. German archivists have searched for it for two centuries. It does not exist.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Medieval Records Found</span>
            <h3 class="card-value text-accent">0</h3>
            <p class="card-desc">Not a court document, executioner's log, or contemporary witness account in the entire surviving legal literature of medieval Europe.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">Device First Documented</span>
            <h3 class="card-value">c.1800</h3>
            <p class="card-desc">285 years after the supposed 1515 execution. The Nuremberg Iron Maiden was assembled from disparate components — interior spikes possibly from Napoleonic-era French bayonets.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Albums Sold</span>
            <h3 class="card-value">&gt;100M</h3>
            <p class="card-desc">Iron Maiden the band, formed in East London in 1975, has sold over 100 million albums — ensuring the myth outlives every scholarly correction.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.device1894} alt="The Nuremberg Iron Maiden photographed in 1894 by Schmidt and Michel" />
            <div class="visual-overlay">
              <span class="overlay-label">NUREMBERG IRON MAIDEN — PHOTOGRAPHED 1894</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The 1894 Photograph</h3>
            <p>On August 11, 1894, photographers Ferdinand Schmidt and A. Michel made albumen silver prints of the Nuremberg Iron Maiden — images now held at the J. Paul Getty Museum. The device looks exactly as a medieval torture instrument should look. That is the problem: its appearance was designed to match a story written in 1793. The physical object was assembled from disparate metalwork around 1800, and some of its interior spikes have been identified as Napoleonic-era French bayonets.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.schandmantel} alt="The Schandmantel — medieval cloak of shame punishment device" />
            <div class="visual-overlay">
              <span class="overlay-label">SCHANDMANTEL — THE REAL MEDIEVAL DEVICE</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Cloak of Shame</h3>
            <p>The <em>Schandmantel</em> — German for "cloak of shame" — was a genuine medieval German punishment device: a barrel-shaped frame of wood and tin worn by petty offenders during public humiliation. No spikes. No deaths. It is documented in German municipal records from the thirteenth century onward. Professor Wolfgang Schild identified it as the likely ancestor of the iron maiden: its human-shaped form was transformed by nineteenth-century imagination from a humiliation device into an execution machine.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.catalogue} alt="Illustrated catalogue of the Nuremberg torture collection, 1890 Earl of Shrewsbury exhibition" />
            <div class="visual-overlay">
              <span class="overlay-label">NUREMBERG TORTURE COLLECTION CATALOGUE — 1890</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Commercial Tour</h3>
            <p>In April 1890, the entire Nuremberg torture collection — over 1,300 objects including the iron maiden — was purchased by Julius Ichenhauser on behalf of the Earl of Shrewsbury and Talbot, Premier Earl of England. The illustrated catalogue Ichenhauser compiled describes the iron maiden as genuine medieval. The collection toured Britain, then appeared at the 1893 Chicago World's Fair, then at Koster and Bial's vaudeville theater in New York. Horror had become commerce.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TIMELINE -->
    <section class="timeline-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">The Making of a Myth</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">1252</span>
          <div class="timeline-content">
            <h4>Real Medieval Torture</h4>
            <p>Pope Innocent IV's bull <em>Ad extirpanda</em> authorizes torture in Inquisition proceedings. The method prescribed: strappado — a rope, a pulley, and body weight. Simple, brutal, and extensively documented. The iron maiden appears nowhere.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1793</span>
          <div class="timeline-content">
            <h4>The Story Is Written</h4>
            <p>Johann Philipp Siebenkees publishes an account of a coin forger executed in a Nuremberg iron maiden on August 14, 1515. In the same year, Jean-François de la Harpe publishes an anti-Inquisition iron maiden account in France. Neither has access to the device itself. Neither can produce their source documents.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">c.1800</span>
          <div class="timeline-content">
            <h4>The Device Is Assembled</h4>
            <p>The Nuremberg Iron Maiden appears in the Royal Castle — assembled from disparate metalwork, the story already in place. First the story, then the object. Professor Wolfgang Schild's analysis identifies some interior spikes as Napoleonic-era French bayonets.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1893</span>
          <div class="timeline-content highlight">
            <h4>27 Million Visitors</h4>
            <p>The Nuremberg torture collection, including the iron maiden, is displayed at the World's Columbian Exposition in Chicago — the largest exhibition in American history. After Chicago, the collection moves to Koster and Bial's Music Hall, a vaudeville theater in New York.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1944</span>
          <div class="timeline-content">
            <h4>The Original Destroyed</h4>
            <p>RAF bombing raids on Nuremberg destroy the original Iron Maiden. The device that had been on display for roughly 140 years is gone. What survives: copies. The Rothenburg museum's iron maiden, made in the 1960s, is a copy of the nineteenth-century fake.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">2000</span>
          <div class="timeline-content">
            <h4>The Verdict</h4>
            <p>Professor Wolfgang Schild publishes <em>Die eiserne Jungfrau: Dichtung und Wahrheit</em> — The Iron Maiden: Fiction and Truth. The scholarly case is complete: no medieval iron maiden has ever been verified. The myth, however, shows no sign of dying.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- KEY FIGURES -->
    <section class="figures-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.siebenkees} alt="Johann Philipp Siebenkees, German philosopher and antiquarian, 1759–1796" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Storyteller</span>
            <h3>Johann Philipp Siebenkees</h3>
            <p>Born in Nuremberg in 1759, dead in Altdorf in 1796 at thirty-six. A philosopher, philologist, and antiquarian, Siebenkees published the first significant iron maiden account in 1793, claiming to draw on an older document that has never been located. His account — specific, measured, anatomically detailed — read convincingly as history. It was convincing enough to shape popular belief for two centuries. His source document, if it ever existed, has not survived. Historians believe it never did.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.conclusion} alt="The Nuremberg Iron Maiden — the device assembled around 1800 and destroyed in 1944" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Object</span>
            <h3>The Nuremberg Iron Maiden</h3>
            <p>Assembled from disparate metalwork around 1800, displayed at the Royal Castle of Nuremberg for 140 years, exhibited at the Chicago World's Fair and a New York vaudeville theater, photographed by Ferdinand Schmidt and A. Michel in 1894, and destroyed by RAF bombing in 1944. The most famous torture device in Western history. Possibly never used to torture anyone. Certainly not medieval. The original is gone; what remains are copies of a fake, displayed in museums across Europe.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.device1894} alt="The Nuremberg Iron Maiden — the 1894 Schmidt and Michel photograph" />
          <div class="image-caption">The 1894 Schmidt &amp; Michel photograph. The device was assembled around 1800. It was destroyed in 1944.</div>
        </div>
        <div class="conclusion-text">
          <h2>The Myth That Won</h2>
          <p>The scholarly verdict is clear: no medieval iron maiden has ever been verified. The Nuremberg original was assembled from pieces around 1800. The first written account appeared nearly three centuries after the supposed event. Not a single medieval court record mentions the device.</p>
          <p>The iron maiden exists in the popular imagination regardless. It exists in the name of a band that has sold a hundred million albums. It exists in torture museums from Amsterdam to Hollywood. It exists because it is too useful to abandon — too perfect an emblem of hypocritical cruelty to be dislodged by mere evidence.</p>
          <p><em>The Middle Ages had the Schandmantel: a wooden barrel for humiliating petty criminals in a public square, no spikes, no deaths. The Romantic era had the iron maiden. Of the two, it is the imaginary one that history remembers.</em></p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the philosopher who wrote the account, the showmen who built the device, and the myth that outlived them all.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','iron-maiden');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy the Book</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
            </div>
            <a href="/books/epub/iron-maiden.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_iron-maiden', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_iron-maiden') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }
</script>

<style>
  /* SWISS TECHNICAL BENTO THEME */
  :root {
    --bg-dark: #0a0a0a;
    --bg-card: #111111;
    --bg-card-hover: #161616;
    --border-color: rgba(255, 255, 255, 0.08);
    --text-primary: #FAFAFA;
    --text-secondary: #A1A1AA;
    --accent: #F59E0B;
    --accent-dim: rgba(245, 158, 11, 0.1);

    --font-serif: 'Cormorant Garamond', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;
  }

  .case-file {
    background-color: var(--bg-dark);
    color: var(--text-primary);
    font-family: var(--font-sans);
    overflow-x: hidden;
  }

  /* UTILS */
  .text-accent { color: var(--accent); }

  /* HERO */
  .hero {
    position: relative;
    height: 90vh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-bottom: 1px solid var(--border-color);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.3) grayscale(0.8) contrast(1.3);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 0%, var(--bg-dark) 90%);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 900px;
    padding: 0 1.5rem;
  }

  .case-meta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .meta-badge {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border-color);
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(4px);
    color: var(--text-secondary);
  }

  .meta-badge.alert {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  .meta-badge.price {
    border-color: var(--accent);
    background: var(--accent-dim);
    color: var(--accent);
    font-weight: 800;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 8vw, 6rem);
    line-height: 0.9;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    text-shadow: 0 10px 30px rgba(0,0,0,0.7);
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    color: var(--text-secondary);
    font-weight: 300;
    margin-bottom: 4rem;
    letter-spacing: 0.02em;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
  }

  .stat-value {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    z-index: 10;
  }

  .scroll-indicator span {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--text-secondary);
    opacity: 0.7;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--text-secondary) 0%, transparent 100%);
  }

  /* HERO ACTIONS */
  .hero-actions {
    margin-top: 3rem;
  }

  /* PRIMARY BUY BUTTON */
  .btn-buy-primary {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
    color: #000;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: all 0.25s;
    box-shadow: 0 4px 24px rgba(245, 158, 11, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .btn-buy-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(245, 158, 11, 0.45), 0 4px 12px rgba(0, 0, 0, 0.3);
    background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%);
  }

  .btn-buy-text {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .btn-buy-price {
    font-size: 1.125rem;
    font-weight: 800;
    padding: 0.25rem 0.75rem;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 4px;
  }

  /* PRIMARY DOWNLOAD BUTTON */
  .btn-download-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, #5DB585 0%, #4a9e70 100%);
    color: #000;
    text-decoration: none;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-sans);
    transition: all 0.25s;
    box-shadow: 0 4px 24px rgba(93, 181, 133, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .btn-download-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(93, 181, 133, 0.45), 0 4px 12px rgba(0, 0, 0, 0.3);
    background: linear-gradient(135deg, #6FC494 0%, #5DB585 100%);
  }

  .cta-buy, .cta-download {
    width: 100%;
    justify-content: center;
  }

  /* INTRO */
  .intro-section {
    padding: 8rem 1.5rem;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .intro-text p {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .intro-text strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* BENTO GRID */
  .bento-section {
    padding: 2rem 1.5rem 8rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
