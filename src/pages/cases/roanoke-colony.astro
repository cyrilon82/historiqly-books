---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-roanoke-colony.jpg',
  map: '/cases/images/roanoke-white-map.jpg',
  croatoan: '/cases/images/roanoke-croatoan-carving.jpg',
  baptism: '/cases/images/roanoke-virginia-dare-baptism.jpg',
  fort: '/cases/images/roanoke-fort-raleigh.jpg',
  raleigh: '/cases/images/figure-walter-raleigh.jpg',
  secoton: '/cases/images/roanoke-secoton-village.jpg',
  debry: '/cases/images/roanoke-debry-map-detail.jpg',
};
---

<SidebarLayout
  title="The Lost Colony of Roanoke — America's Oldest Mystery"
  description="The Lost Colony of Roanoke: 117 colonists vanished from the New World, leaving only the word CROATOAN carved into a post. The true story of America's first English settlement. $2.99 EPUB."
  currentVolume={4}
  image="/books/covers/roanoke-colony.jpg"
  ogType="book"
  keywords="Lost Colony Roanoke book, CROATOAN mystery, Virginia Dare, John White, Roanoke Island, English colonization, disappearance"
  bookSeo={{ bookTitle: "The Lost Colony of Roanoke", subtitle: "The Disappearance That Haunts America", price: "2.99", author: "HistorIQly Mysteries", genre: "Non-Fiction, History, Disappearances", format: "EBook", keywords: "Roanoke Colony, CROATOAN, Virginia Dare, John White, disappearance" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Disappearances", url: "/vol/disappearances" }, { name: "The Lost Colony of Roanoke", url: "/cases/roanoke-colony" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 04-1590</span>
          <span class="meta-badge alert">STATUS: FATE UNKNOWN</span>
        </div>

        <h1 class="hero-title">The Lost Colony of Roanoke</h1>
        <p class="hero-subtitle">The Disappearance That Haunts America</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Colonists</span>
            <span class="stat-value">117</span>
          </div>
          <div class="stat">
            <span class="stat-label">Vanished</span>
            <span class="stat-value">1590</span>
          </div>
           <div class="stat">
            <span class="stat-label">Clue</span>
            <span class="stat-value text-accent">CROATOAN</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','roanoke-colony');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
          </div>
          <a href="/books/roanoke-colony.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">In 1587, Governor John White kissed his nine-day-old granddaughter goodbye and sailed for England to fetch supplies. When he returned three years later, 117 colonists had vanished. The houses were gone. The fort was overgrown. Only one clue remained: the word <strong>CROATOAN</strong>, carved into a gatepost in "fayre Romane letters." No Maltese cross. No distress signal. No bodies. No graves.</p>
        <p>It took <strong>over 400 years</strong> of archaeology, DNA analysis, and detective work to begin assembling the truth — and the answer is stranger than anyone imagined.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Colony</span>
            <h3 class="card-value">1587</h3>
            <p class="card-desc">117 English men, women, and children — the first families to attempt permanent settlement in the New World. They were stranded on Roanoke Island when their pilot refused to continue to the Chesapeake.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">The First</span>
            <h3 class="card-value text-accent">Virginia</h3>
            <p class="card-desc">Virginia Dare, born August 18, 1587 — the first English child born in North America. Her fate remains unknown.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">The Wait</span>
            <h3 class="card-value">3 Years</h3>
            <p class="card-desc">The Spanish Armada crisis trapped Governor White in England. By the time he returned, everyone was gone.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">The Clue</span>
            <h3 class="card-value">CROATOAN</h3>
            <p class="card-desc">One word carved into a post. No distress signal. The colonists' own message — pointing to Manteo's island, fifty miles south.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.croatoan} alt="Engraving depicting John White finding the word CROATOAN" />
            <div class="visual-overlay">
              <span class="overlay-label">THE CROATOAN CARVING</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>CROATOAN</h3>
            <p>When Governor White returned in 1590, he found the colony deserted. On a gatepost, the word "CROATOAN" was carved in clear Roman letters — pointing to Manteo's island. No Maltese cross meant no distress. The colonists had left voluntarily. But a storm prevented White from reaching Croatoan Island, and he never saw his family again.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.map} alt="John White's map of the Virginia coast, La Virginea Pars" />
            <div class="visual-overlay">
               <span class="overlay-label">THE HIDDEN MAP SYMBOL</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Site X</h3>
            <p>In 2012, researchers at the British Museum discovered a hidden symbol on John White's map — a fort marker concealed beneath a paper patch, pointing to a location fifty miles inland. Excavations at "Site X" in Bertie County have since uncovered Elizabethan-era English ceramics, suggesting some colonists moved inland.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.fort} alt="Reconstructed earthworks at Fort Raleigh National Historic Site" />
            <div class="visual-overlay">
               <span class="overlay-label">FORT RALEIGH NATIONAL HISTORIC SITE</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Archaeology</h3>
            <p>Excavations on Hatteras Island (ancient Croatoan) have uncovered 16th-century English artifacts — a gold signet ring, sword parts, writing slates — mixed with Native American pottery. In 2025, hammerscale deposits confirmed European metalworking at the site. The colonists didn't vanish. They adapted.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">Lost and Found</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">1585</span>
          <div class="timeline-content">
            <h4>The First Colony</h4>
            <p>Ralph Lane establishes a military garrison of 107 men on Roanoke Island. Relations with the Algonquian peoples deteriorate. Lane kills the chief Pemisapan. The colony is abandoned within a year.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">AUG 1587</span>
          <div class="timeline-content highlight">
            <h4>The Lost Colony</h4>
            <p>117 colonists — men, women, and children — settle on Roanoke. Virginia Dare is born. Governor White sails for supplies, promising to return quickly.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1588</span>
          <div class="timeline-content">
            <h4>The Armada</h4>
            <p>The Spanish Armada crisis locks down every English port. White's resupply attempt fails. He is wounded. Three years pass before he can return.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">AUG 1590</span>
          <div class="timeline-content">
            <h4>CROATOAN</h4>
            <p>White finds the colony deserted. The word CROATOAN is carved on a post. A storm prevents him from reaching Croatoan Island. He returns to England, never learning his family's fate.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">2012–2025</span>
          <div class="timeline-content">
            <h4>The Evidence Emerges</h4>
            <p>A hidden symbol on White's map. English ceramics fifty miles inland. A gold ring and hammerscale on Hatteras Island. The colonists didn't vanish — they dispersed and adapted.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.raleigh} alt="Portrait of Sir Walter Raleigh by William Segar, 1598" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Patron</span>
            <h3>Sir Walter Raleigh</h3>
            <p>Courtier, poet, privateer, and colonial promoter. Raleigh financed the Roanoke expeditions but never set foot in America. His charter from Elizabeth I created "Virginia" and launched England's colonial ambitions. Imprisoned in the Tower by James I, he was executed in 1618.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.secoton} alt="John White's watercolour of the village of Secoton" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Governor</span>
            <h3>John White</h3>
            <p>Artist, mapmaker, and reluctant governor. White's watercolours of Algonquian life are among the most important visual documents in American history. He left his daughter, son-in-law, and nine-day-old granddaughter on Roanoke Island in 1587 — and never saw them again.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.baptism} alt="The Baptism of Virginia Dare, 1880 engraving" />
          <div class="image-caption">The Baptism of Virginia Dare — the first English child born in America, 1587.</div>
        </div>
        <div class="conclusion-text">
          <h2>Still Searching</h2>
          <p>The Lost Colony did not vanish into thin air. The archaeology tells a story of dispersal, adaptation, and survival — some colonists joining Manteo's Croatoans on Hatteras Island, others moving inland to the Albemarle Sound. Their descendants may walk the streets of North Carolina today.</p>
          <p>But the definitive answer has never been found. And in that uncertainty lies the story's enduring power — <em>a colony that refuses to be found.</em></p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the colonists, the CROATOAN carving, the Armada, and the four-century search for answers.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','roanoke-colony');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
            </div>
            <a href="/books/roanoke-colony.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_roanoke-colony', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_roanoke-colony') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

