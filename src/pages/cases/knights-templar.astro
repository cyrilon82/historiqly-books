---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-templars-burning-philip.jpg',
  molay: '/cases/images/suspect-jacques-de-molay.jpg',
  execution: '/cases/images/templar-molay-execution.jpg',
  seal: '/cases/images/evidence-templar-seal.png',
  philip: '/cases/images/suspect-philip-iv.jpg',
  clement: '/cases/images/suspect-clement-v.jpg',
  battle: '/cases/images/templar-crusade-battle.jpg',
  fortress: '/cases/images/templar-chastel-blanc.jpg',
  stake: '/cases/images/templar-stake-manuscript.jpg',
  church: '/cases/images/templar-temple-church-london.jpg',
};
---

<SidebarLayout
  title="Knights Templar Book — Warrior Monks History"
  description="The Knights Templar: From nine poor knights to the most powerful military order in Christendom. The battles, the banking empire, the heresy trials, and the curse. $2.99 EPUB."
  currentVolume={6}
  image="/books/covers/knights-templar.jpg"
  ogType="book"
  keywords="Knights Templar book, Templar history ebook, Crusades, Jacques de Molay, secret society, warrior monks, Friday the 13th, medieval banking"
  bookSeo={{ bookTitle: "The Knights Templar", subtitle: "The Warrior Monks Who Shook the World", price: "2.99", author: "HistorIQly Mysteries", genre: "Non-Fiction, History, Secret Societies", format: "EBook", keywords: "Knights Templar, Crusades, Jacques de Molay, secret society" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Secret Societies", url: "/vol/secret-societies" }, { name: "The Knights Templar", url: "/cases/knights-templar" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 06-1119</span>
          <span class="meta-badge alert">STATUS: DISSOLVED BY PAPAL DECREE</span>
        </div>

        <h1 class="hero-title">The Knights Templar</h1>
        <p class="hero-subtitle">The Warrior Monks Who Shook the World</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Founded</span>
            <span class="stat-value">1119</span>
          </div>
          <div class="stat">
            <span class="stat-label">Duration</span>
            <span class="stat-value">193 yrs</span>
          </div>
           <div class="stat">
            <span class="stat-label">Grand Masters</span>
            <span class="stat-value text-accent">23</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','knights-templar');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
          </div>
          <a href="/books/knights-templar.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">In the year 1119, nine penniless knights knelt before the King of Jerusalem and swore to protect Christian pilgrims on the most dangerous roads in the world. Two centuries later, they commanded a banking empire, an international army, and the fear of kings and popes alike. Then, at dawn on Friday the thirteenth, it all came crashing down.</p>
        <p>This is the true story of <strong>the warrior monks who shook the world</strong> — from the Temple Mount to the stake.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Founding</span>
            <h3 class="card-value">9 Knights</h3>
            <p class="card-desc">Hugues de Payens and eight companions established the order on the Temple Mount in Jerusalem. They were so poor they shared horses — two men to a mount. Within decades, Bernard of Clairvaux's endorsement transformed them into the most powerful military order in Christendom.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Peak Strength</span>
            <h3 class="card-value text-accent">20,000</h3>
            <p class="card-desc">Members at peak — but only ~2,000 were actual knights in white mantles.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">The Arrests</span>
            <h3 class="card-value">Fri 13th</h3>
            <p class="card-desc">October 13, 1307 — 600+ Templars arrested simultaneously across France.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">The Curse</span>
            <h3 class="card-value">33 Days</h3>
            <p class="card-desc">Between Molay's execution and Pope Clement V's death. Philip IV died 8 months later.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.seal} alt="The seal of the Knights Templar — two knights on one horse" />
            <div class="visual-overlay">
              <span class="overlay-label">TEMPLAR SEAL</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Two Knights, One Horse</h3>
            <p>The official Templar seal depicted two armoured knights riding a single horse — a symbol of the order's founding poverty. The Latin inscription reads <em>Sigillum Militum Xpisti</em>: Seal of the Soldiers of Christ. Whether the image was literal or allegorical, it became the most recognizable emblem of the medieval military orders.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.church} alt="Interior of the Temple Church, London" />
            <div class="visual-overlay">
               <span class="overlay-label">TEMPLE CHURCH, LONDON</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Round Church</h3>
            <p>Consecrated in 1185, the Temple Church in London was the English headquarters of the Knights Templar. Its circular nave echoes the Church of the Holy Sepulchre in Jerusalem. Stone effigies of medieval knights still lie on its floor, and its Purbeck marble columns survived German incendiary bombs in 1941.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.stake} alt="Medieval manuscript showing Templars burned at the stake" />
            <div class="visual-overlay">
               <span class="overlay-label">THE BURNING, 1314</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Final Confession</h3>
            <p>On March 18, 1314, Jacques de Molay was brought to Notre-Dame for sentencing. Instead of accepting life imprisonment, he retracted his confession and declared the order innocent. Philip IV ordered him burned at the stake that same evening. The Chinon Parchment, discovered in 2001, proved the Pope had secretly absolved the Templars years earlier.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">From Temple Mount to the Stake</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">1119</span>
          <div class="timeline-content">
            <h4>Nine Poor Knights</h4>
            <p>Hugues de Payens proposes a monastic military order to King Baldwin II. Nine knights are granted headquarters on the Temple Mount — the former Al-Aqsa Mosque — giving the order its name.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1177</span>
          <div class="timeline-content">
            <h4>Montgisard</h4>
            <p>Eighty Templar knights lead a devastating charge that routs Saladin's army of 26,000. The sultan barely escapes on a camel. It is one of the most remarkable victories of the Crusading era.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1187</span>
          <div class="timeline-content highlight">
            <h4>The Disaster at Hattin</h4>
            <p>The Crusader army is annihilated. Saladin orders the execution of all captured Templars and Hospitallers. Jerusalem falls. The order's headquarters on the Temple Mount is lost forever.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1307</span>
          <div class="timeline-content highlight">
            <h4>Friday the Thirteenth</h4>
            <p>At dawn on October 13, Philip IV's soldiers simultaneously arrest every Templar in France. Jacques de Molay, the last Grand Master, is seized at the Paris Temple. Confessions are extracted under torture.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1314</span>
          <div class="timeline-content">
            <h4>The Curse</h4>
            <p>Molay burns at the stake on the Île aux Juifs, cursing king and pope. Both are dead within the year. The Capetian dynasty collapses within fourteen years, triggering the Hundred Years' War.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.philip} alt="King Philip IV of France" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Destroyer</span>
            <h3>Philip IV of France</h3>
            <p>Called "the Fair" for his striking looks, not his character. Deeply in debt to the Templars, he engineered their destruction through his agent Guillaume de Nogaret. He died of a stroke eight months after Molay's execution — fulfilling, some said, the Grand Master's curse.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.molay} alt="Jacques de Molay, last Grand Master of the Knights Templar" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Last Grand Master</span>
            <h3>Jacques de Molay</h3>
            <p>The 23rd and final Grand Master. He confessed under torture, then dramatically retracted before a crowd at Notre-Dame, declaring the order innocent. Burned at the stake on March 18, 1314, he cursed his persecutors with his dying breath.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.battle} alt="Crusaders in battle — Delacroix" />
          <div class="image-caption">The Crusaders in battle. After Delacroix.</div>
        </div>
        <div class="conclusion-text">
          <h2>The Verdict Arrives</h2>
          <p>They guarded pilgrims. They fought battles that should have been unwinnable. They invented banking. They built fortresses that still stand. And they were destroyed — not by their enemies on the battlefield, but by a king who owed them money and a pope who lacked the courage to stop him.</p>
          <p>In 2001, a piece of parchment was found in the Vatican archives proving what Molay had said from the flames: <em>the Templars were innocent.</em></p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the warrior monks — from the Temple Mount to the stake, from the Crusades to the curse.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','knights-templar');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
            </div>
            <a href="/books/knights-templar.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_knights-templar', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_knights-templar') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>
