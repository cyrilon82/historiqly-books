---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-bermuda-triangle-cyclops.jpg',
  avenger: '/cases/images/bermuda-triangle-tbm-avenger.jpg',
  tudor: '/cases/images/bermuda-triangle-avro-tudor.jpg',
  berlitz: '/cases/images/bermuda-triangle-charles-berlitz.png',
  gyre: '/cases/images/bermuda-triangle-atlantic-gyre.png',
  article: '/cases/images/bermuda-triangle-1950-article.jpg',
};
---

<SidebarLayout
  title="The Bermuda Triangle — Ships, Planes, and the Sea That Swallows Them"
  description="The Bermuda Triangle: USS Cyclops, Flight 19, Star Tiger — ships and planes vanish without a trace. The true story of the world's most famous maritime mystery. $2.99 EPUB."
  currentVolume={5}
  image="/books/covers/bermuda-triangle.jpg"
  ogType="book"
  keywords="Bermuda Triangle book, Bermuda Triangle ebook, Flight 19, USS Cyclops, Devil's Triangle, maritime mystery, Charles Berlitz, Larry Kusche"
  bookSeo={{ bookTitle: "The Bermuda Triangle", subtitle: "Ships, Planes, and the Sea That Swallows Them", price: "2.99", author: "HistorIQly Mysteries", genre: "Non-Fiction, History, Disappearances, Maritime Mystery", format: "EBook", keywords: "Bermuda Triangle, Flight 19, USS Cyclops, maritime mystery" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Disappearances", url: "/vol/disappearances" }, { name: "The Bermuda Triangle", url: "/cases/bermuda-triangle" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 04-1918</span>
          <span class="meta-badge alert">STATUS: LARGELY EXPLAINED</span>
        </div>

        <h1 class="hero-title">The Bermuda Triangle</h1>
        <p class="hero-subtitle">Ships, Planes, and the Sea That Swallows Them</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Earliest</span>
            <span class="stat-value">1918</span>
          </div>
          <div class="stat">
            <span class="stat-label">Ships & Planes</span>
            <span class="stat-value text-accent">50+</span>
          </div>
          <div class="stat">
            <span class="stat-label">Status</span>
            <span class="stat-value">Debunked</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','bermuda-triangle');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
          </div>
          <a href="/books/bermuda-triangle.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">On December 5, 1945, five Navy torpedo bombers took off from Fort Lauderdale for a routine training exercise. They never came back. A rescue plane sent to find them also vanished. Twenty-seven men, six aircraft, swallowed by the Atlantic without a trace. It was the incident that launched the legend of the <strong>Bermuda Triangle</strong> — a half-million square miles of ocean that has allegedly claimed over fifty ships and twenty aircraft.</p>
        <p>The truth is both less mysterious and more terrifying than the myth. The ocean does not need <strong>supernatural powers</strong> to kill.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Area</span>
            <h3 class="card-value">500K</h3>
            <p class="card-desc">Square miles of Atlantic Ocean between Miami, Bermuda, and Puerto Rico — one of the busiest shipping lanes in the world. Thousands of vessels transit daily.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Worst Loss</span>
            <h3 class="card-value text-accent">306</h3>
            <p class="card-desc">Souls lost when USS Cyclops vanished in March 1918 — the largest non-combat disappearance in U.S. Navy history.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">The Bestseller</span>
            <h3 class="card-value">20M</h3>
            <p class="card-desc">Copies of Charles Berlitz's 1974 book sold worldwide, cementing the legend in popular culture.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Insurance Risk</span>
            <h3 class="card-value">Normal</h3>
            <p class="card-desc">Lloyd's of London finds no elevated risk. Ships pay the same insurance rates through the Triangle as anywhere else.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.avenger} alt="A TBM Avenger torpedo bomber — the type flown by Flight 19" />
            <div class="visual-overlay">
              <span class="overlay-label">TBM AVENGER — FLIGHT 19</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Flight 19</h3>
            <p>Five TBM Avengers carrying 14 men vanished on December 5, 1945, after the flight leader became disoriented and led the formation out over the open Atlantic instead of back to Florida. A rescue PBM Mariner with 13 crew exploded mid-air due to a known fuel vapor defect. The Navy Board of Inquiry amended the cause to "reasons unknown" — fueling decades of myth.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.tudor} alt="An Avro Tudor aircraft — the type lost as Star Tiger and Star Ariel" />
            <div class="visual-overlay">
               <span class="overlay-label">AVRO TUDOR — STAR TIGER & STAR ARIEL</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Tudor Vanishings</h3>
            <p>Two identical BSAA Avro Tudor IV airliners disappeared within twelve months — Star Tiger in January 1948 with 31 aboard, and Star Ariel in January 1949 with 20. The Tudor IV was plagued by unreliable pressurisation and heating systems. Star Tiger was flying at a dangerously low 2,000 feet due to a heater failure. BSAA was dissolved shortly after.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.gyre} alt="Map of the North Atlantic Gyre and Gulf Stream" />
            <div class="visual-overlay">
               <span class="overlay-label">GULF STREAM — EVIDENCE ERASER</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Gulf Stream</h3>
            <p>Flowing at up to 5 knots and carrying 30 million cubic metres per second, the Gulf Stream can disperse wreckage over hundreds of miles within days. This single geographic fact explains why debris is so rarely found — not supernatural forces, but one of the most powerful ocean currents on the planet erasing the evidence.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">The Triangle</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">MAR 1918</span>
          <div class="timeline-content">
            <h4>USS Cyclops Vanishes</h4>
            <p>A 542-foot Navy collier carrying 306 souls and 10,800 tons of manganese ore disappears between Barbados and Baltimore. No distress signal. No wreckage ever found.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">DEC 1945</span>
          <div class="timeline-content highlight">
            <h4>Flight 19 Lost</h4>
            <p>Five torpedo bombers and a rescue plane vanish. 27 men lost. The incident that launches the legend. The Navy's "causes unknown" verdict becomes a gift to myth-makers.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">FEB 1964</span>
          <div class="timeline-content">
            <h4>The Name Is Born</h4>
            <p>Writer Vincent Gaddis coins "The Bermuda Triangle" in Argosy magazine. The catchy three-word phrase gives the mystery a brand — vivid, memorable, and slightly sinister.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1974</span>
          <div class="timeline-content">
            <h4>Berlitz's Bestseller</h4>
            <p>Charles Berlitz publishes The Bermuda Triangle, selling 20 million copies. He invokes Atlantis, UFOs, and time warps — while quietly omitting storms, known causes, and incidents outside the Triangle.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1975</span>
          <div class="timeline-content">
            <h4>The Debunking</h4>
            <p>Librarian and pilot Larry Kusche publishes The Bermuda Triangle Mystery — Solved, demolishing the legend case by case through primary-source research. The myth survives anyway.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.berlitz} alt="Charles Berlitz, author of The Bermuda Triangle" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Myth-Maker</span>
            <h3>Charles Berlitz</h3>
            <p>Grandson of the Berlitz language-school founder and self-described speaker of 32 languages. His 1974 bestseller The Bermuda Triangle sold 20 million copies by selectively omitting storms, known causes, and incidents outside the region. Larry Kusche demonstrated that virtually every claim in the book was inaccurate, embellished, or fabricated.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.article} alt="1950 newspaper article about Atlantic disappearances" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Debunker</span>
            <h3>Larry Kusche</h3>
            <p>A research librarian at Arizona State University and licensed pilot who spent two years tracing every Bermuda Triangle incident back to primary sources. His 1975 book proved the legend was "a manufactured mystery — perpetuated by writers who either purposely or unknowingly made use of misconceptions, faulty reasoning, and sensationalism."</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.hero} alt="USS Cyclops — the ghost ship of the Bermuda Triangle" />
          <div class="image-caption">USS Cyclops (AC-4). 306 men. No wreckage. No explanation.</div>
        </div>
        <div class="conclusion-text">
          <h2>The Ocean Is Enough</h2>
          <p>The Bermuda Triangle's power was never supernatural. It was narrative — a catchy name, selective evidence, and the human inability to accept that the ocean kills for no reason at all. Lloyd's of London, the Coast Guard, and NOAA all agree: the Triangle is no more dangerous than any other stretch of ocean.</p>
          <p><em>The men who died at sea deserve to be remembered honestly. The ocean was enough.</em></p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the Cyclops, Flight 19, the Tudor vanishings, and the writers who manufactured the world's most famous maritime mystery.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','bermuda-triangle');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
            </div>
            <a href="/books/bermuda-triangle.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_bermuda-triangle', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_bermuda-triangle') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

