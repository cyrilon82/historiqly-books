---
import Layout from '../../layouts/Layout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/somerton-man-portrait.jpg',
  beach: '/cases/images/hero-somerton-man-beach.jpg',
  tamam: '/cases/images/evidence-tamam-shud-slip.jpg',
  code: '/cases/images/evidence-somerton-code.jpg',
  suitcase: '/cases/images/evidence-somerton-suitcase.jpg',
  grave: '/cases/images/somerton-man-grave.jpg',
  bust: '/cases/images/somerton-man-bust.jpg',
  rubaiyat: '/cases/images/evidence-somerton-rubaiyat.jpg',
};
---

<SidebarLayout
  title="The Somerton Man — Australia's Greatest Cold Case"
  description="The Somerton Man: An unidentified body on an Australian beach, a torn scrap of Persian poetry, and an unbreakable code. The true story of the Tamám Shud case. $2.99 EPUB."
  currentVolume={3}
  image="/books/covers/somerton-man.jpg"
  ogType="book"
  keywords="Somerton Man book, Tamam Shud case, Australian cold case, unidentified body, Cold War mystery, Carl Webb, Rubaiyat cipher"
  bookSeo={{ bookTitle: "The Somerton Man", subtitle: "The Cold War Mystery on an Australian Beach", price: "2.99", author: "HistorIQly Mysteries", genre: "Non-Fiction, History, Cold Cases", format: "EBook", keywords: "Somerton Man, Tamam Shud, cold case, Australia, mystery" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Cold Cases", url: "/vol/cold-cases" }, { name: "The Somerton Man", url: "/cases/somerton-man" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 03-1948</span>
          <span class="meta-badge alert">STATUS: COLD CASE</span>
        </div>

        <h1 class="hero-title">The Somerton Man</h1>
        <p class="hero-subtitle">The Cold War Mystery on an Australian Beach</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Found Dead</span>
            <span class="stat-value">1948</span>
          </div>
          <div class="stat">
            <span class="stat-label">Identified</span>
            <span class="stat-value">2022</span>
          </div>
           <div class="stat">
            <span class="stat-label">Code</span>
            <span class="stat-value text-accent">Unbroken</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','somerton-man');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
          </div>
          <a href="/books/somerton-man.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">On a warm December morning in 1948, a smartly dressed man was found dead on an Australian beach. He carried no wallet, no name, and no explanation. Every label had been cut from his clothing. A tiny scrap of paper hidden in his pocket bore two words in Persian: <strong>Tamám Shud</strong> — <em>It is finished.</em></p>
        <p>It took <strong>74 years</strong>, a strand of hair trapped in plaster, and the birth of forensic genealogy to finally speak his name.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Mystery</span>
            <h3 class="card-value">1948</h3>
            <p class="card-desc">An unidentified man found dead on Somerton Park beach, Adelaide. No wallet, no ID, no cause of death. Every clothing label methodically removed. The perfect unknown.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">The Slip</span>
            <h3 class="card-value text-accent">2 Words</h3>
            <p class="card-desc">"Tamám Shud" — torn from the final page of the <em>Rubáiyát of Omar Khayyám</em>.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">The Code</span>
            <h3 class="card-value">5 Lines</h3>
            <p class="card-desc">An unbroken cipher found on the back of the book. 75+ years. Still unsolved.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Identified</span>
            <h3 class="card-value">2022</h3>
            <p class="card-desc">DNA from hair in a plaster death mask finally named him: Carl "Charles" Webb of Melbourne.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.tamam} alt="The Tamám Shud slip torn from the Rubáiyát" />
            <div class="visual-overlay">
              <span class="overlay-label">THE TAMÁM SHUD SLIP</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Tamám Shud</h3>
            <p>Hidden in a concealed fob pocket sewn into the dead man's trousers, a tiny rolled scrap of paper bore the final words of the <em>Rubáiyát of Omar Khayyám</em>: "Tamám Shud" — "It is finished." The slip was torn from a rare Whitcomb & Tombs edition, traced to a book found in a stranger's car 400 meters from the body.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.code} alt="The mysterious code found on the Rubáiyát's back cover" />
            <div class="visual-overlay">
               <span class="overlay-label">UNBROKEN CIPHER</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Code</h3>
            <p>Five lines of capital letters discovered under ultraviolet light on the inside back cover of the Rubáiyát. The second line is crossed out. A phone number traced to a woman living 400 meters from the death site was also written there. Military intelligence, naval cryptographers, and decades of researchers have failed to break it.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.suitcase} alt="The Somerton Man's suitcase and its contents" />
            <div class="visual-overlay">
               <span class="overlay-label">ADELAIDE RAILWAY STATION</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Suitcase</h3>
            <p>Found at Adelaide Railway Station six weeks after the death. Inside: clothing with all labels removed, a stenciling brush used on merchant ships, a knife cut into a weapon, and singlets marked "T. Keane" — a name that led nowhere. Orange waxed thread in the suitcase matched thread in the dead man's trouser pocket.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">Tamám Shud</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">NOV 1948</span>
          <div class="timeline-content">
            <h4>The Last Evening</h4>
            <p>Witnesses see a smartly dressed man propped against the seawall at Somerton Park beach. He raises his arm, then lets it fall. They assume he's drunk or sleeping.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">DEC 1948</span>
          <div class="timeline-content highlight">
            <h4>Found Dead</h4>
            <p>The man is discovered cold and lifeless the next morning. No ID, no wallet, all clothing labels removed. Autopsy suspects poisoning, but no poison is detected.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">JUN 1949</span>
          <div class="timeline-content">
            <h4>The Hidden Pocket</h4>
            <p>A concealed fob pocket is discovered in the trousers. Inside: a scrap torn from the Rubáiyát reading "Tamám Shud." A copy of the book is found with a mysterious code and a woman's phone number.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">JUL 1949</span>
          <div class="timeline-content">
            <h4>The Nurse</h4>
            <p>The phone number leads to Jessica Thomson, living 400m from the death site. She denies knowing the man — but years later, her daughter reveals she lied. The man's identity was "known to a level higher than the police."</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">JUL 2022</span>
          <div class="timeline-content">
            <h4>Finally Named</h4>
            <p>After 74 years, DNA from hair trapped in the 1949 plaster death mask identifies the Somerton Man as Carl "Charles" Webb, an electrical engineer from Melbourne who vanished in 1947.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.bust} alt="Plaster bust of the Somerton Man" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Unknown Man</span>
            <h3>Carl Webb</h3>
            <p>Born 1905 in Footscray, Melbourne. Electrical engineer. Married in 1941, deserted his wife in 1947. Found dead on Somerton Beach in 1948 with no identification. Finally named in 2022 through forensic DNA genealogy after 74 years as "the unknown man."</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.rubaiyat} alt="The Rubáiyát of Omar Khayyám — the Tamám Shud page" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Connection</span>
            <h3>Jessica Thomson</h3>
            <p>Former nurse whose phone number was found in the dead man's copy of the Rubáiyát. Lived 400 meters from the death site. Denied knowing him — but her daughter later revealed she lied. Her son Robin shared two of the dead man's rarest genetic traits.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.grave} alt="The Somerton Man's grave at West Terrace Cemetery" />
          <div class="image-caption">West Terrace Cemetery, Adelaide. "Here lies the unknown man."</div>
        </div>
        <div class="conclusion-text">
          <h2>It Is Finished</h2>
          <p>The Somerton Man has a name now — Carl Webb — but the mystery endures. The code on the back of the Rubáiyát has never been broken. The poison has never been identified. Jessica Thomson took her secrets to the grave.</p>
          <p><em>Tamám Shud.</em> It is finished. Or perhaps it isn't.</p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the unknown man, the Persian poetry, the unbreakable code, and the nurse who lied.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','somerton-man');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
            </div>
            <a href="/books/somerton-man.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_somerton-man', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_somerton-man') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

