---
import SidebarLayout from '../../layouts/SidebarLayout.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-roswell-newspaper-1947.jpg',
  rameyMemo: '/cases/images/evidence-ramey-memo.jpg',
  marcelDebris: '/cases/images/evidence-marcel-debris.jpg',
  rameyDebris: '/cases/images/evidence-ramey-debris.jpg',
  mogulBalloon: '/cases/images/evidence-mogul-balloon.png',
  marcel: '/cases/images/suspect-jesse-marcel.jpg',
  moore: '/cases/images/figure-charles-moore.jpg',
};
---

<SidebarLayout
  title="Roswell Book — Roswell, 1947: The Crash That Launched a Conspiracy"
  description="Roswell 1947: The definitive non-fiction investigation into the Roswell UFO incident. Debris, witnesses, Project Mogul, alien bodies, government cover-up. $2.99 EPUB."
  currentVolume={5}
  image="/books/covers/roswell.jpg"
  ogType="book"
  keywords="Roswell UFO book, Roswell incident ebook, flying saucer 1947, Jesse Marcel, Project Mogul, alien bodies, government cover-up, UFO conspiracy, true history non-fiction"
  bookSeo={{ bookTitle: "Roswell, 1947", subtitle: "The Crash That Launched a Conspiracy", price: "2.99", author: "HistorIQly Thrillers", genre: "Non-Fiction, History, Conspiracy", format: "EBook", keywords: "Roswell, UFO, flying saucer, conspiracy, cover-up" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Conspiracies", url: "/vol/conspiracies" }, { name: "Roswell", url: "/cases/roswell" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 04-1947</span>
          <span class="meta-badge alert">STATUS: EXPLAINED</span>
        </div>

        <h1 class="hero-title">Roswell, 1947</h1>
        <p class="hero-subtitle">The Crash That Launched a Conspiracy</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Date</span>
            <span class="stat-value">July 1947</span>
          </div>
          <div class="stat">
            <span class="stat-label">Location</span>
            <span class="stat-value">New Mexico</span>
          </div>
           <div class="stat">
            <span class="stat-label">Status</span>
            <span class="stat-value text-accent">EXPLAINED</span>
          </div>
        </div>

        <div class="hero-actions">
          <button onclick={`localStorage.setItem('historiqly_purchasing','roswell');window.location.href='${stripeUrl}'`} class="btn-buy-primary" id="heroBuyBtn">
            <span class="btn-buy-text">Buy the Book</span>
            <span class="btn-buy-price">$2.99</span>
          </button>
          <a href="/books/roswell.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section">
      <div class="intro-text">
        <p class="drop-cap">In July 1947, the United States Army announced it had recovered a "flying disc" from a ranch near Roswell, New Mexico. Hours later, they said it was a weather balloon. The witnesses said otherwise — and they kept saying it for the rest of their lives.</p>
        <p>One crash. Two official explanations. <strong>Seventy-nine years</strong> of unanswered questions.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Debris</span>
            <h3 class="card-value">¾ mi</h3>
            <p class="card-desc">The debris field stretched three-quarters of a mile across Mac Brazel's ranch — foil that couldn't be creased, struts that couldn't be bent, and symbols in an unknown alphabet.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Silence</span>
            <h3 class="card-value text-accent">30 yrs</h3>
            <p class="card-desc">The Roswell incident vanished from public memory for three decades before a nuclear physicist revived the story in 1978.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">Witnesses</span>
            <h3 class="card-value">300+</h3>
            <p class="card-desc">Individuals who claimed connection to the events — from ranch hands to intelligence officers to morticians.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Explanations</span>
            <h3 class="card-value">3</h3>
            <p class="card-desc">Weather balloon (1947), Project Mogul (1994), crash test dummies (1997). Each new answer raised more questions.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.marcelDebris} alt="Major Jesse Marcel holding debris in General Ramey's office, July 8, 1947" />
            <div class="visual-overlay">
              <span class="overlay-label">FORT WORTH — MARCEL WITH DEBRIS</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Switched Debris</h3>
            <p>Major Marcel was photographed holding wreckage in General Ramey's office — but Marcel insisted this was not what he brought from the ranch. The extraordinary material had been replaced with the remains of a weather balloon before the cameras arrived.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.rameyMemo} alt="General Ramey holding the Ramey memo, Fort Worth, July 1947" />
            <div class="visual-overlay">
               <span class="overlay-label">THE RAMEY MEMO</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Hidden Message</h3>
            <p>In one photograph, General Ramey holds a folded piece of paper. Researchers have spent decades enhancing the image, claiming to read words like "victims of the wreck" and "disc." The full text remains undeciphered — a secret hiding in plain sight.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.mogulBalloon} alt="Diagram of a Project Mogul balloon train, USAF 1995 report" />
            <div class="visual-overlay">
               <span class="overlay-label">PROJECT MOGUL — BALLOON TRAIN</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Official Answer</h3>
            <p>In 1994, the Air Force revealed that the debris was from Project Mogul — a top-secret program using 600-foot balloon trains to detect Soviet nuclear tests. The radar reflectors, made with toy-company tape bearing decorative patterns, explained the "alien symbols." Or did they?</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TIMELINE -->
    <section class="timeline-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">The Crash That Launched a Conspiracy</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">JUN 14</span>
          <div class="timeline-content">
            <h4>The Discovery</h4>
            <p>Rancher Mac Brazel finds a field of strange debris scattered across three-quarters of a mile of his remote ranch in Lincoln County — metallic foil, unbreakable struts, and material covered in unknown symbols.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">JUL 7</span>
          <div class="timeline-content">
            <h4>The Investigation</h4>
            <p>Major Jesse Marcel and Captain Sheridan Cavitt examine the debris field. Marcel is astonished — the material matches nothing in his experience as an intelligence officer. He loads his car with samples and drives back to base.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">JUL 8</span>
          <div class="timeline-content highlight">
            <h4>"Flying Saucer Captured"</h4>
            <p>Colonel Blanchard orders a press release announcing recovery of a "flying disc." The story goes worldwide. Hours later, General Ramey holds a press conference in Fort Worth — it was just a weather balloon.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1978</span>
          <div class="timeline-content">
            <h4>The Resurrection</h4>
            <p>Nuclear physicist Stanton Friedman tracks down Jesse Marcel, now retired in Louisiana. Marcel reveals that the weather balloon story was a cover — the real debris was extraordinary and was switched before the press photographs.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1994</span>
          <div class="timeline-content">
            <h4>Project Mogul</h4>
            <p>The Air Force releases a new explanation: the debris came from a classified balloon program monitoring Soviet nuclear tests. The "alien symbols" were decorative tape from a toy manufacturer.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">2023</span>
          <div class="timeline-content">
            <h4>Congressional Hearings</h4>
            <p>Former intelligence officer David Grusch testifies under oath that the US government has recovered "non-human" craft — reigniting the Roswell debate in the halls of Congress.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- KEY FIGURES -->
    <section class="figures-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.marcel} alt="Major Jesse Marcel, intelligence officer of the 509th Bomb Group" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Witness</span>
            <h3>Jesse Marcel</h3>
            <p>Intelligence officer of the 509th Bomb Group — the only nuclear-armed unit in the world. Marcel examined the debris at the ranch and was adamant it was unlike any known material. He was photographed with substitute wreckage and spent decades insisting the weather balloon story was a lie.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.moore} alt="Charles B. Moore, physicist and Project Mogul engineer" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Skeptic</span>
            <h3>Charles B. Moore</h3>
            <p>Atmospheric physicist who personally launched Project Mogul balloon trains from Alamogordo in 1947. Moore confirmed that the materials used — neoprene, balsa wood, aluminum foil, and decorative tape — matched descriptions of the Roswell debris. He calculated that Mogul Flight No. 4 could have landed on the Foster Ranch.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.rameyDebris} alt="The weather balloon debris displayed in General Ramey's office" />
          <div class="image-caption">The debris in General Ramey's office. Weather balloon — or cover story?</div>
        </div>
        <div class="conclusion-text">
          <h2>The Desert Keeps Its Secrets</h2>
          <p>Three official explanations in five decades. Hundreds of witnesses. A debris field scrubbed clean by the military. And a question that refuses to die: what really crashed on Mac Brazel's ranch in the summer of 1947?</p>
          <p>The wind still blows across the high plains of Lincoln County. The empty sky offers no answers.</p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story — from the debris field to the Pentagon hearings, from a rancher's discovery to the conspiracy that changed America.</p>
            <button onclick={`localStorage.setItem('historiqly_purchasing','roswell');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy" id="ctaBuyBtn">
              <span class="btn-buy-text">Buy the Book</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
            <a href="/books/roswell.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_roswell', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_roswell') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuy = document.getElementById('heroBuyBtn');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuy) heroBuy.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuy = document.getElementById('ctaBuyBtn');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuy) ctaBuy.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }
</script>

<style>
  /* SWISS TECHNICAL BENTO THEME */
  :root {
    --bg-dark: #0a0a0a;
    --bg-card: #111111;
    --bg-card-hover: #161616;
    --border-color: rgba(255, 255, 255, 0.08);
    --text-primary: #FAFAFA;
    --text-secondary: #A1A1AA;
    --accent: #F59E0B;
    --accent-dim: rgba(245, 158, 11, 0.1);

    --font-serif: 'Cormorant Garamond', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;
  }

  .case-file {
    background-color: var(--bg-dark);
    color: var(--text-primary);
    font-family: var(--font-sans);
    overflow-x: hidden;
  }

  /* UTILS */
  .text-accent { color: var(--accent); }

  /* HERO */
  .hero {
    position: relative;
    height: 90vh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-bottom: 1px solid var(--border-color);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.4) grayscale(0.8) contrast(1.2);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 0%, var(--bg-dark) 90%);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 900px;
    padding: 0 1.5rem;
  }

  .case-meta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .meta-badge {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border-color);
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(4px);
    color: var(--text-secondary);
  }

  .meta-badge.alert {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  .meta-badge.price {
    border-color: var(--accent);
    background: var(--accent-dim);
    color: var(--accent);
    font-weight: 800;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 8vw, 6rem);
    line-height: 0.9;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    text-shadow: 0 10px 30px rgba(0,0,0,0.7);
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    color: var(--text-secondary);
    font-weight: 300;
    margin-bottom: 4rem;
    letter-spacing: 0.02em;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
  }

  .stat-value {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    z-index: 10;
  }

  .scroll-indicator span {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--text-secondary);
    opacity: 0.7;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--text-secondary) 0%, transparent 100%);
  }

  /* HERO ACTIONS */
  .hero-actions {
    margin-top: 3rem;
  }

  /* PRIMARY BUY BUTTON */
  .btn-buy-primary {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
    color: #000;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: all 0.25s;
    box-shadow: 0 4px 24px rgba(245, 158, 11, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .btn-buy-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(245, 158, 11, 0.45), 0 4px 12px rgba(0, 0, 0, 0.3);
    background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%);
  }

  .btn-buy-text {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .btn-buy-price {
    font-size: 1.125rem;
    font-weight: 800;
    padding: 0.25rem 0.75rem;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 4px;
  }

  /* PRIMARY DOWNLOAD BUTTON */
  .btn-download-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, #5DB585 0%, #4a9e70 100%);
    color: #000;
    text-decoration: none;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-sans);
    transition: all 0.25s;
    box-shadow: 0 4px 24px rgba(93, 181, 133, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .btn-download-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(93, 181, 133, 0.45), 0 4px 12px rgba(0, 0, 0, 0.3);
    background: linear-gradient(135deg, #6FC494 0%, #5DB585 100%);
  }

  .cta-buy, .cta-download {
    width: 100%;
    justify-content: center;
  }

  /* INTRO */
  .intro-section {
    padding: 8rem 1.5rem;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .intro-text p {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .intro-text strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* BENTO GRID */
  .bento-section {
    padding: 2rem 1.5rem 8rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(2, minmax(200px, auto));
    }

    .large-card {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  .bento-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    padding: 2rem;
    border-radius: 4px;
    transition: transform 0.3s ease, border-color 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .bento-card:hover {
    transform: translateY(-2px);
    border-color: rgba(255,255,255,0.2);
    background: var(--bg-card-hover);
  }

  .card-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .card-value {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .discovery-card .card-value { font-size: 5rem; font-weight: 700; }
  .check-card .card-value { font-size: 4rem; }

  .card-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* EVIDENCE */
  .evidence-section {
    padding: 4rem 1.5rem;
    background: #0F0F0F;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 400;
  }

  .evidence-grid {
    max-width: 1000px;
