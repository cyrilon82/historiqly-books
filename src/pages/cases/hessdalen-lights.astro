---
import Layout from '../../layouts/Layout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-hessdalen-valley-winter.jpg',
  village: '/cases/images/hessdalen-village-winter.jpg',
  farms: '/cases/images/hessdalen-farms-abandoned.jpg',
  church: '/cases/images/hessdalen-church.jpg',
  plasma: '/cases/images/water-plasma-lab.jpg',
  community: '/cases/images/hessdalen-community-winter.jpg',
};
---

<SidebarLayout
  title="The Hessdalen Lights — The Valley That Glows in the Dark"
  description="The Hessdalen Lights: For over 40 years, mysterious lights have appeared in a remote Norwegian valley — hovering silently, pulsing with impossible energy, and defying every scientific explanation. $2.99 EPUB."
  currentVolume={8}
  image="/books/covers/hessdalen-lights.jpg"
  ogType="book"
  keywords="hessdalen lights book, hessdalen lights ebook, norway mystery lights, unexplained phenomena, erling strand, project hessdalen, atmospheric mystery"
  bookSeo={{ bookTitle: "The Hessdalen Lights", subtitle: "The Valley That Glows in the Dark", price: "2.99", author: "HistorIQly Mysteries", genre: "Non-Fiction, Science, Unexplained", format: "EBook", keywords: "hessdalen lights, norway, unexplained, plasma, atmospheric phenomena" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Unexplained", url: "/vol/unexplained" }, { name: "The Hessdalen Lights", url: "/cases/hessdalen-lights" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 08-1981</span>
          <span class="meta-badge alert">STATUS: UNSOLVED</span>
        </div>

        <h1 class="hero-title">The Hessdalen Lights</h1>
        <p class="hero-subtitle">The Valley That Glows in the Dark</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">First Modern Sighting</span>
            <span class="stat-value">1981</span>
          </div>
          <div class="stat">
            <span class="stat-label">Peak Radar Speed</span>
            <span class="stat-value">30,000 km/h</span>
          </div>
           <div class="stat">
            <span class="stat-label">Years Monitored</span>
            <span class="stat-value text-accent">40+</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','hessdalen-lights');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
          </div>
          <a href="/books/epub/hessdalen-lights.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">On a December evening in 1981, a Norwegian farmer and his wife watched a burning fireball drift silently above their valley. Within weeks, the entire community of 150 people was seeing lights — fifteen to twenty sightings per week. Glowing spheres that hovered, split, merged, and accelerated to speeds no aircraft could match. Forty years later, an automated station still watches the sky. The lights still come. And no one can explain why.</p>
        <p>Radar speeds of <strong>30,000 km/h</strong>. Radiant power up to <strong>100 kilowatts</strong>. A laser interaction that science cannot account for.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Phenomenon</span>
            <h3 class="card-value">1981</h3>
            <p class="card-desc">The modern wave began in December 1981, though residents reported unusual lights as far back as the 1930s. At its peak, 15-20 sightings per week were recorded across the 15 km valley.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Radar Speed</span>
            <h3 class="card-value text-accent">30,000 km/h</h3>
            <p class="card-desc">The highest velocity measured during the 1984 field campaign — more than 12 times faster than any aircraft on Earth. Silent. No sonic boom.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">Radiant Power</span>
            <h3 class="card-value">100 kW</h3>
            <p class="card-desc">Measured luminous output — more than 50 times brighter than a helicopter searchlight, sustained without any visible energy source.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Laser Response</span>
            <h3 class="card-value">8/9</h3>
            <p class="card-desc">Times a hovering light changed its flash pattern in response to a laser beam — switching from single to double flash, then reverting when the beam moved away.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.village} alt="Hessdalen valley in winter" />
            <div class="visual-overlay">
              <span class="overlay-label">HESSDALEN 1981</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Valley</h3>
            <p>A 15 km valley in central Norway, population ~150, split by the river Hesja. West side: zinc and iron-rich rocks. East side: copper-rich rocks. Old flooded sulfur mines leach acid into the river. The geology is unlike anywhere else on Earth — and so are the lights.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.farms} alt="Farms in the Hessdalen valley" />
            <div class="visual-overlay">
               <span class="overlay-label">1984 CAMPAIGN</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Investigation</h3>
            <p>In January 1984, Erling Strand led a five-week field campaign with borrowed equipment and volunteer labor. They recorded 53 light observations, 30 radar echoes, and the extraordinary laser interaction experiment — the first scientific evidence that the lights respond to external stimulation.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.plasma} alt="Laboratory plasma experiment" />
            <div class="visual-overlay">
               <span class="overlay-label">THE GIANT BATTERY</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Theory</h3>
            <p>Italian engineer Jader Monari discovered that the valley functions as a giant natural battery: zinc on one side, copper on the other, the sulfur-laden river as electrolyte. He built a working model from actual valley rocks — and it generated current. The energy to power the lights may come from the earth itself.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">Four Decades of Mystery</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">1981</span>
          <div class="timeline-content">
            <h4>The First Modern Sighting</h4>
            <p>Aage and Ruth Marry Moe see "a burning fireball" above the valley. Within weeks, the entire community is reporting 15-20 sightings per week.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1984</span>
          <div class="timeline-content">
            <h4>The Field Campaign</h4>
            <p>Erling Strand's team records 53 observations, 30 radar echoes, and the laser interaction effect during five weeks in the deep Norwegian winter.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1998</span>
          <div class="timeline-content">
            <h4>The Blue Box</h4>
            <p>An automated measurement station begins continuous surveillance of the valley — cameras, magnetometers, and sensors watching the sky 24/7.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">2004</span>
          <div class="timeline-content">
            <h4>The Italian Connection</h4>
            <p>Massimo Teodorani publishes his seminal paper — measuring radiant power up to 19 kW, detecting elevated radioactivity, and identifying scandium in the light spectrum.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">2024</span>
          <div class="timeline-content highlight">
            <h4>Beneath the Surface</h4>
            <p>A VLF electromagnetic survey reveals conductive sulfide zones and a 6x12 km elliptical gabbro intrusion beneath the valley — the geological engine that may power the lights.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.church} alt="Hessdalen church" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Engineer</span>
            <h3>Erling Strand</h3>
            <p>Electrical engineer who founded Project Hessdalen in 1983 after witnessing the lights himself. He spent 40 years leading the scientific investigation — never claiming more than the data supported, never retreating from what it showed.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.community} alt="Hessdalen valley community" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Astrophysicist</span>
            <h3>Massimo Teodorani</h3>
            <p>Italian astrophysicist who led the EMBLA missions (2000-2002) and published the most-cited paper on the phenomenon. His measurements transformed the lights from anomaly to research program.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.farms} alt="The Hessdalen valley" />
          <div class="image-caption">The Hessdalen valley, central Norway.</div>
        </div>
        <div class="conclusion-text">
          <h2>The Valley Still Glows</h2>
          <p>After four decades of observation, multiple international research campaigns, and continuous automated monitoring, the Hessdalen Lights remain the most thoroughly documented unexplained atmospheric phenomenon on Earth.</p>
          <p>The Blue Box still watches. The lights still come. <em>And the valley keeps its secret.</em></p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the mysterious lights, the scientists who chased them, and the ancient geology that may have created them.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','hessdalen-lights');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
            </div>
            <a href="/books/epub/hessdalen-lights.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_hessdalen-lights', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_hessdalen-lights') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>
