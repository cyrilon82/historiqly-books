---
import Layout from '../../layouts/Layout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-antwerp-diamond-district.jpg',
  shops: '/cases/images/atmosphere-antwerp-diamond-shops.jpg',
  station: '/cases/images/atmosphere-antwerp-central-station.jpg',
  skyline: '/cases/images/atmosphere-antwerp-skyline.jpg',
  vault1908: '/cases/images/evidence-safe-deposit-vault-1908.jpg',
  vaultDoor: '/cases/images/evidence-bank-vault-door.png',
  diamonds: '/cases/images/evidence-diamond-assortment.jpg',
  safeDeposit: '/cases/images/evidence-vault-door-safe-deposit.jpg',
};
---

<SidebarLayout
  title="Antwerp Diamond Heist Book — The Perfect Crime"
  description="The Antwerp Diamond Heist: How thieves beat ten layers of security to steal $100 million in diamonds. Non-fiction ebook. $2.99 EPUB."
  currentVolume={11}
  image="/books/covers/antwerp-diamond-heist.jpg"
  ogType="book"
  keywords="Antwerp diamond heist book, diamond heist ebook, biggest diamond theft, Belgian heist, perfect crime, diamond vault robbery, heist non-fiction"
  bookSeo={{ bookTitle: "The Antwerp Diamond Heist", subtitle: "The Thieves Who Beat Ten Layers of Security", price: "2.99", author: "HistorIQly Mysteries", genre: "Non-Fiction, True Crime, Heists", format: "EBook", keywords: "Antwerp diamond heist, diamond theft, Belgium, heist" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Heists", url: "/vol/heists" }, { name: "Antwerp Diamond Heist", url: "/cases/antwerp-diamond-heist" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 03-2003</span>
          <span class="meta-badge alert">STATUS: SOLVED</span>
        </div>

        <h1 class="hero-title">The Antwerp Diamond Heist</h1>
        <p class="hero-subtitle">The Thieves Who Beat Ten Layers of Security</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Heist Date</span>
            <span class="stat-value">2003</span>
          </div>
          <div class="stat">
            <span class="stat-label">Value Stolen</span>
            <span class="stat-value text-accent">$100M+</span>
          </div>
           <div class="stat">
            <span class="stat-label">Planning</span>
            <span class="stat-value">28 Months</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','antwerp-diamond-heist');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
            <a href="https://www.amazon.com/dp/B0GQ82SFX7" target="_blank" rel="noopener" class="btn-buy-kindle">
              Buy on Kindle →
            </a>
          </div>
          <a href="/books/epub/antwerp-diamond-heist.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">On a February weekend in 2003, four men crawled on their bellies through the basement of the Antwerp Diamond Centre, defeated ten layers of supposedly impenetrable security with hairspray and electrical tape, and walked out with over $100 million in diamonds. They were undone by a half-eaten sandwich.</p>
        <p>It took <strong>28 months</strong> of planning, a replica vault, and a man who could duplicate a key from a photograph.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Target</span>
            <h3 class="card-value">189</h3>
            <p class="card-desc">Safe deposit boxes in the Antwerp Diamond Centre vault, two floors below street level. The crew broke into 109 of them on a single weekend, extracting approximately 120,000 carats of loose diamonds.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Security Layers</span>
            <h3 class="card-value text-accent">10</h3>
            <p class="card-desc">Cameras, light sensors, infrared, magnetic, Doppler radar, seismic, combination lock, vault key, window alarms, guards.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">Caught After</span>
            <h3 class="card-value">5 Days</h3>
            <p class="card-desc">DNA from a sandwich led police to the mastermind.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Recovered</span>
            <h3 class="card-value">$0</h3>
            <p class="card-desc">Aside from 17 diamonds in the mastermind's home safe, the $100M+ haul has never been found.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.vaultDoor} alt="A steel bank vault door" />
            <div class="visual-overlay">
              <span class="overlay-label">VAULT DOOR: 3 TONS</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Ten Layers Defeated</h3>
            <p>The vault was protected by cameras, light sensors, infrared detectors, magnetic locks, Doppler radar, seismic sensors, a combination lock with 100 million possible sequences, a foot-long key, window alarms, and private security guards. The crew defeated every single one — using hairspray, electrical tape, Styrofoam, and patience.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.diamonds} alt="An assortment of cut diamonds" />
            <div class="visual-overlay">
               <span class="overlay-label">120,000 CARATS STOLEN</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Haul</h3>
            <p>From 109 broken safe deposit boxes, the crew extracted approximately 120,000 carats of loose diamonds, gold bars, cash, rare coins, and jewelry. The Guinness Book of World Records certified it as the largest diamond heist in history. Most of the loot remains missing over two decades later.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.vault1908} alt="Interior of a safe deposit vault" />
            <div class="visual-overlay">
               <span class="overlay-label">EVIDENCE: FLOORDAMBOS WOODS</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Sandwich</h3>
            <p>The crew's logistics man dumped garbage bags in a forest near the E19 motorway instead of destroying them. A local shopkeeper found the bags, which contained Diamond Centre envelopes, tools, a videotape — and a half-eaten salami sandwich. The DNA matched mastermind Leonardo Notarbartolo.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">The Heist of the Century</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">2000</span>
          <div class="timeline-content">
            <h4>The Infiltration</h4>
            <p>Leonardo Notarbartolo rents an office in the Antwerp Diamond Centre for $700/month, posing as an Italian gem importer. He installs hidden cameras and spends 28 months studying the vault's ten security layers from the inside.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">FEB 2003</span>
          <div class="timeline-content highlight">
            <h4>The Heist</h4>
            <p>Over Valentine's Day weekend, the crew enters through a neighbouring building, defeats all ten layers, and empties 109 safe deposit boxes. Estimated value: over $100 million in diamonds, gold, and jewelry.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">FEB 2003</span>
          <div class="timeline-content">
            <h4>The Mistake</h4>
            <p>Garbage bags containing evidence — including a DNA-laden sandwich — are dumped in a forest instead of being destroyed. A local shopkeeper finds them and calls the police. Notarbartolo is arrested within five days.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">2005</span>
          <div class="timeline-content">
            <h4>The Verdict</h4>
            <p>Notarbartolo sentenced to 10 years. Three accomplices receive 5 years each. The "King of Keys" — the man who forged the vault key — is never identified or caught. Over $100 million remains unrecovered.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">2025</span>
          <div class="timeline-content">
            <h4>The Documentary</h4>
            <p>Netflix releases "Stolen: Heist of the Century." Notarbartolo appears on camera for the first time: "We felt proud of doing something so strong and powerful."</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.shops} alt="Antwerp Diamond District shops" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Mastermind</span>
            <h3>Leonardo Notarbartolo</h3>
            <p>A professional thief from Turin who spent 28 months posing as a gem importer inside the Diamond Centre. He studied every guard rotation, every camera angle, and every security system — then recruited a crew from the School of Turin to execute the most technically sophisticated heist in history.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.safeDeposit} alt="Safe deposit room door" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Ghost</span>
            <h3>The King of Keys</h3>
            <p>The only team member never identified or caught. He duplicated the Diamond Centre's supposedly impossible-to-forge, foot-long vault key from video footage alone. His real name remains unknown to this day — the one mystery the heist of the century never solved.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.station} alt="Antwerp Central Station, adjacent to the Diamond District" />
          <div class="image-caption">Antwerp Centraal Station, adjacent to the Diamond District.</div>
        </div>
        <div class="conclusion-text">
          <h2>Every Lock Is a Puzzle</h2>
          <p>The most technically sophisticated theft in history was undone by the most basic failure of discipline — a garbage bag dumped in a forest.</p>
          <p>Twenty-eight months of preparation. A replica vault. Ten defeated security layers. <em>And a sandwich that should have been burned.</em></p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the School of Turin, the ten-layer vault, and the heist of the century.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','antwerp-diamond-heist');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
              <a href="https://www.amazon.com/dp/B0GQ82SFX7" target="_blank" rel="noopener" class="btn-buy-kindle cta-kindle">
                Buy on Kindle →
              </a>
            </div>
            <a href="/books/epub/antwerp-diamond-heist.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_antwerp-diamond-heist', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_antwerp-diamond-heist') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

