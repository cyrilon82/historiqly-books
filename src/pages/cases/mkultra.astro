---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-mkultra-declassified-documents.jpg',
  lsdDoc: '/cases/images/evidence-mkultra-lsd-document.jpg',
  declassifiedPage: '/cases/images/evidence-mkultra-declassified-page.png',
  gottlieb: '/cases/images/figure-sidney-gottlieb.jpg',
  olson: '/cases/images/victim-frank-olson.jpg',
  allanMemorial: '/cases/images/location-allan-memorial-institute.jpg',
  senateReport: '/cases/images/hero-mkultra-senate-report.jpg',
};
---

<SidebarLayout
  title="MKUltra Book — CIA Mind Control Program"
  description="MKUltra: The CIA's secret mind control program exposed. Non-fiction ebook about LSD experiments, declassified documents, and government conspiracies. $2.99 EPUB."
  currentVolume={7}
  image="/books/covers/mkultra.jpg"
  ogType="book"
  keywords="MKUltra book, MKUltra ebook, CIA mind control, MK Ultra LSD experiments, declassified CIA programs, conspiracy non-fiction, government secrets book, mind control program, Sidney Gottlieb, Project MKUltra"
  bookSeo={{
    bookTitle: "MKUltra",
    subtitle: "The CIA's Secret War on the Mind",
    price: "2.99",
    author: "HistorIQly Mysteries",
    genre: "Non-Fiction, History, Conspiracy, Declassified",
    format: "EBook",
    keywords: "MKUltra, CIA, mind control, LSD, declassified",
  }}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Declassified", url: "/vol/declassified" },
    { name: "MKUltra", url: "/cases/mkultra" },
  ]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 07-1953</span>
          <span class="meta-badge alert">STATUS: CONFIRMED</span>
        </div>

        <h1 class="hero-title">MKUltra</h1>
        <p class="hero-subtitle">The CIA's Secret War on the Mind</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Authorised</span>
            <span class="stat-value">1953</span>
          </div>
          <div class="stat">
            <span class="stat-label">Exposed</span>
            <span class="stat-value">1975</span>
          </div>
           <div class="stat">
            <span class="stat-label">Duration</span>
            <span class="stat-value text-accent">20 Years</span>
          </div>
        </div>

        <div class="hero-actions">
          <div class="buy-options" id="heroBuyOptions">
            <button onclick={`localStorage.setItem('historiqly_purchasing','mkultra');window.location.href='${stripeUrl}'`} class="btn-buy-primary">
              <span class="btn-buy-text">Buy on Website</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
            <a href="https://www.amazon.com/dp/B0GQ3QJWZY" target="_blank" rel="noopener" class="btn-buy-kindle">
              Buy on Kindle →
            </a>
          </div>
          <a href="/books/epub/mkultra.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">In 1953, the CIA launched a covert program to crack the code of human consciousness — through LSD, electroshock, sensory deprivation, and psychological torture. For twenty years, thousands of unwitting Americans were used as test subjects.</p>
        <p>When the files were ordered destroyed, <strong>20,000 pages</strong> survived by accident.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Program</span>
            <h3 class="card-value">149</h3>
            <p class="card-desc">Separate subprojects conducted at 80 institutions — universities, hospitals, prisons, and pharmaceutical companies across the United States and Canada.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Criminal Charges</span>
            <h3 class="card-value text-accent">0</h3>
            <p class="card-desc">No one was ever prosecuted for MKUltra.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">Test Subjects</span>
            <h3 class="card-value">7,000+</h3>
            <p class="card-desc">Soldiers dosed at Edgewood Arsenal alone. Total victims unknown.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Files Destroyed</span>
            <h3 class="card-value">~80%</h3>
            <p class="card-desc">Ordered shredded by CIA Director Richard Helms in 1973.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">Declassified Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.lsdDoc} alt="Declassified MKUltra LSD document" />
            <div class="visual-overlay">
              <span class="overlay-label">CIA FOIA RELEASE</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The LSD Experiments</h3>
            <p>Gottlieb purchased the world's entire supply of LSD from Sandoz Laboratories. Unwitting subjects — prisoners, addicts, psychiatric patients — were dosed without knowledge or consent. Operation Midnight Climax ran CIA safe houses where prostitutes lured men to be drugged and observed through one-way mirrors.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.allanMemorial} alt="Allan Memorial Institute, Montreal" />
            <div class="visual-overlay">
               <span class="overlay-label">SUBPROJECT 68</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Psychic Driving</h3>
            <p>At the Allan Memorial Institute in Montreal, Dr. Donald Ewen Cameron subjected patients to electroshock at many times normal voltage, drug-induced comas lasting months, and recorded messages played on loop half a million times — erasing their memories, identities, and ability to function.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.declassifiedPage} alt="Declassified MKUltra authorization page" />
            <div class="visual-overlay">
               <span class="overlay-label">DECLASSIFIED 1977</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Paper Trail</h3>
            <p>In 1973, CIA Director Richard Helms ordered all MKUltra files destroyed. But 20,000 financial records survived — misfiled in the wrong archive. They were enough to reconstruct the program's scope and prove what the CIA had done to its own citizens.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">20 Years in the Shadows</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">1953</span>
          <div class="timeline-content">
            <h4>Program Authorised</h4>
            <p>CIA Director Allen Dulles approves MKUltra. Sidney Gottlieb is appointed director with virtually unlimited budget and no oversight.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1953</span>
          <div class="timeline-content">
            <h4>Frank Olson Dies</h4>
            <p>Army scientist Frank Olson, covertly dosed with LSD by Gottlieb, falls from the 13th floor of the Hotel Statler. The CIA calls it suicide.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1955</span>
          <div class="timeline-content">
            <h4>Midnight Climax</h4>
            <p>CIA safe houses in San Francisco and New York begin dosing unwitting citizens with LSD. The operation runs for a decade.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">1973</span>
          <div class="timeline-content">
            <h4>Files Destroyed</h4>
            <p>Director Helms orders the destruction of all MKUltra records before leaving office. Most are shredded and incinerated.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">1975</span>
          <div class="timeline-content highlight">
            <h4>The Church Committee</h4>
            <p>Senator Frank Church's investigation exposes MKUltra. The image of Church holding a CIA dart gun on live TV becomes iconic.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Key Figures</span>
        <h2 class="section-title">The Poisoner & The Victim</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.gottlieb} alt="Sidney Gottlieb" />
          </div>
          <div class="figure-info">
            <h3>Sidney Gottlieb</h3>
            <span class="figure-role">MKUltra Director, 1953–1973</span>
            <p>The CIA chemist known as the "Poisoner in Chief." He oversaw 149 subprojects, purchased the world supply of LSD, personally dosed unwitting colleagues, and ordered the destruction of evidence. He died in 1999, never prosecuted.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.olson} alt="Frank Olson" />
          </div>
          <div class="figure-info">
            <h3>Frank Olson</h3>
            <span class="figure-role">Army Scientist, 1910–1953</span>
            <p>A biochemist at Fort Detrick who was covertly dosed with LSD by Gottlieb. Nine days later he fell from a hotel window. A 1994 exhumation revealed a cranial wound inconsistent with a fall. His family spent fifty years seeking the truth.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.senateReport} alt="1977 Senate report on MKUltra" />
          <div class="image-caption">The 1977 Senate report that exposed MKUltra to the public.</div>
        </div>
        <div class="conclusion-text">
          <h2>The Files Are Open</h2>
          <p>No criminal charges. No prison sentences. A $750,000 settlement for the Olson family. Cameron's patients in Montreal eventually received compensation from the Canadian government — approximately $100,000 each for years of experimentation that destroyed their minds.</p>
          <p>The twenty thousand surviving pages sit in the National Archives. They are enough to prove what the CIA did. The question is whether anyone is still reading.</p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>8 chapters. The complete story of the chemist, the psychiatrist, the victims, and the cover-up that almost succeeded.</p>
            <div class="buy-options cta-buy-options" id="ctaBuyOptions">
              <button onclick={`localStorage.setItem('historiqly_purchasing','mkultra');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy">
                <span class="btn-buy-text">Buy on Website</span>
                <span class="btn-buy-price">$2.99</span>
              </button>
              <a href="https://www.amazon.com/dp/B0GQ3QJWZY" target="_blank" rel="noopener" class="btn-buy-kindle cta-kindle">
                Buy on Kindle →
              </a>
            </div>
            <a href="/books/epub/mkultra.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_mkultra', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_mkultra') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuyOptions = document.getElementById('heroBuyOptions');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuyOptions) heroBuyOptions.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuyOptions = document.getElementById('ctaBuyOptions');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuyOptions) ctaBuyOptions.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

