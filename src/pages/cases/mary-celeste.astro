---
import Layout from '../../layouts/Layout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import CornerOrnaments from '../../components/CornerOrnaments.astro';
import HeroGlow from '../../components/HeroGlow.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const stripeUrl = import.meta.env.PUBLIC_STRIPE_BUY_URL;

const images = {
  hero: '/cases/images/hero-mary-celeste.jpg',
  amazon: '/cases/images/mary-celeste-as-amazon.jpg',
  briggs: '/cases/images/figure-captain-briggs.jpg',
  sarah: '/cases/images/figure-sarah-briggs.jpg',
  sophia: '/cases/images/figure-sophia-briggs.jpg',
  richardson: '/cases/images/figure-albert-richardson.jpg',
  conanDoyle: '/cases/images/suspect-conan-doyle.jpg',
  gibraltarHarbor: '/cases/images/gibraltar-harbor-aivazovsky.jpg',
  gibraltarWharf: '/cases/images/gibraltar-waterport-wharf-1878.jpg',
  nytimes: '/cases/images/nytimes-1873-mary-celeste.jpg',
  chart: '/cases/images/nautical-chart-north-atlantic-1870.jpg',
  atmosphere: '/cases/images/atmosphere-sailing-ship-sea.jpg',
};
---

<SidebarLayout
  title="Mary Celeste Book — Ghost Ship Mystery"
  description="The Mary Celeste: The ghost ship found adrift in the Atlantic with no crew. Non-fiction ebook investigating maritime history's greatest mystery. $2.99 EPUB."
  currentVolume={4}
  image="/books/covers/mary-celeste.jpg"
  ogType="book"
  keywords="Mary Celeste book, Mary Celeste ebook, ghost ship mystery, maritime disappearance, abandoned ship 1872, nautical mysteries non-fiction"
  bookSeo={{ bookTitle: "The Mary Celeste", subtitle: "The Ghost Ship That Haunted the Atlantic", price: "2.99", author: "HistorIQly Mysteries", genre: "Non-Fiction, History, Disappearances, Maritime", format: "EBook", keywords: "Mary Celeste, ghost ship, maritime mystery, disappearance" }}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Disappearances", url: "/vol/disappearances" }, { name: "The Mary Celeste", url: "/cases/mary-celeste" }]}
>
  <article class="case-file">

    <!-- HERO SECTION -->
    <header class="hero">
      <div class="hero-bg">
        <img src={images.hero} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <HeroGlow />
      <CornerOrnaments />
      <div class="hero-content">
        <div class="case-meta">
          <span class="meta-badge price">$2.99</span>
          <span class="meta-badge">CASE 03-1872</span>
          <span class="meta-badge alert">STATUS: UNSOLVED</span>
        </div>

        <h1 class="hero-title">The Mary Celeste</h1>
        <p class="hero-subtitle">The Ghost Ship That Haunted the Atlantic</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-label">Found</span>
            <span class="stat-value">1872</span>
          </div>
          <div class="stat">
            <span class="stat-label">Missing</span>
            <span class="stat-value text-accent">10 Souls</span>
          </div>
           <div class="stat">
            <span class="stat-label">Cargo</span>
            <span class="stat-value">1,701 Barrels</span>
          </div>
        </div>

        <div class="hero-actions">
          <button onclick={`localStorage.setItem('historiqly_purchasing','mary-celeste');window.location.href='${stripeUrl}'`} class="btn-buy-primary" id="heroBuyBtn">
            <span class="btn-buy-text">Buy the Book</span>
            <span class="btn-buy-price">$2.99</span>
          </button>
          <a href="/books/epub/mary-celeste.epub" class="btn-download-primary" id="heroDownloadBtn" style="display:none;" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download Your Book</span>
          </a>
        </div>
      </div>

       <div class="scroll-indicator">
        <span>INVESTIGATE</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <!-- THE HOOK -->
    <section class="intro-section fade-in-section">
      <div class="intro-text">
        <p class="drop-cap">On a grey December afternoon in 1872, a Canadian brigantine spotted a ship drifting in the mid-Atlantic. Her sails were torn. Her helm was unmanned. When sailors climbed aboard, they found food in the pantry, cargo in the hold, and personal belongings in every cabin. But every soul aboard had vanished.</p>
        <p>No bodies. No struggle. No explanation. Just <strong>silence</strong>.</p>
      </div>
    </section>

    <!-- BENTO GRID STATS -->
    <section class="bento-section fade-in-section">
      <div class="bento-grid">

        <div class="bento-card large-card discovery-card">
          <div class="card-content">
            <span class="card-label">The Voyage</span>
            <h3 class="card-value">Nov 7</h3>
            <p class="card-desc">Captain Benjamin Briggs sails from New York with his wife Sarah, two-year-old daughter Sophia, and seven crew. Destination: Genoa. Cargo: 1,701 barrels of industrial alcohol.</p>
          </div>
        </div>

        <div class="bento-card check-card">
          <div class="card-content">
            <span class="card-label">Last Log Entry</span>
            <h3 class="card-value text-accent">Nov 25</h3>
            <p class="card-desc">Position: 6 miles NE of Santa Maria, Azores. After this — silence.</p>
          </div>
        </div>

        <div class="bento-card papers-card">
          <div class="card-content">
            <span class="card-label">Days Adrift</span>
            <h3 class="card-value">10</h3>
            <p class="card-desc">Between the last log entry and discovery by the <em>Dei Gratia</em>.</p>
          </div>
        </div>

        <div class="bento-card fraud-card">
          <div class="card-content">
            <span class="card-label">Empty Barrels</span>
            <h3 class="card-value">9</h3>
            <p class="card-desc">All made of porous red oak. The alcohol seeped out and filled the hold with invisible, explosive vapour.</p>
          </div>
        </div>

      </div>
    </section>

        <SectionDivider />

    <!-- FORENSIC EVIDENCE -->
    <section class="evidence-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Exhibit A</span>
        <h2 class="section-title">The Evidence</h2>
      </div>

      <div class="evidence-grid">
        <!-- Item 1 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.amazon} alt="The Mary Celeste as Amazon, painting from 1861" />
            <div class="visual-overlay">
              <span class="overlay-label">SHIP: BUILT 1861</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Cursed Ship</h3>
            <p>Originally named the <em>Amazon</em>, the ship's first captain died on her maiden voyage. She suffered multiple collisions, a fire, and a grounding before being abandoned as a wreck. Rebuilt and renamed <em>Mary Celeste</em> in 1868, she seemed reborn — until November 1872.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.nytimes} alt="New York Times article about the Mary Celeste, February 1873" />
            <div class="visual-overlay">
               <span class="overlay-label">NYT: FEB 26, 1873</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>Piracy Suspected</h3>
            <p>Contemporary newspaper coverage from the <em>New York Times</em> reported suspicions of foul play: "spots of blood on the blade of a sword, in the cabin, and on the rails." Scientific analysis would later prove the stains were rust — not blood. But the damage to the story was done.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="evidence-card">
          <div class="evidence-visual">
            <img src={images.gibraltarWharf} alt="Waterport Wharf, Gibraltar, 1878" />
            <div class="visual-overlay">
               <span class="overlay-label">GIBRALTAR: 1878</span>
            </div>
          </div>
          <div class="evidence-data">
            <h3>The Inquisition</h3>
            <p>Attorney General Solly-Flood conducted a three-month investigation at the Vice Admiralty Court, alleging murder and conspiracy. He found no evidence. The salvage crew received a fraction of the normal award — punished for a crime that never happened.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- TIMELINE -->
    <section class="timeline-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Chronology</span>
        <h2 class="section-title">A Ghost Ship Is Born</h2>
      </div>

      <div class="timeline">
        <div class="timeline-line"></div>

        <div class="timeline-entry left">
          <span class="timeline-year">NOV 1872</span>
          <div class="timeline-content">
            <h4>The Departure</h4>
            <p>The <em>Mary Celeste</em> sails from Pier 50, New York, with Captain Briggs, his wife Sarah, two-year-old Sophia, and seven crew. Cargo: 1,701 barrels of denatured alcohol bound for Genoa.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">NOV 25</span>
          <div class="timeline-content highlight">
            <h4>The Last Entry</h4>
            <p>Final log entry at 8 AM: position six miles northeast of Santa Maria Island, Azores. The ship has been at sea for 18 days. After this — nothing.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">DEC 4</span>
          <div class="timeline-content">
            <h4>The Discovery</h4>
            <p>The <em>Dei Gratia</em> spots the <em>Mary Celeste</em> drifting 600 miles from Portugal. First Mate Deveau boards and finds her deserted. Lifeboat gone. Navigation instruments gone. Everything else untouched.</p>
          </div>
        </div>

        <div class="timeline-entry right">
          <span class="timeline-year">JAN 1884</span>
          <div class="timeline-content">
            <h4>The Fiction</h4>
            <p>Arthur Conan Doyle publishes a fictional account, misspelling the name as "Marie Celeste" and inventing details — warm meals, burning cigars — that replace the real facts forever.</p>
          </div>
        </div>

        <div class="timeline-entry left">
          <span class="timeline-year">MAY 2006</span>
          <div class="timeline-content">
            <h4>The Experiment</h4>
            <p>UCL chemist Dr. Andrea Sella demonstrates that alcohol vapour produces a flash explosion — terrifying but leaving no fire damage. The most likely cause of the crew's decision to abandon ship.</p>
          </div>
        </div>
      </div>
    </section>

        <SectionDivider />

    <!-- KEY FIGURES -->
    <section class="figures-section fade-in-section">
      <div class="section-header">
        <span class="section-label">Dossier</span>
        <h2 class="section-title">Key Figures</h2>
      </div>

      <div class="figures-grid">
        <div class="figure-card">
          <div class="figure-image">
            <img src={images.briggs} alt="Captain Benjamin Spooner Briggs" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Captain</span>
            <h3>Benjamin Briggs</h3>
            <p>A devout, teetotalling Massachusetts captain from a prominent seafaring family. He invested his savings in the <em>Mary Celeste</em> and brought his wife and infant daughter aboard. He was 37 years old and had never lost a ship.</p>
          </div>
        </div>

        <div class="figure-card">
          <div class="figure-image">
            <img src={images.conanDoyle} alt="Arthur Conan Doyle, c. 1890" />
          </div>
          <div class="figure-info">
            <span class="figure-role">The Mythmaker</span>
            <h3>Arthur Conan Doyle</h3>
            <p>Three years before creating Sherlock Holmes, Doyle published a fictional account of the <em>Mary Celeste</em> so convincing that readers mistook it for fact. His invented details replaced reality in the public imagination.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCLUSION -->
    <section class="conclusion-section fade-in-section">
      <div class="conclusion-grid">
        <div class="conclusion-image">
          <img src={images.gibraltarHarbor} alt="Ships near Gibraltar, by Aivazovsky, 1873" />
          <div class="image-caption">American Shipping off the Rock of Gibraltar. Ivan Aivazovsky, 1873.</div>
        </div>
        <div class="conclusion-text">
          <h2>Where Did They Go?</h2>
          <p>The most likely answer is the simplest. Leaking alcohol filled the hold with invisible vapour. A flash explosion blew open the hatches. Captain Briggs, believing his ship was about to burn, launched the lifeboat with his family and crew.</p>
          <p>The explosion left no fire. The ship sailed on without them. <em>They could not catch her.</em></p>

          <div class="cta-box" id="ctaBox">
            <h3 id="ctaTitle">Get the Full Book</h3>
            <p>The complete story of the captain, the ghost ship, the mythmaker, and the truth that took 134 years to find.</p>
            <button onclick={`localStorage.setItem('historiqly_purchasing','mary-celeste');window.location.href='${stripeUrl}'`} class="btn-buy-primary cta-buy" id="ctaBuyBtn">
              <span class="btn-buy-text">Buy the Book</span>
              <span class="btn-buy-price">$2.99</span>
            </button>
            <a href="/books/epub/mary-celeste.epub" class="btn-download-primary cta-download" id="ctaDownloadBtn" style="display:none;" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Your Book
            </a>
          </div>
        </div>
      </div>
    </section>

  </article>
</SidebarLayout>

<script>
  // Purchase detection (fallback — homepage handles the main redirect)
  const params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    localStorage.setItem('historiqly_purchased_mary-celeste', 'true');
    localStorage.removeItem('historiqly_purchasing');
    history.replaceState({}, '', window.location.pathname);
  }

  const hasPurchased = localStorage.getItem('historiqly_purchased_mary-celeste') === 'true';

  if (hasPurchased) {
    // Hero buttons
    const heroBuy = document.getElementById('heroBuyBtn');
    const heroDownload = document.getElementById('heroDownloadBtn');
    if (heroBuy) heroBuy.style.display = 'none';
    if (heroDownload) heroDownload.style.display = 'inline-flex';

    // CTA buttons
    const ctaBuy = document.getElementById('ctaBuyBtn');
    const ctaDownload = document.getElementById('ctaDownloadBtn');
    const ctaTitle = document.getElementById('ctaTitle');
    if (ctaBuy) ctaBuy.style.display = 'none';
    if (ctaDownload) ctaDownload.style.display = 'inline-flex';
    if (ctaTitle) ctaTitle.textContent = 'Your Book Is Ready';
  }

  // Scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
</script>

