---
import '../styles/globals.css';
import { volumes, icons } from "../data/volumes";
import { getFreeCases } from "../lib/cases";
import LaunchCountdown from "../components/LaunchCountdown.astro";
import FreeBookModal from "../components/FreeBookModal.astro";

interface BookSeo {
  bookTitle: string;
  subtitle: string;
  price: string;
  author: string;
  genre: string;
  format: string;
  keywords: string;
}

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description?: string;
  currentVolume?: number;
  image?: string;
  maxWidth?: string;
  keywords?: string;
  bookSeo?: BookSeo;
  breadcrumbs?: BreadcrumbItem[];
  ogType?: string;
}

const {
  title,
  description = "HistorIQly Mysteries — History's darkest mysteries, told as gripping mysteries. Narrative non-fiction you can't put down.",
  currentVolume,
  image = "/logo.png",
  maxWidth = "900px",
  keywords = "history mysteries, cold cases, conspiracies, AI investigation, evidence-based history, historical mysteries, unsolved cases, lost civilizations, secret societies, declassified documents, non-fiction ebooks, history books",
  bookSeo,
  breadcrumbs,
  ogType = "website",
} = Astro.props;

const siteUrl = "https://books.historiqly.com/";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(image, siteUrl).toString();
const fullTitle = `${title} | HistorIQly Mysteries`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="HistorIQly Mysteries" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Theme -->
    <meta name="theme-color" content="#5DB585" />
    <meta name="color-scheme" content="dark" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@400;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="HistorIQly Mysteries" />
    <meta property="og:locale" content="en_US" />
    {bookSeo && <meta property="og:book:author" content={bookSeo.author} />}
    {bookSeo && <meta property="product:price:amount" content={bookSeo.price} />}
    {bookSeo && <meta property="product:price:currency" content="USD" />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data: Website -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "HistorIQly Mysteries",
      url: siteUrl,
      description: "History's darkest mysteries, told as gripping mysteries.",
      publisher: {
        "@type": "Organization",
        name: "HistorIQly",
        url: "https://historiqly.com",
      },
    })} />

    {/* Structured Data: Book (per-page) */}
    {bookSeo && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Book",
        name: bookSeo.bookTitle,
        alternateName: bookSeo.subtitle,
        author: {
          "@type": "Organization",
          name: bookSeo.author,
        },
        publisher: {
          "@type": "Organization",
          name: "HistorIQly",
          url: "https://historiqly.com",
        },
        bookFormat: "https://schema.org/EBook",
        url: canonicalUrl,
        image: ogImage,
        description: description,
        genre: bookSeo.genre,
        inLanguage: "en",
        offers: {
          "@type": "Offer",
          price: bookSeo.price,
          priceCurrency: "USD",
          availability: "https://schema.org/InStock",
          url: canonicalUrl,
        },
      })} />
    )}

    {/* Structured Data: BreadcrumbList */}
    {breadcrumbs && breadcrumbs.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbs.map((crumb, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: crumb.name,
          item: new URL(crumb.url, siteUrl).toString(),
        })),
      })} />
    )}

    <script is:inline>
      // Apply collapsed state immediately to prevent layout shift
      if (localStorage.getItem('sidebarCollapsed') === 'true') {
        document.documentElement.classList.add('sidebar-collapsed');
      }
    </script>
  </head>
  <body>
    <!-- Top Bar -->
    <header class="top-bar">
      <div class="top-bar-content">
        <a href="/" class="logo">
          <img src="/logo.png" alt="HistorIQly" class="logo-img" />
          <span class="logo-title">Histor<span class="logo-iq">IQ</span>ly Mysteries</span>
        </a>
        <nav class="top-nav">
          <a href="https://x.com/historiqly" class="nav-link nav-icon" target="_blank" rel="noopener" aria-label="Follow on X">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://historiqly.com" class="btn-hq">
            HQ
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </nav>
        <button class="mobile-menu-btn" id="menuBtn" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <div class="layout">
      <!-- Sidebar -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
          <span class="sidebar-title">Volumes</span>
          <button class="collapse-btn" id="collapseBtn" aria-label="Collapse sidebar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
        </div>
        <nav class="sidebar-nav">
          {volumes.map((vol) => {
            const hasFree = getFreeCases(vol.slug).length > 0;
            return (
              <a
                href={`/vol/${vol.slug}`}
                class:list={["sidebar-link", { active: currentVolume === vol.num }]}
                title={`${vol.title} - ${vol.totalCases} cases`}
              >
                <span class="vol-icon">
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <Fragment set:html={icons[vol.icon]} />
                  </svg>
                </span>
                <span class="vol-info">
                  <span class="vol-title">{vol.title}</span>
                  <span class="vol-progress">{vol.totalCases} cases</span>
                </span>
                {hasFree && <span class="available-badge">Free</span>}
              </a>
            );
          })}
        </nav>
        <div class="sidebar-external">
          <div class="sidebar-external-header">HistorIQly HQ</div>
          <a href="https://historiqly.com" class="sidebar-external-link" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
              <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
            </svg>
            <div class="external-link-text">
              <span class="external-link-title">Chat</span>
              <span class="external-link-desc">Talk to Einstein, Socrates & 140+ minds</span>
            </div>
          </a>
          <a href="https://blog.historiqly.com" class="sidebar-external-link" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
              <path d="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z"/>
            </svg>
            <div class="external-link-text">
              <span class="external-link-title">Blog</span>
              <span class="external-link-desc">Cold cases, time travel & Hollywood myths</span>
            </div>
          </a>
          <a href="https://x.com/historiqly" class="sidebar-external-link" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            <div class="external-link-text">
              <span class="external-link-title">Daily Brief</span>
              <span class="external-link-desc">History takes & AI conversations</span>
            </div>
          </a>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="main-content" style={`--content-max-width: ${maxWidth}`}>
        <slot />

        <!-- Footer -->
        <footer class="footer">
          <div class="footer-content">
            <p class="footer-left">
              <span class="footer-brand-name">Histor<span class="footer-iq">IQ</span>ly</span>
              <span class="footer-copy">&copy; 2026 &middot; AI-curated content</span>
            </p>
            <nav class="footer-links">
              <a href="https://app.historiqly.com" target="_blank" rel="noopener">Chat</a>
              <svg class="footer-glyph" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 2L9.5 6.5L14 8L9.5 9.5L8 14L6.5 9.5L2 8L6.5 6.5Z" /></svg>
              <a href="https://blog.historiqly.com" target="_blank" rel="noopener">Blog</a>
              <svg class="footer-glyph" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 2L9.5 6.5L14 8L9.5 9.5L8 14L6.5 9.5L2 8L6.5 6.5Z" /></svg>
              <a href="https://x.com/historiqly" target="_blank" rel="noopener">Daily Brief</a>
            </nav>
          </div>
        </footer>
      </main>
    </div>

    <script>
      const menuBtn = document.getElementById('menuBtn');
      const sidebar = document.getElementById('sidebar');
      const collapseBtn = document.getElementById('collapseBtn');

      // Check if we should open sidebar on page load (from Free Preview click)
      if (sessionStorage.getItem('openSidebar') === 'true') {
        sessionStorage.removeItem('openSidebar');
        // On mobile, open the sidebar
        if (window.innerWidth <= 768) {
          sidebar?.classList.add('open');
          menuBtn?.classList.add('open');
        } else {
          // On desktop, expand the sidebar if collapsed
          document.documentElement.classList.remove('sidebar-collapsed');
          localStorage.setItem('sidebarCollapsed', 'false');
        }
      }

      // Toggle collapse on desktop
      collapseBtn?.addEventListener('click', () => {
        document.documentElement.classList.toggle('sidebar-collapsed');
        const isCollapsed = document.documentElement.classList.contains('sidebar-collapsed');
        localStorage.setItem('sidebarCollapsed', isCollapsed ? 'true' : 'false');
      });

      menuBtn?.addEventListener('click', () => {
        sidebar?.classList.toggle('open');
        menuBtn?.classList.toggle('open');
      });

      // Close sidebar when clicking a link (mobile)
      document.querySelectorAll('.sidebar-link').forEach(link => {
        link.addEventListener('click', () => {
          if (window.innerWidth <= 768) {
            sidebar?.classList.remove('open');
            menuBtn?.classList.remove('open');
          }
        });
      });

      // Add click handler to Free Preview links to open sidebar on destination
      document.querySelectorAll('a[href*="/vol/hoaxes"]').forEach(link => {
        link.addEventListener('click', () => {
          sessionStorage.setItem('openSidebar', 'true');
        });
      });
    </script>

    <FreeBookModal />
    <LaunchCountdown />
  </body>
</html>

<style>
  :root {
    --primary: #5DB585;
    --primary-hover: #6FC494;
    --primary-dim: rgba(93, 181, 133, 0.08);
    --gold: #e3ab71;
    --gold-light: #f3e3c6;
    --gold-dk: #4b3a1f;
    --gold-glow: rgba(227, 171, 113, 0.28);
    --gold-border: rgba(227, 171, 113, 0.25);
    --background: #0f0c08;
    --surface: #1a1815;
    --surface-elevated: #222019;
    --surface-hover: #2a2720;
    --foreground: #ede9dd;
    --foreground-muted: #a09a92;
    --border: rgba(255, 255, 255, 0.06);
    --border-strong: rgba(255, 255, 255, 0.12);
    --muted: #7b7262;
    --sidebar-width: 220px;
    --sidebar-collapsed-width: 52px;
    --topbar-height: 48px;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    height: 100%;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background-color: var(--background);
    color: var(--foreground);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ── Top Bar ── */
  .top-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--topbar-height);
    background: rgba(15, 12, 8, 0.8);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(227, 171, 113, 0.1);
    z-index: 100;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .top-bar-content {
    max-width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
  }

  .logo-img {
    height: 28px;
    width: auto;
  }

  .logo-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--foreground);
    letter-spacing: -0.01em;
  }

  .logo-iq {
    background: linear-gradient(180deg, #f3e3c6 0%, #e3ab71 55%, #b97a37 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .top-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-link {
    color: var(--foreground-muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color var(--transition-fast, 0.2s);
  }

  .nav-link:hover {
    color: var(--gold-light);
  }

  .nav-icon {
    display: flex;
    align-items: center;
  }

  .btn-hq {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    background: rgba(40, 38, 31, 0.5);
    backdrop-filter: blur(8px);
    color: var(--gold);
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid rgba(227, 171, 113, 0.25);
    border-radius: 3px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    position: relative;
    box-shadow:
      inset 0 0 0 2px rgba(15, 12, 8, 0.8),
      inset 0 0 0 3px rgba(227, 171, 113, 0.08);
  }

  /* Corner dots on HQ button */
  .btn-hq::after {
    content: '';
    position: absolute;
    inset: 3px;
    background:
      radial-gradient(circle at 0% 0%, rgba(227, 171, 113, 0.3) 1px, transparent 1px),
      radial-gradient(circle at 100% 0%, rgba(227, 171, 113, 0.3) 1px, transparent 1px),
      radial-gradient(circle at 0% 100%, rgba(227, 171, 113, 0.3) 1px, transparent 1px),
      radial-gradient(circle at 100% 100%, rgba(227, 171, 113, 0.3) 1px, transparent 1px);
    pointer-events: none;
  }

  .btn-hq:hover {
    color: var(--gold-light);
    border-color: rgba(227, 171, 113, 0.45);
    box-shadow:
      inset 0 0 0 2px rgba(15, 12, 8, 0.7),
      inset 0 0 0 3px rgba(227, 171, 113, 0.15),
      0 0 12px rgba(227, 171, 113, 0.1);
  }

  .btn-hq svg {
    transition: transform 0.2s;
  }

  .btn-hq:hover svg {
    transform: translateX(2px);
  }

  /* ── Mobile Menu Button ── */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .mobile-menu-btn span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--gold);
    transition: all 0.3s;
    border-radius: 1px;
  }

  .mobile-menu-btn.open span:nth-child(1) {
    transform: rotate(45deg) translate(4px, 4px);
  }

  .mobile-menu-btn.open span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-btn.open span:nth-child(3) {
    transform: rotate(-45deg) translate(4px, -4px);
  }

  /* ── Layout ── */
  .layout {
    display: flex;
    padding-top: var(--topbar-height);
    min-height: 100vh;
  }

  /* ── Sidebar ── */
  .sidebar {
    position: fixed;
    top: var(--topbar-height);
    left: 0;
    bottom: 0;
    width: var(--sidebar-width);
    background: var(--surface);
    border-right: 1px solid rgba(227, 171, 113, 0.06);
    overflow-y: auto;
    scrollbar-width: none;
    z-index: 50;
    transition: width 0.2s;
    display: flex;
    flex-direction: column;
  }

  .sidebar::-webkit-scrollbar {
    width: 0;
    height: 0;
  }

  .sidebar-header {
    padding: 0.75rem;
    border-bottom: 1px solid rgba(227, 171, 113, 0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .sidebar-title {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold);
    transition: opacity 0.2s;
  }

  .collapse-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: none;
    border: none;
    color: var(--foreground-muted);
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s;
  }

  .collapse-btn:hover {
    background: var(--surface-elevated);
    color: var(--gold);
  }

  .sidebar-nav {
    padding: 0.5rem;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    text-decoration: none;
    color: var(--foreground-muted);
    font-size: 0.8125rem;
    transition: all 0.2s;
    margin-bottom: 0.125rem;
  }

  .sidebar-link:hover {
    background: var(--surface-elevated);
    color: var(--foreground);
  }

  .sidebar-link.active {
    background: rgba(227, 171, 113, 0.08);
    color: var(--gold);
    box-shadow: inset 3px 0 0 var(--gold);
  }

  .sidebar-link.unavailable {
    opacity: 0.5;
  }

  .vol-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--surface-elevated);
    border-radius: 4px;
    flex-shrink: 0;
    color: var(--foreground-muted);
    transition: all 0.2s;
  }

  .vol-icon svg {
    width: 18px;
    height: 18px;
  }

  .sidebar-link:hover .vol-icon {
    color: var(--gold);
    background: rgba(227, 171, 113, 0.1);
  }

  .sidebar-link.active .vol-icon {
    background: rgba(227, 171, 113, 0.15);
    color: var(--gold);
  }

  .vol-info {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .vol-title {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .vol-progress {
    font-size: 0.625rem;
    color: var(--foreground-muted);
    opacity: 0.7;
  }

  .new-dot {
    width: 6px;
    height: 6px;
    background: #22c55e;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }

  .available-badge {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.5rem;
    padding: 0.1rem 0.3rem;
    background: rgba(227, 171, 113, 0.1);
    color: var(--gold);
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }

  /* ── Main Content ── */
  .main-content {
    flex: 1;
    margin-left: var(--sidebar-width);
    padding: 1.5rem;
    min-height: calc(100vh - var(--topbar-height));
    transition: margin-left 0.2s;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow-x: visible;
