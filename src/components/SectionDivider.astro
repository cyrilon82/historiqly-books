---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={["section-divider", className]} aria-hidden="true">
  <span class="divider-rule-line"></span>
  <svg class="divider-star" viewBox="0 0 16 16" fill="currentColor">
    <path d="M8 2L9.5 6.5L14 8L9.5 9.5L8 14L6.5 9.5L2 8L6.5 6.5Z" />
  </svg>
  <span class="divider-rule-line"></span>
  <svg class="divider-diamond" viewBox="0 0 12 12" fill="currentColor">
    <path d="M6 1L8.5 6L6 11L3.5 6Z" />
  </svg>
  <span class="divider-rule-line"></span>
  <svg class="divider-star" viewBox="0 0 16 16" fill="currentColor">
    <path d="M8 2L9.5 6.5L14 8L9.5 9.5L8 14L6.5 9.5L2 8L6.5 6.5Z" />
  </svg>
  <span class="divider-rule-line"></span>
</div>
